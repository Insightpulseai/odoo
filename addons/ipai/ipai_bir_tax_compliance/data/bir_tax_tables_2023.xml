<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================ -->
        <!-- 2023 Philippine Monthly Withholding Tax Table (TRAIN Law)    -->
        <!-- ============================================================ -->
        <record id="bir_tax_table_monthly_2023" model="ipai.bir.tax.table">
            <field name="name">Monthly Withholding Tax Table 2023 (TRAIN)</field>
            <field name="table_type">monthly</field>
            <field name="effective_date">2023-01-01</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Bracket 1: 0 - 20,833 => 0 tax -->
        <record id="bir_bracket_monthly_2023_01" model="ipai.bir.tax.bracket">
            <field name="table_id" ref="bir_tax_table_monthly_2023"/>
            <field name="range_from">0</field>
            <field name="range_to">20833</field>
            <field name="base_tax">0</field>
            <field name="excess_rate">0</field>
            <field name="excess_over">0</field>
        </record>

        <!-- Bracket 2: 20,833 - 33,333 => 0 + 15% of excess over 20,833 -->
        <record id="bir_bracket_monthly_2023_02" model="ipai.bir.tax.bracket">
            <field name="table_id" ref="bir_tax_table_monthly_2023"/>
            <field name="range_from">20833</field>
            <field name="range_to">33333</field>
            <field name="base_tax">0</field>
            <field name="excess_rate">0.15</field>
            <field name="excess_over">20833</field>
        </record>

        <!-- Bracket 3: 33,333 - 66,667 => 1,875 + 20% of excess over 33,333 -->
        <record id="bir_bracket_monthly_2023_03" model="ipai.bir.tax.bracket">
            <field name="table_id" ref="bir_tax_table_monthly_2023"/>
            <field name="range_from">33333</field>
            <field name="range_to">66667</field>
            <field name="base_tax">1875</field>
            <field name="excess_rate">0.20</field>
            <field name="excess_over">33333</field>
        </record>

        <!-- Bracket 4: 66,667 - 166,667 => 8,541.80 + 25% of excess over 66,667 -->
        <record id="bir_bracket_monthly_2023_04" model="ipai.bir.tax.bracket">
            <field name="table_id" ref="bir_tax_table_monthly_2023"/>
            <field name="range_from">66667</field>
            <field name="range_to">166667</field>
            <field name="base_tax">8541.80</field>
            <field name="excess_rate">0.25</field>
            <field name="excess_over">66667</field>
        </record>

        <!-- Bracket 5: 166,667 - 666,667 => 33,541.80 + 30% of excess over 166,667 -->
        <record id="bir_bracket_monthly_2023_05" model="ipai.bir.tax.bracket">
            <field name="table_id" ref="bir_tax_table_monthly_2023"/>
            <field name="range_from">166667</field>
            <field name="range_to">666667</field>
            <field name="base_tax">33541.80</field>
            <field name="excess_rate">0.30</field>
            <field name="excess_over">166667</field>
        </record>

        <!-- Bracket 6: 666,667+ => 183,541.80 + 35% of excess over 666,667 -->
        <record id="bir_bracket_monthly_2023_06" model="ipai.bir.tax.bracket">
            <field name="table_id" ref="bir_tax_table_monthly_2023"/>
            <field name="range_from">666667</field>
            <field name="range_to">0</field>
            <field name="base_tax">183541.80</field>
            <field name="excess_rate">0.35</field>
            <field name="excess_over">666667</field>
        </record>

    </data>
</odoo>
