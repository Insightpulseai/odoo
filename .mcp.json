{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "azure": {
      "command": "npx",
      "args": ["-y", "@azure/mcp@latest", "server", "start"]
    },
    "figma": {
      "type": "http",
      "url": "https://figma.com/mcp"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "azure-devops": {
      "command": "npx",
      "args": ["-y", "@azure-devops/mcp", "insightpulseai"]
    },
    "wix": {
      "command": "npx",
      "args": [
        "-y", "@wix/mcp-remote@latest",
        "https://mcp.wix.com/mcp",
        "--header", "Authorization:${WIX_API_KEY}",
        "--header", "wix-account-id:c169c522-8188-4fc5-a7c4-8dcce7700ef6"
      ],
      "env": {
        "WIX_API_KEY": "${WIX_API_KEY}"
      }
    }
  }
}
