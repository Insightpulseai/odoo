<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- =====================================================
         Tax Audit Log — List View (read-only)
         ===================================================== -->
    <record id="view_tax_audit_log_tree" model="ir.ui.view">
        <field name="name">tax.audit.log.tree</field>
        <field name="model">tax.audit.log</field>
        <field name="arch" type="xml">
            <list string="Tax Audit Log" create="false" edit="false" delete="false">
                <field name="timestamp"/>
                <field name="exception_id"/>
                <field name="user_id"/>
                <field name="action"/>
                <field name="old_state"/>
                <field name="new_state"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <!-- =====================================================
         Tax Audit Log — Action
         ===================================================== -->
    <record id="action_tax_audit_log" model="ir.actions.act_window">
        <field name="name">Tax Audit Log</field>
        <field name="res_model">tax.audit.log</field>
        <field name="view_mode">list</field>
        <field name="context">{"create": false}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No audit log entries yet.
            </p>
            <p>
                The tax audit log records every state transition and review action
                on tax exceptions.
            </p>
        </field>
    </record>
</odoo>
