<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Source Form -->
    <record id="view_ipai_ai_agent_source_form" model="ir.ui.view">
        <field name="name">ipai.ai.agent.source.form</field>
        <field name="model">ipai.ai.agent.source</field>
        <field name="arch" type="xml">
            <form string="Agent Source">
                <header>
                    <button name="action_submit_for_indexing" type="object"
                            string="Submit for Indexing"
                            class="btn-primary"
                            invisible="status == 'processing'"/>
                    <button name="action_reindex" type="object"
                            string="Reindex"
                            invisible="status != 'indexed'"/>
                    <button name="action_deactivate" type="object"
                            string="Deactivate"
                            invisible="not active"/>
                    <button name="action_activate" type="object"
                            string="Activate"
                            invisible="active or status != 'indexed'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,processing,indexed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Source">
                            <field name="agent_id"/>
                            <field name="source_type"/>
                            <field name="active"/>
                        </group>
                        <group string="Content">
                            <field name="attachment_id"
                                   invisible="source_type not in ('pdf', 'docx', 'xlsx', 'pptx', 'image', 'document')"/>
                            <field name="url"
                                   invisible="source_type != 'weblink'"
                                   widget="url"/>
                            <field name="knowledge_ref"
                                   invisible="source_type != 'knowledge'"/>
                            <field name="mimetype"
                                   invisible="not attachment_id"/>
                            <field name="file_size"
                                   invisible="not attachment_id"/>
                            <field name="checksum"/>
                        </group>
                    </group>
                    <group string="External Identifiers">
                        <field name="external_source_id"/>
                        <field name="external_index_id"/>
                        <field name="processed_at"/>
                    </group>
                    <group string="Error" invisible="not last_error">
                        <field name="last_error" nolabel="1"
                               colspan="2" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Indexing History" name="runs">
                            <field name="run_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="create_date" string="Date"/>
                                    <field name="status"
                                           decoration-success="status == 'success'"
                                           decoration-danger="status == 'failed'"
                                           widget="badge"/>
                                    <field name="external_source_id"/>
                                    <field name="error_message"/>
                                    <field name="duration_ms"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Source List -->
    <record id="view_ipai_ai_agent_source_list" model="ir.ui.view">
        <field name="name">ipai.ai.agent.source.list</field>
        <field name="model">ipai.ai.agent.source</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="agent_id"/>
                <field name="source_type"/>
                <field name="status"
                       decoration-success="status == 'indexed'"
                       decoration-warning="status == 'processing'"
                       decoration-danger="status == 'failed'"
                       decoration-muted="status == 'draft'"
                       widget="badge"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="processed_at"/>
                <field name="external_source_id"/>
            </list>
        </field>
    </record>

    <!-- Source Action -->
    <record id="action_ipai_ai_agent_source" model="ir.actions.act_window">
        <field name="name">Agent Sources</field>
        <field name="res_model">ipai.ai.agent.source</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Root menu (loaded before agent views) -->
    <menuitem id="menu_ipai_ai_root"
              name="AI"
              sequence="90"/>

    <!-- Menu -->
    <menuitem id="menu_ipai_ai_sources"
              name="Sources"
              parent="menu_ipai_ai_root"
              action="action_ipai_ai_agent_source"
              sequence="20"/>

</odoo>
