<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_ipai_copilot" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ipai.copilot</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='general_settings']" position="inside">

                <block title="Pulser for Odoo" name="ipai_copilot_settings">
                    <setting string="Copilot"
                             help="Enable AI copilot assistant in the systray">
                        <field name="ipai_copilot_enabled"/>
                        <div class="content-group" invisible="not ipai_copilot_enabled">
                            <div class="row mt16">
                                <label for="ipai_copilot_gateway_url" class="col-lg-3"/>
                                <field name="ipai_copilot_gateway_url"
                                       placeholder="http://localhost:8088"/>
                            </div>
                            <div class="row">
                                <label for="ipai_copilot_mode" class="col-lg-3"/>
                                <field name="ipai_copilot_mode"/>
                            </div>
                            <div class="row mt8">
                                <button name="action_test_copilot_connection"
                                        type="object"
                                        string="Test Connection"
                                        class="btn-secondary"
                                        icon="fa-plug"
                                        invisible="not ipai_copilot_gateway_url"/>
                            </div>
                        </div>
                    </setting>
                </block>

            </xpath>
        </field>
    </record>
</odoo>
