{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "azure": {
      "command": "npx",
      "args": ["-y", "@azure/mcp@latest", "server", "start"]
    },
    "azure-devops": {
      "command": "npx",
      "args": ["-y", "@azure-devops/mcp", "insightpulseai"]
    },
    "foundry": {
      "command": "uvx",
      "args": [
        "--prerelease=allow",
        "--from",
        "git+https://github.com/azure-ai-foundry/mcp-foundry.git",
        "run-azure-ai-foundry-mcp"
      ],
      "env": {
        "AZURE_AI_FOUNDRY_ENDPOINT": "https://ipai-copilot-resource.services.ai.azure.com/api/projects/proj-ipai-copilot"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "figma": {
      "type": "http",
      "url": "https://figma.com/mcp"
    },
    "databricks-genie": {
      "command": "python3",
      "args": [
        "-m",
        "databricks_genie_mcp.server"
      ],
      "env": {
        "DATABRICKS_HOST": "https://adb-7405608559466577.17.azuredatabricks.net",
        "DATABRICKS_WORKSPACE_NAME": "dbw-ipai-dev",
        "DATABRICKS_RESOURCE_GROUP": "rg-ipai-dev-ai-sea",
        "DATABRICKS_SQL_WAREHOUSE_ID": "e7d89eabce4c330c",
        "DATABRICKS_GENIE_SPACE_ID": "PENDING_SPACE_ID_FROM_URL",
        "_NOTE": "Two Genie Spaces exist: 'Finance Operations' and 'Compliance & Tax' (created Apr 17). Get space ID from URL when opening a space. Alternative: use Genie Code native MCP (Workspace Settings → MCP Servers → Add → Genie space) instead of this external MCP.",
        "_REPO": "https://github.com/alexxx-db/databricks-genie-mcp",
        "_STATUS": "genie-spaces-created-awaiting-id",
        "_NATIVE_ALTERNATIVE": "Genie Code now supports Genie-as-MCP natively inside the workspace (Apr 2026). Consider using that instead of this external server."
      }
    }
  }
}
