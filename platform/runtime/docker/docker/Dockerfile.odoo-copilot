# syntax=docker/dockerfile:1
# Dockerfile.odoo-copilot - Odoo 18 CE + OCA Must-Have + Copilot + Document Intelligence
# =============================================================================
# Build: az acr build --registry acripaiodoo --resource-group rg-ipai-dev-odoo-runtime \
#        --image ipai-odoo:18.0-copilot --file platform/runtime/docker/docker/Dockerfile.odoo-copilot .
# Context: repo root
# =============================================================================

FROM odoo:18.0

LABEL maintainer="InsightPulse AI <devops@insightpulseai.com>"
LABEL description="Odoo 18 CE + OCA must-have + IPAI Copilot + Agent + Tax Guru + Doc Intelligence"
LABEL version="18.0.5.1.0"

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Create overlay addons directories
RUN mkdir -p /mnt/extra-addons/ipai /mnt/extra-addons/oca

# ---------------------------------------------------------------------------
# OCA must-have modules — sparse checkout (module dirs only, not full repos)
# Branch: 18.0 for all repos (Odoo 18 is canonical runtime)
# ---------------------------------------------------------------------------

# Helper script for sparse-cloning individual OCA modules
RUN printf '#!/bin/bash\nset -e\nREPO="$1"; shift\nTMPDIR=$(mktemp -d)\ngit clone --depth 1 --filter=blob:none --sparse -b 18.0 "https://github.com/OCA/${REPO}.git" "$TMPDIR"\ncd "$TMPDIR"\ngit sparse-checkout set "$@"\nfor MOD in "$@"; do\n  if [ -d "$MOD" ]; then\n    cp -r "$MOD" /mnt/extra-addons/oca/\n  else\n    echo "WARNING: module $MOD not found in OCA/$REPO (18.0 branch)" >&2\n  fi\ndone\nrm -rf "$TMPDIR"\n' > /tmp/oca_sparse_clone.sh \
    && chmod +x /tmp/oca_sparse_clone.sh

# --- server-auth: auth + security ---
RUN /tmp/oca_sparse_clone.sh server-auth \
    auth_oidc \
    auth_oidc_environment \
    auth_session_timeout \
    password_security \
    auth_api_key

# --- server-brand: debranding ---
RUN /tmp/oca_sparse_clone.sh server-brand disable_odoo_online remove_odoo_enterprise

# --- server-tools: admin + audit ---
RUN /tmp/oca_sparse_clone.sh server-tools \
    base_name_search_improved \
    base_exception \
    auditlog \
    auto_backup

# --- server-ux ---
RUN /tmp/oca_sparse_clone.sh server-ux server_action_mass_edit

# --- queue: async jobs ---
RUN /tmp/oca_sparse_clone.sh queue \
    queue_job \
    queue_job_cron

# --- web: 6 modules ---
RUN /tmp/oca_sparse_clone.sh web \
    web_advanced_search \
    web_listview_range_select \
    web_m2x_options \
    web_no_bubble \
    web_pivot_computed_measure \
    web_tree_many2one_clickable

# --- social / mail: activity + debranding ---
RUN /tmp/oca_sparse_clone.sh social \
    mail_debrand \
    mail_tracking \
    base_search_mail_content \
    mail_activity_plan \
    mail_activity_done \
    mail_composer_cc_bcc

# --- currency ---
RUN /tmp/oca_sparse_clone.sh currency currency_rate_update

# --- account-payment ---
RUN /tmp/oca_sparse_clone.sh account-payment account_payment_partner

# --- account-financial-tools ---
RUN /tmp/oca_sparse_clone.sh account-financial-tools \
    account_asset_management \
    account_chart_update

# --- account-financial-reporting ---
RUN /tmp/oca_sparse_clone.sh account-financial-reporting \
    account_financial_report \
    account_tax_balance \
    partner_statement

# --- account-reconcile ---
RUN /tmp/oca_sparse_clone.sh account-reconcile \
    account_move_base_import

# --- bank-payment ---
RUN /tmp/oca_sparse_clone.sh bank-payment account_reconcile_oca

# --- sale-workflow ---
RUN /tmp/oca_sparse_clone.sh sale-workflow \
    sale_automatic_workflow \
    sale_advance_payment

# --- purchase-workflow ---
RUN /tmp/oca_sparse_clone.sh purchase-workflow \
    purchase_blanket_order \
    purchase_advance_payment \
    purchase_cancel_reason

# --- project ---
RUN /tmp/oca_sparse_clone.sh project \
    project_task_dependency \
    project_task_recurrence \
    project_template \
    project_role \
    project_task_stage_mgmt

# --- helpdesk ---
RUN /tmp/oca_sparse_clone.sh helpdesk \
    helpdesk_mgmt \
    helpdesk_mgmt_project \
    helpdesk_mgmt_crm

# --- dms ---
RUN /tmp/oca_sparse_clone.sh dms \
    dms \
    dms_field \
    dms_user_role

# Cleanup helper script and git (reduce image size)
RUN rm -f /tmp/oca_sparse_clone.sh \
    && apt-get purge -y git && apt-get autoremove -y && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Python dependencies for IPAI modules
# ---------------------------------------------------------------------------
RUN pip3 install --no-cache-dir --break-system-packages paho-mqtt

# ---------------------------------------------------------------------------
# IPAI custom modules (22 with __manifest__.py)
# Regenerate list: find addons/ipai/ -maxdepth 2 -name "__manifest__.py" -exec dirname {} \; | xargs -I{} basename {} | sort
# ---------------------------------------------------------------------------
COPY addons/ipai/ipai_aca_proxy /mnt/extra-addons/ipai/ipai_aca_proxy/
COPY addons/ipai/ipai_ai_channel_actions /mnt/extra-addons/ipai/ipai_ai_channel_actions/
COPY addons/ipai/ipai_ai_copilot /mnt/extra-addons/ipai/ipai_ai_copilot/
COPY addons/ipai/ipai_ai_platform /mnt/extra-addons/ipai/ipai_ai_platform/
COPY addons/ipai/ipai_ai_widget /mnt/extra-addons/ipai/ipai_ai_widget/
COPY addons/ipai/ipai_ask_ai_azure /mnt/extra-addons/ipai/ipai_ask_ai_azure/
COPY addons/ipai/ipai_auth_oidc /mnt/extra-addons/ipai/ipai_auth_oidc/
COPY addons/ipai/ipai_bank_recon /mnt/extra-addons/ipai/ipai_bank_recon/
COPY addons/ipai/ipai_bir_compliance /mnt/extra-addons/ipai/ipai_bir_compliance/
COPY addons/ipai/ipai_branch_profile /mnt/extra-addons/ipai/ipai_branch_profile/
COPY addons/ipai/ipai_copilot_actions /mnt/extra-addons/ipai/ipai_copilot_actions/
COPY addons/ipai/ipai_document_intelligence /mnt/extra-addons/ipai/ipai_document_intelligence/
COPY addons/ipai/ipai_enterprise_bridge /mnt/extra-addons/ipai/ipai_enterprise_bridge/
COPY addons/ipai/ipai_finance_close_seed /mnt/extra-addons/ipai/ipai_finance_close_seed/
COPY addons/ipai/ipai_finance_ppm /mnt/extra-addons/ipai/ipai_finance_ppm/
COPY addons/ipai/ipai_hr_expense_liquidation /mnt/extra-addons/ipai/ipai_hr_expense_liquidation/
COPY addons/ipai/ipai_llm_supabase_bridge /mnt/extra-addons/ipai/ipai_llm_supabase_bridge/
COPY addons/ipai/ipai_odoo_copilot /mnt/extra-addons/ipai/ipai_odoo_copilot/
COPY addons/ipai/ipai_project_seed /mnt/extra-addons/ipai/ipai_project_seed/
COPY addons/ipai/ipai_security_frontdoor /mnt/extra-addons/ipai/ipai_security_frontdoor/
COPY addons/ipai/ipai_web_branding /mnt/extra-addons/ipai/ipai_web_branding/
COPY addons/ipai/ipai_workspace_core /mnt/extra-addons/ipai/ipai_workspace_core/

# ---------------------------------------------------------------------------
# Build-time assertion: fail if IPAI module count drops below expected
# ---------------------------------------------------------------------------
RUN MANIFEST_COUNT=$(find /mnt/extra-addons/ipai/ -name "__manifest__.py" -maxdepth 2 | wc -l) \
    && echo "IPAI modules: $MANIFEST_COUNT manifests" \
    && if [ "$MANIFEST_COUNT" -lt 21 ]; then \
         echo "FATAL: Expected >= 21 __manifest__.py, found $MANIFEST_COUNT" && exit 1; \
       fi

# ---------------------------------------------------------------------------
# Configure addons_path: OCA + IPAI + core
# ---------------------------------------------------------------------------
# Patch default config: addons_path, proxy_mode, db routing
RUN sed -i '/^addons_path/d' /etc/odoo/odoo.conf \
    && sed -i '/^\[options\]/a addons_path = /mnt/extra-addons/oca,/mnt/extra-addons/ipai,/usr/lib/python3/dist-packages/odoo/addons' /etc/odoo/odoo.conf \
    && sed -i '/^\[options\]/a proxy_mode = True' /etc/odoo/odoo.conf \
    && sed -i '/^\[options\]/a db_name = odoo' /etc/odoo/odoo.conf \
    && sed -i '/^\[options\]/a dbfilter = ^odoo$$' /etc/odoo/odoo.conf \
    && sed -i '/^\[options\]/a list_db = False' /etc/odoo/odoo.conf \
    && sed -i '/^\[options\]/a server_wide_modules = base,web,ipai_aca_proxy' /etc/odoo/odoo.conf

RUN chown -R odoo:odoo /mnt/extra-addons /etc/odoo/odoo.conf

USER odoo

HEALTHCHECK --interval=30s --timeout=10s --start-period=90s --retries=5 \
    CMD curl -sf http://localhost:8069/web/health || exit 1

ENTRYPOINT ["/entrypoint.sh"]
CMD ["odoo", "--addons-path=/mnt/extra-addons/oca,/mnt/extra-addons/ipai,/usr/lib/python3/dist-packages/odoo/addons"]
