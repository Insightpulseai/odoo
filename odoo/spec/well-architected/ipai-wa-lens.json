{
  "$schema": "ipai-well-architected-lens/v1",
  "name": "IPAI Well-Architected Lens",
  "version": "1.0.0",
  "description": "Custom Well-Architected lens for InsightPulse AI self-hosted stack",
  "scoring": {
    "scale": { "min": 0, "max": 5 },
    "labels": {
      "0": "Non-existent",
      "1": "Initial",
      "2": "Managed",
      "3": "Defined",
      "4": "Measured",
      "5": "Optimized"
    },
    "risk_map": {
      "HIGH_RISK": [0, 1],
      "MEDIUM_RISK": [2, 3],
      "NO_RISK": [4, 5]
    }
  },
  "pillars": [
    {
      "id": "security",
      "name": "Security & Compliance",
      "weight": 0.25,
      "questions": [
        {
          "id": "sec-01",
          "title": "TLS/HTTPS on all public endpoints",
          "automatable": true,
          "check_command": "curl -sI https://{subdomain}.insightpulseai.com | grep -i strict-transport-security",
          "choices": [
            { "label": "No HTTPS", "score": 0 },
            { "label": "HTTPS without HSTS", "score": 2 },
            { "label": "HTTPS + HSTS on some", "score": 3 },
            { "label": "HTTPS + HSTS on all endpoints", "score": 5 }
          ]
        },
        {
          "id": "sec-02",
          "title": "Database selector disabled (list_db=False)",
          "automatable": true,
          "check_command": "curl -s https://erp.insightpulseai.com/web/database/selector | grep -c 'selector'",
          "choices": [
            { "label": "Database selector exposed", "score": 0 },
            { "label": "Disabled (list_db=False)", "score": 5 }
          ]
        },
        {
          "id": "sec-03",
          "title": "No hardcoded secrets in workflow JSON exports",
          "automatable": true,
          "check_command": "grep -rE '(password|secret|token|api_key)\\s*[:=]\\s*\"[^{$]' automations/n8n/workflows/ | grep -v example",
          "choices": [
            { "label": "Hardcoded secrets found", "score": 0 },
            { "label": "All secrets via credential refs", "score": 5 }
          ]
        },
        {
          "id": "sec-04",
          "title": "SSH key-only authentication",
          "automatable": true,
          "check_command": "ssh root@178.128.112.214 'grep -c PasswordAuthentication.*no /etc/ssh/sshd_config'",
          "choices": [
            { "label": "Password auth enabled", "score": 0 },
            { "label": "Key-only auth", "score": 5 }
          ]
        },
        {
          "id": "sec-05",
          "title": "Firewall (UFW) active with restrictive rules",
          "automatable": true,
          "check_command": "ssh root@178.128.112.214 'ufw status | head -1'",
          "choices": [
            { "label": "No firewall", "score": 0 },
            { "label": "UFW active, permissive", "score": 2 },
            { "label": "UFW active, restrictive rules", "score": 5 }
          ]
        },
        {
          "id": "sec-06",
          "title": "RBAC / access control in Odoo",
          "automatable": false,
          "choices": [
            { "label": "No RBAC beyond defaults", "score": 1 },
            { "label": "Basic groups defined", "score": 3 },
            { "label": "Full RBAC with record rules + field ACLs", "score": 5 }
          ]
        },
        {
          "id": "sec-07",
          "title": "Dependency vulnerability scanning",
          "automatable": true,
          "check_command": "gh api repos/Insightpulseai/odoo/actions/workflows -q '.workflows[] | select(.name | test(\"security|trivy|semgrep|gitleaks\"; \"i\")) | .name'",
          "choices": [
            { "label": "No scanning", "score": 0 },
            { "label": "Manual scanning", "score": 2 },
            { "label": "CI-automated scanning", "score": 5 }
          ]
        },
        {
          "id": "sec-08",
          "title": "SSL certificate expiry > 14 days",
          "automatable": true,
          "check_command": "echo | openssl s_client -connect erp.insightpulseai.com:443 2>/dev/null | openssl x509 -noout -enddate",
          "choices": [
            { "label": "Expired or < 7 days", "score": 0 },
            { "label": "7-14 days remaining", "score": 2 },
            { "label": "> 14 days remaining", "score": 5 }
          ]
        }
      ]
    },
    {
      "id": "reliability",
      "name": "Reliability & DR",
      "weight": 0.20,
      "questions": [
        {
          "id": "rel-01",
          "title": "Daily database backups exist",
          "automatable": true,
          "check_command": "ssh root@178.128.112.214 'ls -lt /opt/backups/odoo/ | head -3'",
          "choices": [
            { "label": "No backups", "score": 0 },
            { "label": "Manual backups only", "score": 2 },
            { "label": "Daily automated backups", "score": 4 },
            { "label": "Daily automated + off-site sync", "score": 5 }
          ]
        },
        {
          "id": "rel-02",
          "title": "Backup restore tested",
          "automatable": false,
          "choices": [
            { "label": "Never tested", "score": 0 },
            { "label": "Tested > 6 months ago", "score": 2 },
            { "label": "Tested within 3 months", "score": 4 },
            { "label": "Tested within 30 days", "score": 5 }
          ]
        },
        {
          "id": "rel-03",
          "title": "Health check endpoints respond",
          "automatable": true,
          "check_command": "curl -s -o /dev/null -w '%{http_code}' https://erp.insightpulseai.com/web/health",
          "choices": [
            { "label": "No health endpoints", "score": 0 },
            { "label": "Some endpoints respond", "score": 3 },
            { "label": "All critical endpoints respond 200", "score": 5 }
          ]
        },
        {
          "id": "rel-04",
          "title": "DR runbook documented",
          "automatable": true,
          "check_command": "test -f docs/operations/DR_RUNBOOK.md && echo exists",
          "choices": [
            { "label": "No runbook", "score": 0 },
            { "label": "Partial runbook", "score": 2 },
            { "label": "Complete runbook with tested procedures", "score": 5 }
          ]
        },
        {
          "id": "rel-05",
          "title": "PostgreSQL replication configured",
          "automatable": true,
          "check_command": "ssh root@178.128.112.214 'docker exec odoo-db psql -U odoo -c \"SELECT * FROM pg_stat_replication;\"'",
          "choices": [
            { "label": "No replication", "score": 0 },
            { "label": "Streaming replication to standby", "score": 4 },
            { "label": "Replication + auto-failover", "score": 5 }
          ]
        },
        {
          "id": "rel-06",
          "title": "Service auto-restart on failure",
          "automatable": true,
          "check_command": "ssh root@178.128.112.214 'docker inspect --format=\"{{.HostConfig.RestartPolicy.Name}}\" odoo-web 2>/dev/null'",
          "choices": [
            { "label": "No restart policy", "score": 0 },
            { "label": "restart: on-failure", "score": 3 },
            { "label": "restart: unless-stopped or always", "score": 5 }
          ]
        },
        {
          "id": "rel-07",
          "title": "Uptime monitoring configured",
          "automatable": false,
          "choices": [
            { "label": "No monitoring", "score": 0 },
            { "label": "Basic health checks (n8n/cron)", "score": 2 },
            { "label": "Dedicated uptime service with alerting", "score": 5 }
          ]
        },
        {
          "id": "rel-08",
          "title": "n8n error workflows configured",
          "automatable": true,
          "check_command": "ssh root@178.128.112.214 'docker exec n8n n8n list:workflow 2>/dev/null | grep -i error'",
          "choices": [
            { "label": "No error handling", "score": 0 },
            { "label": "Some workflows have error handlers", "score": 3 },
            { "label": "Global error workflow + per-workflow handlers", "score": 5 }
          ]
        }
      ]
    },
    {
      "id": "operations",
      "name": "Operational Excellence",
      "weight": 0.20,
      "questions": [
        {
          "id": "ops-01",
          "title": "CI/CD pipeline active",
          "automatable": true,
          "check_command": "gh api repos/Insightpulseai/odoo/actions/runs -q '.workflow_runs | length'",
          "choices": [
            { "label": "No CI/CD", "score": 0 },
            { "label": "CI only (lint/test)", "score": 2 },
            { "label": "CI + CD with gating", "score": 4 },
            { "label": "CI + CD + automated rollback", "score": 5 }
          ]
        },
        {
          "id": "ops-02",
          "title": "Structured logging enabled",
          "automatable": true,
          "check_command": "ssh root@178.128.112.214 'docker logs odoo-web --tail 5 2>&1 | python3 -c \"import sys,json; json.loads(sys.stdin.readline())\" 2>/dev/null && echo json || echo text'",
          "choices": [
            { "label": "No logging", "score": 0 },
            { "label": "Text logs only", "score": 2 },
            { "label": "Structured JSON logs", "score": 4 },
            { "label": "Structured + centralized aggregation", "score": 5 }
          ]
        },
        {
          "id": "ops-03",
          "title": "Monitoring dashboards (Prometheus/Grafana)",
          "automatable": true,
          "check_command": "ssh root@178.128.112.214 'docker ps --format \"{{.Names}}\" | grep -iE \"prometheus|grafana\"'",
          "choices": [
            { "label": "No monitoring", "score": 0 },
            { "label": "Basic docker stats only", "score": 1 },
            { "label": "Prometheus metrics collection", "score": 3 },
            { "label": "Prometheus + Grafana dashboards", "score": 5 }
          ]
        },
        {
          "id": "ops-04",
          "title": "n8n metrics enabled (N8N_METRICS=true)",
          "automatable": true,
          "check_command": "ssh root@178.128.112.214 'docker exec n8n printenv N8N_METRICS 2>/dev/null'",
          "choices": [
            { "label": "Metrics disabled", "score": 0 },
            { "label": "Metrics enabled", "score": 5 }
          ]
        },
        {
          "id": "ops-05",
          "title": "Alerting configured (Slack/PagerDuty)",
          "automatable": false,
          "choices": [
            { "label": "No alerting", "score": 0 },
            { "label": "Manual monitoring", "score": 1 },
            { "label": "n8n-based alerting to Slack", "score": 3 },
            { "label": "Dedicated alerting (PagerDuty/Opsgenie)", "score": 5 }
          ]
        },
        {
          "id": "ops-06",
          "title": "n8n execution data pruning enabled",
          "automatable": true,
          "check_command": "ssh root@178.128.112.214 'docker exec n8n printenv EXECUTIONS_DATA_MAX_AGE 2>/dev/null'",
          "choices": [
            { "label": "No pruning (unbounded growth)", "score": 0 },
            { "label": "Pruning enabled", "score": 5 }
          ]
        },
        {
          "id": "ops-07",
          "title": "IaC for infrastructure changes",
          "automatable": true,
          "check_command": "test -d infra/cloudflare && test -f infra/dns/subdomain-registry.yaml && echo exists",
          "choices": [
            { "label": "Console-only changes", "score": 0 },
            { "label": "Some IaC (DNS YAML)", "score": 3 },
            { "label": "Full IaC (DNS + compute + networking)", "score": 5 }
          ]
        },
        {
          "id": "ops-08",
          "title": "Runbook for common operations",
          "automatable": true,
          "check_command": "find docs/ -name '*runbook*' -o -name '*RUNBOOK*' | head -5",
          "choices": [
            { "label": "No runbooks", "score": 0 },
            { "label": "Partial runbooks", "score": 2 },
            { "label": "Comprehensive runbooks for all critical ops", "score": 5 }
          ]
        }
      ]
    },
    {
      "id": "devops",
      "name": "DevOps Maturity (DORA)",
      "weight": 0.20,
      "questions": [
        {
          "id": "dora-01",
          "title": "Deployment frequency",
          "automatable": true,
          "check_command": "gh api repos/Insightpulseai/odoo/actions/runs -q '[.workflow_runs[] | select(.name | test(\"deploy\"; \"i\")) | select(.created_at > (now - 2592000 | todate))] | length'",
          "choices": [
            { "label": "Less than monthly", "score": 1 },
            { "label": "Monthly", "score": 2 },
            { "label": "Weekly", "score": 3 },
            { "label": "Daily", "score": 4 },
            { "label": "On-demand (multiple per day)", "score": 5 }
          ]
        },
        {
          "id": "dora-02",
          "title": "Lead time for changes (commit to deploy)",
          "automatable": true,
          "check_command": "gh pr list --state merged --limit 10 --json mergedAt,createdAt -q '.[].mergedAt'",
          "choices": [
            { "label": "> 1 month", "score": 1 },
            { "label": "1 week - 1 month", "score": 2 },
            { "label": "1 day - 1 week", "score": 3 },
            { "label": "< 1 day", "score": 4 },
            { "label": "< 1 hour", "score": 5 }
          ]
        },
        {
          "id": "dora-03",
          "title": "Change failure rate",
          "automatable": false,
          "choices": [
            { "label": "> 30%", "score": 1 },
            { "label": "16-30%", "score": 2 },
            { "label": "5-15%", "score": 3 },
            { "label": "1-5%", "score": 4 },
            { "label": "< 1%", "score": 5 }
          ]
        },
        {
          "id": "dora-04",
          "title": "Mean time to recover (MTTR)",
          "automatable": false,
          "choices": [
            { "label": "> 1 week", "score": 1 },
            { "label": "1 day - 1 week", "score": 2 },
            { "label": "< 1 day", "score": 3 },
            { "label": "< 1 hour", "score": 4 },
            { "label": "< 15 minutes", "score": 5 }
          ]
        },
        {
          "id": "dora-05",
          "title": "Commit frequency (main branch)",
          "automatable": true,
          "check_command": "git log --since='30 days ago' --oneline | wc -l",
          "choices": [
            { "label": "< 5 commits/month", "score": 1 },
            { "label": "5-20 commits/month", "score": 2 },
            { "label": "20-50 commits/month", "score": 3 },
            { "label": "50-100 commits/month", "score": 4 },
            { "label": "> 100 commits/month", "score": 5 }
          ]
        },
        {
          "id": "dora-06",
          "title": "PR merge time (median)",
          "automatable": true,
          "check_command": "gh pr list --state merged --limit 20 --json createdAt,mergedAt",
          "choices": [
            { "label": "> 1 week", "score": 1 },
            { "label": "2-7 days", "score": 2 },
            { "label": "1-2 days", "score": 3 },
            { "label": "< 24 hours", "score": 4 },
            { "label": "< 4 hours", "score": 5 }
          ]
        },
        {
          "id": "dora-07",
          "title": "Automated rollback capability",
          "automatable": false,
          "choices": [
            { "label": "No rollback process", "score": 0 },
            { "label": "Manual rollback documented", "score": 2 },
            { "label": "Semi-automated rollback", "score": 3 },
            { "label": "Fully automated rollback on failure", "score": 5 }
          ]
        },
        {
          "id": "dora-08",
          "title": "Feature flags / progressive delivery",
          "automatable": false,
          "choices": [
            { "label": "No feature flags", "score": 0 },
            { "label": "Manual env-var toggles", "score": 2 },
            { "label": "Feature flag system (LaunchDarkly/custom)", "score": 4 },
            { "label": "Progressive delivery with canary/blue-green", "score": 5 }
          ]
        }
      ]
    },
    {
      "id": "governance",
      "name": "Governance & Audit",
      "weight": 0.15,
      "questions": [
        {
          "id": "gov-01",
          "title": "SSOT files current (no drift)",
          "automatable": true,
          "check_command": "grep -r 'odoo_core\\|159\\.223\\.75\\.148\\|insightpulseai\\.net\\|MATTERMOST' infra/ automations/ docs/ --include='*.yaml' --include='*.yml' --include='*.md' --include='*.json' -l | wc -l",
          "choices": [
            { "label": "> 10 stale references", "score": 0 },
            { "label": "5-10 stale references", "score": 1 },
            { "label": "1-4 stale references", "score": 3 },
            { "label": "Zero stale references", "score": 5 }
          ]
        },
        {
          "id": "gov-02",
          "title": "Module naming compliance (ipai_* convention)",
          "automatable": true,
          "check_command": "find addons/ -maxdepth 2 -name '__manifest__.py' | xargs grep -L 'ipai_' | wc -l",
          "choices": [
            { "label": "> 20% non-compliant", "score": 1 },
            { "label": "10-20% non-compliant", "score": 2 },
            { "label": "< 10% non-compliant", "score": 4 },
            { "label": "100% compliant", "score": 5 }
          ]
        },
        {
          "id": "gov-03",
          "title": "Audit logging enabled",
          "automatable": true,
          "check_command": "gh api repos/Insightpulseai/odoo/actions/runs -q '.workflow_runs | length' 2>/dev/null",
          "choices": [
            { "label": "No audit logs", "score": 0 },
            { "label": "Git history only", "score": 2 },
            { "label": "Git + GitHub audit log API", "score": 4 },
            { "label": "Full audit trail (Git + GitHub + app-level)", "score": 5 }
          ]
        },
        {
          "id": "gov-04",
          "title": "Spec bundles exist for active features",
          "automatable": true,
          "check_command": "find spec/ -name 'prd.md' | wc -l",
          "choices": [
            { "label": "< 30% features have specs", "score": 1 },
            { "label": "30-60% features have specs", "score": 2 },
            { "label": "60-80% features have specs", "score": 4 },
            { "label": "> 80% features have specs", "score": 5 }
          ]
        },
        {
          "id": "gov-05",
          "title": "Deprecated items cleaned up",
          "automatable": true,
          "check_command": "grep -rE 'insightpulseai\\.net|mattermost|odoo-ce' --include='*.py' --include='*.ts' --include='*.js' addons/ apps/ packages/ -l | wc -l",
          "choices": [
            { "label": "> 20 files with deprecated refs", "score": 0 },
            { "label": "10-20 files", "score": 1 },
            { "label": "1-9 files", "score": 3 },
            { "label": "Zero deprecated references in source", "score": 5 }
          ]
        },
        {
          "id": "gov-06",
          "title": "OCA-first module selection",
          "automatable": false,
          "choices": [
            { "label": "Custom modules without OCA evaluation", "score": 0 },
            { "label": "Some OCA modules used", "score": 2 },
            { "label": "OCA evaluated first for every need", "score": 4 },
            { "label": "OCA-first with delta-only ipai_* policy enforced", "score": 5 }
          ]
        },
        {
          "id": "gov-07",
          "title": "Project management system unified",
          "automatable": false,
          "choices": [
            { "label": "Fragmented across 3+ systems", "score": 0 },
            { "label": "Two systems with some sync", "score": 2 },
            { "label": "Single PM system + GitHub Issues", "score": 4 },
            { "label": "Unified PM with automated sync to GitHub", "score": 5 }
          ]
        },
        {
          "id": "gov-08",
          "title": "Access review cadence",
          "automatable": false,
          "choices": [
            { "label": "No access reviews", "score": 0 },
            { "label": "Ad-hoc reviews", "score": 1 },
            { "label": "Quarterly reviews", "score": 3 },
            { "label": "Monthly reviews with audit trail", "score": 5 }
          ]
        }
      ]
    }
  ]
}
