<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        Composer AI Patch — extends the mail.Composer template to render
        the AiInlinePanel below the input container, before the footer.

        This template inherits mail.Composer and inserts the panel DOM node
        conditionally based on ipaiAiPanel.show (set by the composer action).

        Placement: between o-mail-Composer-coreMain and o-mail-Composer-footer
        so the AI panel sits below the text input but above attachments/send.
    -->
    <t t-inherit="mail.Composer" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-Composer-footer')]" position="before">
            <AiInlinePanel
                t-if="ipaiAiPanel and ipaiAiPanel.show"
                thread="ipaiThread"
                onInsertText.bind="ipaiInsertText"
                onReplaceText.bind="ipaiReplaceText"
                onClose.bind="ipaiClosePanel"
                hasSelection="false"
                selectedText="''"
                chatterText="''"/>
        </xpath>
    </t>

</templates>
