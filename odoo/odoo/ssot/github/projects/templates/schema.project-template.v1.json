{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ssot.github.projects.template.v1",
  "title": "GitHub Project Template Spec v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "template_id",
    "title",
    "owner",
    "org",
    "project",
    "fields"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "template_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "enum": ["org", "user"]
    },
    "org": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "slug"],
      "properties": {
        "number": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        }
      }
    },
    "labels": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "name", "type"],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["SINGLE_SELECT", "TEXT", "NUMBER", "DATE", "ITERATION"]
          },
          "required": {
            "type": "boolean"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "description": { "type": "string" },
                "color": {
                  "type": "string",
                  "enum": [
                    "GRAY",
                    "BLUE",
                    "GREEN",
                    "YELLOW",
                    "ORANGE",
                    "RED",
                    "PINK",
                    "PURPLE"
                  ]
                }
              }
            }
          },
          "iteration": {
            "type": "object",
            "additionalProperties": false,
            "required": ["duration", "start_date", "iterations"],
            "properties": {
              "duration": {
                "type": "integer",
                "minimum": 1
              },
              "start_date": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "iterations": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["title", "start_date", "duration"],
                  "properties": {
                    "title": { "type": "string", "minLength": 1 },
                    "start_date": {
                      "type": "string",
                      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                    },
                    "duration": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                }
              }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": { "const": "SINGLE_SELECT" }
              }
            },
            "then": {
              "required": ["options"]
            }
          },
          {
            "if": {
              "properties": {
                "type": { "const": "ITERATION" }
              }
            },
            "then": {
              "required": ["iteration"]
            }
          }
        ]
      }
    }
  }
}
