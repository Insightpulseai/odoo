<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!-- Tax Table Views                                                   -->
    <!-- ================================================================ -->

    <record id="view_bir_tax_table_form" model="ir.ui.view">
        <field name="name">ipai.bir.tax.table.form</field>
        <field name="model">ipai.bir.tax.table</field>
        <field name="arch" type="xml">
            <form string="BIR Tax Table">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Monthly Withholding Tax Table 2023"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="table_type"/>
                            <field name="effective_date"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tax Brackets" name="brackets">
                            <field name="bracket_ids">
                                <list editable="bottom">
                                    <field name="range_from"/>
                                    <field name="range_to"/>
                                    <field name="base_tax"/>
                                    <field name="excess_rate"/>
                                    <field name="excess_over"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bir_tax_table_list" model="ir.ui.view">
        <field name="name">ipai.bir.tax.table.list</field>
        <field name="model">ipai.bir.tax.table</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="table_type"/>
                <field name="effective_date"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_bir_tax_table" model="ir.actions.act_window">
        <field name="name">BIR Tax Tables</field>
        <field name="res_model">ipai.bir.tax.table</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first BIR Withholding Tax Table
            </p>
            <p>
                Define Philippine BIR withholding tax brackets per TRAIN Law.
            </p>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- Contribution Table Views                                          -->
    <!-- ================================================================ -->

    <record id="view_bir_contribution_table_form" model="ir.ui.view">
        <field name="name">ipai.bir.contribution.table.form</field>
        <field name="model">ipai.bir.contribution.table</field>
        <field name="arch" type="xml">
            <form string="Contribution Table">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. SSS Contribution Table 2023"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="contribution_type"/>
                            <field name="effective_date"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Contribution Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="range_from"/>
                                    <field name="range_to"/>
                                    <field name="employee_share"/>
                                    <field name="employer_share"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bir_contribution_table_list" model="ir.ui.view">
        <field name="name">ipai.bir.contribution.table.list</field>
        <field name="model">ipai.bir.contribution.table</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="contribution_type"/>
                <field name="effective_date"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_bir_contribution_table" model="ir.actions.act_window">
        <field name="name">Contribution Tables</field>
        <field name="res_model">ipai.bir.contribution.table</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Contribution Table
            </p>
            <p>
                Define SSS, PhilHealth, and Pag-IBIG/HDMF contribution schedules.
            </p>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- Menus                                                             -->
    <!-- ================================================================ -->

    <menuitem
        id="menu_bir_tax_root"
        name="BIR Tax Compliance"
        parent="account.menu_finance"
        sequence="90"
    />

    <menuitem
        id="menu_bir_tax_tables"
        name="Withholding Tax Tables"
        parent="menu_bir_tax_root"
        action="action_bir_tax_table"
        sequence="10"
    />

    <menuitem
        id="menu_bir_contribution_tables"
        name="Contribution Tables"
        parent="menu_bir_tax_root"
        action="action_bir_contribution_table"
        sequence="20"
    />

</odoo>
