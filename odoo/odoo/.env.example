# =============================================================================
# Odoo Environment Configuration Template
# =============================================================================
# Copy this file to .env and set appropriate values for your environment
#
# Environment-specific examples:
#   - .env.dev       (local development - odoo_dev)
#   - .env.stage     (staging - odoo_staging)
#   - .env.prod      (production - odoo_prod)
#
# Usage:
#   cp .env.dev .env        # Local development
#   docker compose up -d
# =============================================================================

COMPOSE_PROJECT_NAME=ipai
ENVIRONMENT=dev

# PostgreSQL
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo
POSTGRES_DB=odoo_dev
POSTGRES_PORT=5433

# Odoo
ODOO_DB=odoo_dev
ODOO_PORT=8069
ODOO_LONGPOLL_PORT=8072
ODOO_LOG_LEVEL=info

# Redis
REDIS_PORT=6379

# Tools (optional)
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@localhost
PGADMIN_PASSWORD=admin
MAILPIT_WEB_PORT=8025
MAILPIT_SMTP_PORT=1025

# =============================================================================
# LLM Provider Routing (infra/ai/provider_router)
# Set AI_PROVIDER_PRIMARY to route all Ask AI calls to a specific provider.
# =============================================================================
AI_PROVIDER_PRIMARY=openai
AI_PROVIDER_SECONDARY=
AI_PROVIDER_TERTIARY=

# OpenAI (default)
IPAI_LLM_API_KEY=
IPAI_LLM_MODEL=gpt-4o-mini
IPAI_LLM_BASE_URL=https://api.openai.com/v1

# Ollama (local — set AI_PROVIDER_PRIMARY=ollama to activate)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# =============================================================================
# Slack Integration (PPM Clarity & n8n workflows)
# =============================================================================
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CHANNEL_LOGS=#ppm-clarity-logs
SLACK_CHANNEL_ALERTS=#ppm-clarity-alerts
SLACK_CHANNEL_CONFLICTS=#ppm-clarity-conflicts

# =============================================================================
# Azure AI Foundry — Odoo bridge / copilot
# Subset of ops-platform/.env.example sections 2, 3, 4
# =============================================================================

# Canonical Foundry project endpoint
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://data-intel-ph-resource.services.ai.azure.com/api/projects/data-intel-ph

# Canonical Foundry resource endpoint
AZURE_AI_FOUNDRY_ENDPOINT=https://data-intel-ph-resource.services.ai.azure.com/

# Odoo copilot agent name in Foundry
AZURE_AI_FOUNDRY_AGENT_ID=ipai-odoo-copilot-azure
AZURE_AI_FOUNDRY_AGENT_NAME=ipai-odoo-copilot-azure

# Resource API key (leave blank if using managed identity / az login)
AZURE_AI_FOUNDRY_API_KEY=

# Project metadata
AZURE_AI_FOUNDRY_PROJECT_NAME=data-intel-ph
AZURE_AI_FOUNDRY_RESOURCE_NAME=data-intel-ph-resource
AZURE_AI_FOUNDRY_REGION=eastus2

# Model deployments
AZURE_AI_FOUNDRY_CHAT_DEPLOYMENT=gpt-4.1
AZURE_AI_FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Auth mode: managed_identity | api_key | azure_cli | default_credential
AZURE_AI_FOUNDRY_AUTH_MODE=api_key
AZURE_AI_FOUNDRY_AUTH_AUDIENCE=https://ai.azure.com/.default

# =============================================================================
# Azure AI Search / Knowledge grounding (optional)
# =============================================================================

AZURE_AI_SEARCH_SERVICE_NAME=
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_INDEX_NAME=
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_API_VERSION=2025-03-01-preview

# =============================================================================
# APIM (optional — leave blank if not deployed)
# =============================================================================

AZURE_APIM_ENABLED=0
AZURE_APIM_ENDPOINT=
AZURE_APIM_SUBSCRIPTION_KEY=
