<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="ir_cron_process_scheduled_posts" model="ir.cron">
        <field name="name">Social Marketing: Process Scheduled Posts</field>
        <field name="model_id" ref="model_ipai_social_post"/>
        <field name="state">code</field>
        <field name="code">model._cron_process_scheduled()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_fetch_social_analytics" model="ir.cron">
        <field name="name">Social Marketing: Fetch Analytics</field>
        <field name="model_id" ref="model_ipai_social_post"/>
        <field name="state">code</field>
        <field name="code">model._cron_fetch_analytics()</field>
        <field name="interval_number">6</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>

</odoo>
