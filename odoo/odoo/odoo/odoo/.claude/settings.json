{
  "env": {
    "DOCKER_CONTEXT_OVERRIDE": "colima",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "GH_HOST": "github.com",
    "PYTHON_TRUTH": "container"
  },
  "permissions": {
    "allow": [
      "Bash(/usr/local/bin/docker --context colima *)",
      "Bash(/usr/local/bin/docker compose -f .devcontainer/docker-compose.devcontainer.yml *)",
      "Bash(/usr/local/bin/docker context show)",
      "Bash(/usr/local/bin/docker exec *)",
      "Bash(docker --context colima *)",
      "Bash(docker compose -f .devcontainer/docker-compose.devcontainer.yml *)",
      "Bash(docker context show)",
      "Bash(docker exec *)",
      "Bash(SUPABASE_ACCESS_TOKEN=\"$SUPABASE_ACCESS_TOKEN\" supabase functions list --project-ref spdtwktxdalcfigzeqrz)"
    ],
    "deny": [
      "Bash(docker context use *)",
      "Bash(/usr/local/bin/docker context use *)"
    ]
  },
  "allowedTools": [
    "Edit",
    "Read",
    "Write",
    "Glob",
    "Grep",
    "Bash(git status)",
    "Bash(git diff*)",
    "Bash(git add*)",
    "Bash(git commit*)",
    "Bash(git push*)",
    "Bash(git log*)",
    "Bash(git branch*)",
    "Bash(gh *)",
    "Bash(npm run lint*)",
    "Bash(npm run typecheck*)",
    "Bash(npm run test*)",
    "Bash(npm run build*)",
    "Bash(pnpm -s lint*)",
    "Bash(pnpm -s typecheck*)",
    "Bash(pnpm -s test*)",
    "Bash(pnpm -s build*)",
    "Bash(python3 -m py_compile*)",
    "Bash(black --check*)",
    "Bash(black *)",
    "Bash(isort --check*)",
    "Bash(isort *)",
    "Bash(flake8*)",
    "Bash(./scripts/repo_health.sh)",
    "Bash(./scripts/spec_validate.sh)",
    "Bash(./scripts/verify.sh)",
    "Bash(./scripts/ci_local.sh*)",
    "Bash(./scripts/ci/*)",
    "Bash(docker *)",
    "Bash(docker compose *)",
    "Bash(/usr/local/bin/docker *)",
    "Bash(curl *)",
    "Bash(psql *)",
    "Bash(python3 *)",
    "Bash(node *)",
    "Bash(pnpm *)",
    "Bash(npm *)",
    "Bash(which *)",
    "Bash(ls *)",
