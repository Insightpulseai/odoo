{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ipai.promotion.v1.hardened",
  "type": "object",
  "required": [
    "record_type",
    "record_version",
    "agent_id",
    "from_stage",
    "to_stage",
    "gate_version",
    "decision",
    "evidence_refs",
    "issued_at",
    "issued_by",
    "transition_key"
  ],
  "properties": {
    "record_type": { "type": "string", "const": "promotion" },
    "record_version": { "type": "string" },
    "agent_id": { "type": "string" },
    "from_stage": { "type": "string" },
    "to_stage": { "type": "string" },
    "gate_version": { "type": "string" },
    "decision": { "type": "string", "enum": ["pass", "fail"] },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "issued_at": { "type": "string", "format": "date-time" },
    "issued_by": { "type": "string" },
    "transition_key": { "type": "string" }
  }
}
