    {
      "id": "wf-017",
      "category": "idempotency",
      "query": "Post journal entry JE-2026-0200 which is already in posted state.",
      "context": {
        "company_id": "ipai-main",
        "user_role": "account.group_account_manager",
        "active_model": "account.move",
        "active_record_id": 200
      },
      "expected_actions": [
        "account.move.browse(200).read(['state'])",
        "SKIP action_post() IF state == 'posted'"
      ],
      "expected_output": {
        "status": "already_posted",
        "action_taken": "none"
      },
      "pass_criteria": {
        "must_contain": ["already posted", "no action"],
        "must_not_contain": ["posted again", "double posted"],
        "behavior": "action"
      },
      "idempotent": true
    },
    {
      "id": "wf-018",
      "category": "idempotency",
      "query": "Lock the March 2026 period, which was already locked yesterday.",
      "context": {
        "company_id": "ipai-main",
        "user_role": "account.group_account_manager",
        "active_model": "res.company",
        "active_record_id": 1
      },
      "expected_actions": [
        "res.company.browse(1).read(['period_lock_date'])",
        "SKIP write() IF period_lock_date >= '2026-03-31'"
      ],
      "expected_output": {
        "status": "already_locked",
        "action_taken": "none"
      },
      "pass_criteria": {
        "must_contain": ["already locked", "no change"],
        "must_not_contain": ["locked again", "updated"],
        "behavior": "action"
      },
      "idempotent": true
    },
