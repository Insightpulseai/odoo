<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ipai.bridge</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='general_settings']" position="inside">
                <block title="IPAI Enterprise Bridge" name="ipai_bridge_settings">
                    <setting string="Email Provider" help="Configure email delivery without IAP">
                        <field name="ipai_mail_provider"/>
                        <div class="content-group" invisible="ipai_mail_provider != 'mailgun'">
                            <div class="row mt16">
                                <label for="ipai_mailgun_domain" class="col-lg-3"/>
                                <field name="ipai_mailgun_domain"/>
                            </div>
                            <div class="row">
                                <label for="ipai_mailgun_api_key" class="col-lg-3"/>
                                <field name="ipai_mailgun_api_key" password="True"/>
                            </div>
                        </div>
                        <div class="row mt16">
                            <label for="ipai_mail_catchall_domain" class="col-lg-3"/>
                            <field name="ipai_mail_catchall_domain" placeholder="mail.example.com"/>
                        </div>
                    </setting>
                    <setting string="OAuth Providers" help="Enable social login without Enterprise">
                        <div class="content-group">
                            <div class="row">
                                <field name="ipai_oauth_google_enabled"/>
                                <span class="o_form_label">Google OAuth</span>
                            </div>
                            <div class="row">
                                <field name="ipai_oauth_azure_enabled"/>
                                <span class="o_form_label">Azure AD OAuth</span>
                            </div>
                        </div>
                    </setting>
                    <setting string="IoT Bridge" help="Control IoT devices without IoT Box subscription">
                        <field name="ipai_iot_enabled"/>
                        <div class="content-group" invisible="not ipai_iot_enabled">
                            <div class="row mt16">
                                <label for="ipai_iot_mqtt_broker" class="col-lg-3"/>
                                <field name="ipai_iot_mqtt_broker"/>
                            </div>
                            <div class="row">
                                <label for="ipai_iot_mqtt_port" class="col-lg-3"/>
                                <field name="ipai_iot_mqtt_port"/>
                            </div>
                        </div>
                    </setting>
                    <setting string="API Keys" help="Manage API keys for external integrations and service users">
                        <div class="mt8">
                            <button name="action_open_api_keys"
                                    type="object"
                                    string="Manage API Keys"
                                    class="btn-link"
                                    icon="fa-key"/>
                        </div>
                    </setting>
                </block>

                <!-- ===== AI / Integrations ===== -->
                <block title="AI / Integrations" name="ipai_ai_integrations_settings">
                    <setting string="Microsoft Foundry"
                             help="Connect to Azure AI Foundry for LLM and AI model inference">
                        <field name="ipai_foundry_enabled"/>
                        <div class="content-group" invisible="not ipai_foundry_enabled">
                            <div class="row mt16">
                                <label for="ipai_foundry_endpoint" class="col-lg-3"/>
                                <field name="ipai_foundry_endpoint"
                                       placeholder="https://your-resource.services.ai.azure.com/api/projects/your-project"/>
                            </div>
                            <div class="row">
                                <label for="ipai_foundry_project_name" class="col-lg-3"/>
                                <field name="ipai_foundry_project_name"/>
                            </div>
                            <div class="row">
                                <label for="ipai_foundry_model_deployment" class="col-lg-3"/>
                                <field name="ipai_foundry_model_deployment"/>
                            </div>
                            <div class="row">
                                <label for="ipai_foundry_auth_mode" class="col-lg-3"/>
                                <field name="ipai_foundry_auth_mode"/>
                            </div>
                            <div class="row">
                                <label for="ipai_foundry_api_version" class="col-lg-3"/>
                                <field name="ipai_foundry_api_version"/>
                            </div>
                            <div class="mt8">
                                <button name="action_open_foundry_provider"
                                        type="object"
                                        string="Configure"
                                        class="btn-link"
                                        icon="fa-cog"/>
                                <button name="action_test_foundry_connection"
                                        type="object"
                                        string="Test Connection"
                                        class="btn-link ms-3"
                                        icon="fa-plug"/>
                            </div>
                        </div>
                    </setting>

                    <setting string="Document Digitization / OCR"
                             help="Extract data from invoices, receipts and documents using AI-powered OCR">
                        <field name="ipai_doc_ai_enabled"/>
                        <div class="content-group" invisible="not ipai_doc_ai_enabled">
                            <div class="row mt16">
                                <label for="ipai_doc_ai_provider" class="col-lg-3"/>
                                <field name="ipai_doc_ai_provider"/>
                            </div>
                            <div class="row">
                                <label for="ipai_doc_ai_endpoint" class="col-lg-3"/>
                                <field name="ipai_doc_ai_endpoint"
                                       placeholder="https://your-doc-ai.cognitiveservices.azure.com"/>
                            </div>
                            <div class="row">
                                <label for="ipai_doc_ai_model" class="col-lg-3"/>
                                <field name="ipai_doc_ai_model"/>
                            </div>
                            <div class="row">
                                <label for="ipai_doc_ai_storage_mode" class="col-lg-3"/>
                                <field name="ipai_doc_ai_storage_mode"/>
                            </div>
                            <div class="row">
                                <label for="ipai_doc_ai_async_enabled" class="col-lg-3"/>
                                <field name="ipai_doc_ai_async_enabled"/>
                            </div>
                            <div class="row">
                                <label for="ipai_doc_ai_min_file_size" class="col-lg-3"/>
                                <field name="ipai_doc_ai_min_file_size"/>
                            </div>
                            <div class="mt8">
                                <button name="action_open_doc_digitization_provider"
                                        type="object"
                                        string="Configure"
                                        class="btn-link"
                                        icon="fa-cog"/>
                                <button name="action_test_doc_digitization_connection"
                                        type="object"
                                        string="Test Connection"
                                        class="btn-link ms-3"
                                        icon="fa-plug"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
