<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Session Tree View -->
    <record id="chat_session_view_list" model="ir.ui.view">
        <field name="name">ipai.chat.session.list</field>
        <field name="model">ipai.chat.session</field>
        <field name="arch" type="xml">
            <list string="Chat Sessions" default_order="write_date desc">
                <field name="name"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-muted="state == 'archived'"/>
                <field name="message_count" string="Msgs"/>
                <field name="source_count" string="Sources"/>
                <field name="eligible_source_count" string="Eligible"/>
                <field name="write_date" string="Last Activity"/>
            </list>
        </field>
    </record>

    <!-- Session Form View -->
    <record id="chat_session_view_form" model="ir.ui.view">
        <field name="name">ipai.chat.session.form</field>
        <field name="model">ipai.chat.session</field>
        <field name="arch" type="xml">
            <form string="Chat Session">
                <header>
                    <button name="action_archive" string="Archive"
                            type="object" class="oe_highlight"
                            invisible="state != 'active'"/>
                    <button name="action_unarchive" string="Unarchive"
                            type="object"
                            invisible="state != 'archived'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Chat title..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="external_session_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="message_count"/>
                            <field name="source_count"/>
                            <field name="eligible_source_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sources" name="sources">
                            <field name="source_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="source_type"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'indexed'"
                                           decoration-warning="status == 'processing'"
                                           decoration-danger="status == 'failed'"
                                           decoration-muted="status == 'draft'"/>
                                    <field name="active" widget="boolean_toggle"/>
                                    <field name="file_size"/>
                                    <field name="processed_at"/>
                                    <button name="action_retry" string="Retry"
                                            type="object" class="btn-link"
                                            icon="fa-refresh"
                                            invisible="status != 'failed'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Messages" name="messages">
                            <field name="chat_message_ids">
                                <list create="0" delete="0">
                                    <field name="role" widget="badge"/>
                                    <field name="content" widget="text"/>
                                    <field name="latency_ms"/>
                                    <field name="create_date" string="Sent"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Session Action -->
    <record id="chat_session_action" model="ir.actions.act_window">
        <field name="name">Chat Sessions</field>
        <field name="res_model">ipai.chat.session</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No chat sessions yet
            </p>
            <p>Create a chat session to upload sources and start grounded conversations.</p>
        </field>
    </record>
</odoo>
