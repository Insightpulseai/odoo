{
  "manifest_version": 3,
  "name": "InsightPulseAI Browser Copilot",
  "version": "0.1.0",
  "description": "AI copilot with screenshot capture. Type 'ss' to capture active window.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "nativeMessaging",
    "sidePanel"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "commands": {
    "capture-active-window": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Capture active window (ss)"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
