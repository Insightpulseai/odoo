<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Main Menu -->
    <menuitem id="menu_expense_liquidation_root"
        name="Expense Liquidation"
        sequence="80"
        web_icon="ipai_hr_expense_liquidation,static/description/icon.png"
        groups="group_expense_liquidation_user"/>

    <!-- Cash Advance -->
    <menuitem id="menu_cash_advance_parent"
        name="Cash Advance"
        parent="menu_expense_liquidation_root"
        sequence="5"/>

    <menuitem id="menu_cash_advance_my"
        name="My Cash Advances"
        parent="menu_cash_advance_parent"
        action="action_cash_advance_my"
        sequence="10"/>

    <menuitem id="menu_cash_advance_all"
        name="All Cash Advances"
        parent="menu_cash_advance_parent"
        action="action_cash_advance"
        sequence="20"
        groups="group_expense_liquidation_approver"/>

    <menuitem id="menu_cash_advance_to_approve"
        name="To Approve"
        parent="menu_cash_advance_parent"
        action="action_cash_advance_to_approve"
        sequence="30"
        groups="group_expense_liquidation_approver"/>

    <menuitem id="menu_cash_advance_overdue"
        name="Overdue"
        parent="menu_cash_advance_parent"
        action="action_cash_advance_overdue"
        sequence="40"
        groups="group_expense_liquidation_approver"/>

    <!-- Liquidations -->
    <menuitem id="menu_expense_liquidation_parent"
        name="Liquidations"
        parent="menu_expense_liquidation_root"
        sequence="10"/>

    <menuitem id="menu_expense_liquidation_my"
        name="My Liquidations"
        parent="menu_expense_liquidation_parent"
        action="action_expense_liquidation_my"
        sequence="10"/>

    <menuitem id="menu_expense_liquidation_all"
        name="All Liquidations"
        parent="menu_expense_liquidation_parent"
        action="action_expense_liquidation"
        sequence="20"
        groups="group_expense_liquidation_approver"/>

    <menuitem id="menu_expense_liquidation_approve"
        name="To Approve"
        parent="menu_expense_liquidation_parent"
        action="action_expense_liquidation_to_approve"
        sequence="30"
        groups="group_expense_liquidation_approver"/>

    <!-- Configuration -->
    <menuitem id="menu_expense_liquidation_config"
        name="Configuration"
        parent="menu_expense_liquidation_root"
        sequence="90"
        groups="group_expense_liquidation_approver"/>

    <menuitem id="menu_expense_policy_rules"
        name="Policy Rules"
        parent="menu_expense_liquidation_config"
        action="action_expense_policy_rule"
        sequence="10"/>

    <menuitem id="menu_expense_policy_violations"
        name="Policy Violations"
        parent="menu_expense_liquidation_config"
        action="action_expense_policy_violation"
        sequence="20"/>

</odoo>
