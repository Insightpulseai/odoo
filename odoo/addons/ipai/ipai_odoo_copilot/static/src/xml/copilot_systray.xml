<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Systray Button -->
    <t t-name="ipai_odoo_copilot.SystrayButton">
        <div class="o_ipai_copilot_systray">
            <!-- Systray Icon -->
            <button class="o_ipai_copilot_btn btn border-0 bg-transparent"
                    t-on-click="togglePanel"
                    title="IPAI Copilot"
                    t-att-class="{'o_ipai_copilot_btn_active': state.isOpen}">
                <i class="fa fa-commenting-o fa-lg"
                   t-att-class="{'text-primary': state.isOpen, 'text-muted': state.isDisabled}"/>
            </button>

            <!-- Chat Panel (right side drawer) -->
            <div t-if="state.isOpen"
                 class="o_ipai_copilot_panel shadow-lg">

                <!-- Header -->
                <div class="o_ipai_copilot_header d-flex align-items-center justify-content-between px-3 py-2 border-bottom">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa fa-robot text-primary"/>
                        <strong>IPAI Copilot</strong>
                        <span t-if="state.isDisabled"
                              class="badge bg-warning text-dark">Disabled</span>
                    </div>
                    <div class="d-flex gap-1">
                        <button class="btn btn-sm btn-outline-secondary border-0"
                                t-on-click="clearMessages"
                                title="Clear chat">
                            <i class="fa fa-trash-o"/>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary border-0"
                                t-on-click="closePanel"
                                title="Close">
                            <i class="fa fa-times"/>
                        </button>
                    </div>
                </div>

                <!-- Disabled State -->
                <div t-if="state.isDisabled"
                     class="o_ipai_copilot_disabled p-4 text-center text-muted">
                    <i class="fa fa-exclamation-circle fa-2x mb-2 d-block"/>
                    <p class="mb-1"><strong>Copilot is not configured</strong></p>
                    <p class="small">Go to Settings → IPAI Copilot to configure the Azure Foundry connection.</p>
                </div>

                <!-- Message List -->
                <div t-if="!state.isDisabled"
                     class="o_ipai_copilot_messages flex-grow-1 overflow-auto px-3 py-2"
                     t-ref="messageList">

                    <!-- Empty State -->
                    <div t-if="!state.messages.length"
                         class="text-center text-muted mt-4">
                        <i class="fa fa-comments-o fa-2x mb-2 d-block"/>
                        <p class="mb-1">Ask me anything about your Odoo data</p>
                        <p class="small">BIR compliance, expenses, accounting, projects...</p>
                    </div>

                    <!-- Messages -->
                    <t t-foreach="state.messages" t-as="msg" t-key="msg_index">
                        <!-- User Message -->
                        <div t-if="msg.role === 'user'"
                             class="o_ipai_msg o_ipai_msg_user mb-2 d-flex justify-content-end">
                            <div class="bg-primary text-white rounded-3 px-3 py-2 small"
                                 style="max-width: 85%;">
                                <t t-esc="msg.content"/>
                            </div>
                        </div>

                        <!-- Assistant Message -->
                        <div t-if="msg.role === 'assistant'"
                             class="o_ipai_msg o_ipai_msg_assistant mb-2">
                            <div t-att-class="{'bg-light border rounded-3 px-3 py-2 small': true, 'border-warning': msg.blocked}"
                                 style="max-width: 90%;">
                                <div class="o_ipai_msg_content" t-out="msg.content"/>

                                <!-- Citations -->
                                <div t-if="msg.citations and msg.citations.length"
                                     class="o_ipai_citations mt-2 pt-2 border-top">
                                    <small class="text-muted d-block mb-1">
                                        <i class="fa fa-link"/> Sources:
                                    </small>
                                    <t t-foreach="msg.citations" t-as="cite" t-key="cite_index">
                                        <small class="d-block text-primary">
                                            <t t-esc="cite.title || cite.url || cite"/>
                                        </small>
                                    </t>
                                </div>
                            </div>
                            <small class="text-muted ms-1"><t t-esc="msg.timestamp"/></small>
                        </div>

                        <!-- Error Message -->
                        <div t-if="msg.role === 'error'"
                             class="o_ipai_msg o_ipai_msg_error mb-2">
                            <div class="bg-danger bg-opacity-10 border border-danger rounded-3 px-3 py-2 small">
                                <i class="fa fa-exclamation-triangle text-danger me-1"/>
                                <t t-esc="msg.content"/>
                            </div>
                        </div>
                    </t>

                    <!-- Loading Indicator -->
                    <div t-if="state.isLoading"
                         class="o_ipai_msg o_ipai_msg_loading mb-2">
                        <div class="bg-light rounded-3 px-3 py-2 small">
                            <i class="fa fa-spinner fa-spin me-1"/> Thinking...
                        </div>
                    </div>
                </div>

                <!-- Input Area -->
                <div t-if="!state.isDisabled"
                     class="o_ipai_copilot_input border-top px-3 py-2">
                    <div class="d-flex gap-2">
                        <textarea
                            t-ref="promptInput"
                            class="form-control form-control-sm"
                            placeholder="Ask IPAI Copilot..."
                            rows="1"
                            t-on-keydown="onKeyDown"
                            t-att-disabled="state.isLoading"/>
                        <button class="btn btn-primary btn-sm px-3"
                                t-on-click="sendMessage"
                                t-att-disabled="state.isLoading">
                            <i t-att-class="state.isLoading ? 'fa fa-spinner fa-spin' : 'fa fa-paper-plane'"/>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
