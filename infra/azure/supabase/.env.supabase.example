# =============================================================================
# Self-Hosted Supabase — Environment Variables Template
# =============================================================================
# Copy to .env.supabase and fill in all values. NEVER commit .env.supabase.
# Secrets should be sourced from Azure Key Vault (kv-ipai-dev) at deploy time.
#
# Generate JWT keys:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# Generate ANON_KEY and SERVICE_ROLE_KEY:
#   Use https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#   or: npx supabase-key generate --jwt-secret=YOUR_JWT_SECRET
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=your-super-secret-postgres-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_EXTERNAL_PORT=54322

# ---------------------------------------------------------------------------
# JWT / API Keys
# ---------------------------------------------------------------------------
# JWT_SECRET: minimum 32 characters, used to sign all JWT tokens
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# ANON_KEY: public key for client-side access (limited permissions)
# Generate with: npx supabase-key generate --type anon --jwt-secret=YOUR_JWT_SECRET
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.PLACEHOLDER_REPLACE_ME

# SERVICE_ROLE_KEY: secret key for server-side access (bypasses RLS)
# Generate with: npx supabase-key generate --type service_role --jwt-secret=YOUR_JWT_SECRET
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.PLACEHOLDER_REPLACE_ME

# ---------------------------------------------------------------------------
# URLs
# ---------------------------------------------------------------------------
# SITE_URL: The URL of your frontend app (for auth redirects)
SITE_URL=https://insightpulseai.com

# API_EXTERNAL_URL: Public URL of the Supabase API gateway (Kong)
API_EXTERNAL_URL=https://supabase.insightpulseai.com

# ADDITIONAL_REDIRECT_URLS: Comma-separated list of allowed redirect URLs
ADDITIONAL_REDIRECT_URLS=https://erp.insightpulseai.com,https://ops.insightpulseai.com

# ---------------------------------------------------------------------------
# Studio (Dashboard)
# ---------------------------------------------------------------------------
STUDIO_PORT=54323
STUDIO_DEFAULT_ORGANIZATION=InsightPulseAI
STUDIO_DEFAULT_PROJECT=ipai-supabase
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=your-dashboard-password-change-me

# ---------------------------------------------------------------------------
# Kong (API Gateway)
# ---------------------------------------------------------------------------
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# ---------------------------------------------------------------------------
# Auth (GoTrue)
# ---------------------------------------------------------------------------
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_SIGN_IN=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=true

# OAuth — GitHub (optional, enable as needed)
ENABLE_GITHUB_AUTH=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Mailer URL paths
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# ---------------------------------------------------------------------------
# SMTP — Mailgun (mg.insightpulseai.com)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=2525
SMTP_USER=postmaster@mg.insightpulseai.com
SMTP_PASS=your-mailgun-smtp-password
SMTP_ADMIN_EMAIL=noreply@insightpulseai.com
SMTP_SENDER_NAME=InsightPulseAI

# ---------------------------------------------------------------------------
# Realtime
# ---------------------------------------------------------------------------
# REALTIME_DB_ENC_KEY: 32-byte hex string for encrypting realtime DB secrets
REALTIME_DB_ENC_KEY=your-realtime-encryption-key-32bytes-hex
# REALTIME_SECRET_KEY_BASE: 64-byte hex string for Phoenix/Elixir secret
REALTIME_SECRET_KEY_BASE=your-realtime-secret-key-base-at-least-64-characters-long-generate-with-openssl-rand-hex-64

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
STORAGE_FILE_SIZE_LIMIT=52428800
STORAGE_REGION=southeastasia

# ---------------------------------------------------------------------------
# PostgREST
# ---------------------------------------------------------------------------
PGRST_DB_SCHEMAS=public,storage,graphql_public

# ---------------------------------------------------------------------------
# Edge Functions
# ---------------------------------------------------------------------------
FUNCTIONS_VERIFY_JWT=true

# ---------------------------------------------------------------------------
# Analytics / Logflare
# ---------------------------------------------------------------------------
LOGFLARE_API_KEY=your-logflare-api-key
LOGFLARE_PORT=4000

# ---------------------------------------------------------------------------
# imgproxy
# ---------------------------------------------------------------------------
IMGPROXY_ENABLE_WEBP_DETECTION=true
