<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_ppm_budget_line_tree" model="ir.ui.view">
        <field name="name">ppm.budget.line.tree</field>
        <field name="model">ppm.budget.line</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="project_id"/>
                <field name="period_label"/>
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="cost_type"/>
                <field name="budget_amount" sum="Total Budget"/>
                <field name="forecast_amount" sum="Total Forecast"/>
                <field name="actual_amount" sum="Total Actual"/>
                <field name="variance" sum="Total Variance"
                       decoration-danger="variance &lt; 0"
                       decoration-success="variance &gt;= 0"/>
                <field name="variance_pct"/>
                <field name="currency_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_ppm_budget_line_pivot" model="ir.ui.view">
        <field name="name">ppm.budget.line.pivot</field>
        <field name="model">ppm.budget.line</field>
        <field name="arch" type="xml">
            <pivot string="Budget vs Actual">
                <field name="project_id" type="row"/>
                <field name="period_label" type="col"/>
                <field name="budget_amount" type="measure"/>
                <field name="actual_amount" type="measure"/>
                <field name="variance" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_ppm_budget_line_graph" model="ir.ui.view">
        <field name="name">ppm.budget.line.graph</field>
        <field name="model">ppm.budget.line</field>
        <field name="arch" type="xml">
            <graph string="Budget vs Actual" type="bar">
                <field name="project_id" type="row"/>
                <field name="budget_amount" type="measure"/>
                <field name="actual_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_ppm_budget_line" model="ir.actions.act_window">
        <field name="name">Budget Lines</field>
        <field name="res_model">ppm.budget.line</field>
        <field name="view_mode">tree,pivot,graph</field>
    </record>

</odoo>
