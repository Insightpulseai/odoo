# Odoo production environment variables
# Copy to .env and fill in values — NEVER commit actual values
DB_HOST=pg-ipai-odoo.postgres.database.azure.com
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=odoo
ODOO_HTTP_PORT=8069
# All secrets MUST come from Azure Key Vault (kv-ipai-prod)
# Managed identity -> Key Vault -> env vars at runtime
# ZOHO_SMTP_USER: from Key Vault
# ZOHO_SMTP_PASSWORD: from Key Vault
# AZURE_OPENAI_KEY: from Key Vault
