# Dockerfile.gateway — IPAI Copilot Gateway
# Builds the agent-platform builder-factory as an HTTP gateway service.
#
# Build:  docker build -f Dockerfile.gateway -t ipai-copilot-gateway:latest .
# Run:    docker run -p 8088:8088 -e AGENTS_ROOT=/app/agents ipai-copilot-gateway:latest
#
# Required at runtime:
#   AGENTS_ROOT                     — path to agents/ assets (mounted or baked in)
#   AZURE_AI_FOUNDRY_ENDPOINT       — Foundry endpoint (optional, falls back to mock)
#   AZURE_AI_FOUNDRY_KEY            — Foundry API key (optional)
#   AZURE_AI_FOUNDRY_DEPLOYMENT     — model deployment name (default: gpt-4.1)
#   PORT                            — listen port (default: 8088)

FROM node:20-slim AS builder

WORKDIR /build

# Copy workspace root files
COPY package.json package-lock.json* tsconfig.json ./

# Copy all packages and apps
COPY packages/ packages/
COPY apps/ apps/

# Install dependencies and build
RUN npm ci --ignore-scripts 2>/dev/null || npm install --ignore-scripts
RUN npm run build

# ---

FROM node:20-slim AS runtime

WORKDIR /app

# Copy built output
COPY --from=builder /build/package.json ./
COPY --from=builder /build/node_modules/ ./node_modules/
COPY --from=builder /build/packages/ ./packages/
COPY --from=builder /build/apps/ ./apps/

# Agents assets — baked in from _agents/ (prepared by scripts/build-gateway.sh)
COPY _agents/ ./agents/

ENV NODE_ENV=production
ENV PORT=8088
ENV AGENTS_ROOT=/app/agents

EXPOSE 8088

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD node -e "const http=require('http');http.get('http://localhost:8088/health',r=>{process.exit(r.statusCode===200?0:1)}).on('error',()=>process.exit(1))"

CMD ["node", "apps/builder-factory/dist/server.js"]
