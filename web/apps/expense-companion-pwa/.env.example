# --- Odoo session passthrough ---
NEXT_PUBLIC_ODOO_URL=http://localhost:8069
NEXT_PUBLIC_ODOO_DB=odoo_dev

# --- Azure Document Intelligence (server-only) ---
# OAuth-only via DefaultAzureCredential. Do NOT add an API key.
# Production: managed identity on Azure Container Apps with role
#   "Cognitive Services User" on the Document Intelligence resource.
# Dev: az login (the CLI credential is picked up by DefaultAzureCredential).
DOCUMENT_INTELLIGENCE_ENDPOINT=https://<resource-name>.cognitiveservices.azure.com/

# --- Microsoft Entra ID (browser-side MSAL) ---
# Reuse the same Entra app registration as the Odoo deployment so users
# get one OAuth session across both surfaces. Add the PWA origin
# (https://expense.insightpulseai.com) to the app's redirect URIs first.
NEXT_PUBLIC_ENTRA_TENANT_ID=
NEXT_PUBLIC_ENTRA_CLIENT_ID=
NEXT_PUBLIC_ENTRA_REDIRECT_URI=
