<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_expense_liquidation" model="ir.actions.report">
        <field name="name">Expense Liquidation</field>
        <field name="model">hr.expense.liquidation</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ipai_hr_expense_liquidation.report_expense_liquidation</field>
        <field name="report_file">ipai_hr_expense_liquidation.report_expense_liquidation</field>
        <field name="binding_model_id" ref="model_hr_expense_liquidation"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_expense_liquidation">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Expense Liquidation: <t t-out="doc.name"/></h2>
                        <div class="row mt-4 mb-4">
                            <div class="col-6">
                                <strong>Employee:</strong> <t t-out="doc.employee_id.name"/><br/>
                                <strong>Type:</strong> <t t-out="dict(doc._fields['liquidation_type'].selection).get(doc.liquidation_type)"/><br/>
                                <strong>Status:</strong> <t t-out="dict(doc._fields['state'].selection).get(doc.state)"/>
                            </div>
                            <div class="col-6">
                                <strong>Advance Amount:</strong> <t t-out="doc.advance_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/><br/>
                                <strong>Total Expenses:</strong> <t t-out="doc.total_expenses" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/><br/>
                                <strong>Balance:</strong> <t t-out="doc.balance" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </div>
                        </div>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Description</th>
                                    <th>Category</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.line_ids" t-as="line">
                                    <tr>
                                        <td><t t-out="line.date"/></td>
                                        <td><t t-out="line.name"/></td>
                                        <td><t t-out="dict(line._fields['category'].selection).get(line.category)"/></td>
                                        <td class="text-end"><t t-out="line.amount" t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
