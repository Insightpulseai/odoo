{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentRunRef",
  "description": "Reference to an agent run that contributed to a Diva Goals artifact",
  "type": "object",
  "required": ["run_id", "agent_name", "agent_role", "timestamp", "status"],
  "properties": {
    "run_id": { "type": "string", "format": "uuid" },
    "agent_name": { "type": "string" },
    "agent_role": { "type": "string", "enum": ["maker", "judge", "orchestrator", "collector", "reviewer"] },
    "workflow_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["completed", "failed", "pending_approval", "rejected"] },
    "output_type": { "type": "string" },
    "output_ref": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "approved_by": { "type": ["string", "null"] },
    "trace_url": { "type": "string", "format": "uri" }
  }
}
