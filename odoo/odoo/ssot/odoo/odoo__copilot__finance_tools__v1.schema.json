{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://insightpulseai.com/schemas/odoo-copilot-finance-tools/v1",
  "title": "Odoo Copilot Finance Tools Contract",
  "description": "JSON Schema for copilot tool definitions that interact with Odoo CE 19.0 finance and expense models.",
  "type": "object",
  "required": ["name", "version", "generated", "odoo_version", "category", "depends_on", "tools"],
  "properties": {
    "name": {
      "type": "string",
      "const": "odoo-copilot-finance-tools"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+\\.\\d+\\.\\d+$"
    },
    "generated": {
      "type": "string",
      "format": "date"
    },
    "odoo_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "category": {
      "type": "string",
      "const": "copilot-tools"
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of entity contract YAML files this tool set depends on."
    },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/definitions/tool" },
      "minItems": 1
    }
  },
  "definitions": {
    "tool": {
      "type": "object",
      "required": ["name", "description", "parameters", "returns"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Tool identifier (snake_case)."
        },
        "description": {
          "type": "string",
          "description": "What this tool does."
        },
        "parameters": {
          "type": "array",
          "items": { "$ref": "#/definitions/parameter" }
        },
        "returns": {
          "$ref": "#/definitions/return_type"
        },
        "example": {
          "$ref": "#/definitions/example"
        }
      },
      "additionalProperties": false
    },
    "parameter": {
      "type": "object",
      "required": ["name", "type", "required"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Parameter name."
        },
        "type": {
          "type": "string",
          "enum": ["string", "integer", "number", "boolean", "array", "object"],
          "description": "Parameter data type."
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "description": "Format hint (e.g. date, datetime)."
        },
        "enum": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Allowed values for string parameters."
        },
        "items": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "properties": {
                  "type": "object",
                  "additionalProperties": { "$ref": "#/definitions/parameter" }
                }
              }
            },
            {
              "type": "object",
              "properties": {
                "type": { "type": "string" }
              },
              "required": ["type"]
            }
          ],
          "description": "Item schema for array parameters."
        },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/parameter" },
          "description": "Nested properties for object parameters."
        }
      },
      "additionalProperties": false
    },
    "return_type": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["object", "array", "string", "integer", "number", "boolean"]
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "description": { "type": "string" },
              "items": {
                "type": "object",
                "properties": {
                  "type": { "type": "string" },
                  "properties": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "properties": {
                        "type": { "type": "string" },
                        "description": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "items": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "properties": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "type": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "example": {
      "type": "object",
      "required": ["request", "response"],
      "properties": {
        "request": {
          "type": "object",
          "description": "Example tool invocation parameters."
        },
        "response": {
          "description": "Example tool response."
        }
      },
      "additionalProperties": false
    }
  }
}
