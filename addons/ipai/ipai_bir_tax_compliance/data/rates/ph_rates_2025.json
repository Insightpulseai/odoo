  "metadata": {
    "source": "Bureau of Internal Revenue (BIR)",
    "legal_basis": [
      "NIRC (RA 8424) - 1997 (base tax code)",
      "TRAIN Law (RA 10963) - 2017 (individual tax, VAT threshold, excise)",
      "CREATE Law (RA 11534) - 2021 (CIT reduction, MCIT, fiscal incentives)",
      "CREATE MORE Act (RA 12066) - 2024 (permanent 1% MCIT, enhanced RBE incentives)",
      "VAT on Digital Services Act (RA 12023) - 2024 (12% VAT on non-resident DSPs)",
      "RR 11-2018 (EWT implementation of TRAIN)",
      "RR 14-2018 (EWT amendments)",
      "RR 3-2025 (Digital services VAT IRR)",
      "RR 7-2024 (Updated SLSP format)"
    ],
    "last_updated": "2026-04-07",
    "version": "2025.2",
    "breaking_changes_from_2025_1": [
      "MCIT corrected from 2% to 1% per RA 12066 (CREATE MORE)",
      "ATC codes migrated from short-form (W010) to BIR official format (WI010) per RR 11-2018 Annex",
      "Added 5% professional fee tier (WI011) for non-VAT individuals ≤ PHP 3M",
      "Added non-resident FWT rates (NRFC 25% per CREATE, previously 30%)",
      "Added percentage tax (3%, reverted from temporary 1%)",
      "Added digital services VAT (12%, RA 12023)",
      "Added filing deadlines section",
      "Added capital gains tax section",
      "Restructured FWT into resident and non_resident subsections",
      "Added CIT detail: SME rate (20%), RBE special rate (5%), NRFC rate (25%)",
      "Added legacy_code fields for backward compatibility",
      "Added payee_type fields to all EWT entries",
      "Added WI157/WC157/WI158/WC158 supplier goods/services codes",
      "Added WI161 commission agent code",
      "Added WI169/WC169/WI170/WC170 rent codes split by payee type"
    ]
  }
}
