Verification Commands:
----------------------

# Validate workflow files
python3 -c "import yaml; yaml.safe_load(open('.github/workflows/comprehensive-testing.yml'))"
python3 -c "import yaml; yaml.safe_load(open('.github/workflows/ai-test-generation.yml'))"

# Install test dependencies
pip install -r tests/requirements-testing.txt

# Run local unit tests
pytest tests/ -v --cov=addons/ipai --cov-report=html

# Run E2E tests locally
ODOO_BASE_URL=http://localhost:8069 \
ODOO_USERNAME=admin \
ODOO_PASSWORD=admin \
pytest tests/e2e/ -v --headed

# Run k6 performance test
k6 run tests/performance/odoo-comprehensive-load.js \
  --vus 10 \
  --duration 1m

# Run security scans
bandit -c tests/security/.bandit -r addons/ipai -f json
safety check --file tests/requirements-testing.txt --json

# Trigger workflows (requires gh CLI + secrets configured)
gh workflow run comprehensive-testing.yml -f test_type=all
gh workflow run ai-test-generation.yml -f module_name=ipai_finance_ppm

