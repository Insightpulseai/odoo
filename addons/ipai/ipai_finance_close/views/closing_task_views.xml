<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Task Form -->
    <record id="closing_task_form" model="ir.ui.view">
        <field name="name">closing.task.form</field>
        <field name="model">closing.task</field>
        <field name="arch" type="xml">
            <form string="Closing Task">
                <header>
                    <button name="action_start" type="object"
                            string="Start" class="btn-primary"
                            invisible="state != 'open'"/>
                    <button name="action_complete" type="object"
                            string="Complete" class="btn-primary"
                            invisible="state != 'in_progress'"/>
                    <button name="action_approve" type="object"
                            string="Approve" class="btn-success"
                            invisible="state != 'completed'"/>
                    <button name="action_fail" type="object"
                            string="Mark Failed"
                            invisible="state not in ('open', 'in_progress')"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state in ('approved', 'canceled')"
                            confirm="Cancel this task?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="open,in_progress,completed,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                        <field name="code"/>
                    </div>
                    <group>
                        <group string="Definition">
                            <field name="task_list_id"/>
                            <field name="task_type"/>
                            <field name="stage"/>
                            <field name="sequence"/>
                            <field name="planned_hours"/>
                        </group>
                        <group string="Assignment">
                            <field name="processor_id"/>
                            <field name="processor_role"/>
                            <field name="responsible_id"/>
                            <field name="responsible_role"/>
                        </group>
                    </group>
                    <group>
                        <group string="Schedule">
                            <field name="planned_date"/>
                            <field name="actual_start_date"/>
                            <field name="actual_end_date"/>
                            <field name="is_overdue"/>
                        </group>
                        <group string="Dependencies">
                            <field name="dependency_ids" widget="many2many_tags"/>
                            <field name="can_start"/>
                        </group>
                    </group>
                    <group string="Completion">
                        <field name="completion_comment" placeholder="Required for approval tasks"/>
                        <field name="state_changed_by"/>
                        <field name="state_changed_date"/>
                    </group>
                    <field name="description"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Task List View -->
    <record id="closing_task_list_view" model="ir.ui.view">
        <field name="name">closing.task.list.view</field>
        <field name="model">closing.task</field>
        <field name="arch" type="xml">
            <list decoration-danger="is_overdue"
                  decoration-muted="state in ('canceled',)"
                  decoration-success="state in ('completed', 'approved')">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="task_type"/>
                <field name="stage"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('completed', 'approved')"
                       decoration-danger="state == 'failed'"
                       decoration-info="state == 'in_progress'"/>
                <field name="planned_date"/>
                <field name="is_overdue"/>
                <field name="processor_id"/>
                <field name="responsible_id"/>
                <field name="can_start"/>
                <field name="task_list_id"/>
            </list>
        </field>
    </record>

    <!-- Task Action -->
    <record id="action_closing_task" model="ir.actions.act_window">
        <field name="name">Closing Tasks</field>
        <field name="res_model">closing.task</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
