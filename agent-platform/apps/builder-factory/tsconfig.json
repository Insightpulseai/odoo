{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "composite": true
  },
  "include": ["src"],
  "references": [
    { "path": "../../packages/builder-contract" },
    { "path": "../../packages/builder-foundry-client" },
    { "path": "../../packages/builder-orchestrator" },
    { "path": "../../packages/builder-evals" }
  ]
}
