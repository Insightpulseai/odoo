<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- workspace.page: form view                                     -->
    <!-- ============================================================ -->
    <record id="view_workspace_page_form" model="ir.ui.view">
        <field name="name">workspace.page.form</field>
        <field name="model">workspace.page</field>
        <field name="arch" type="xml">
            <form string="Workspace Page">
                <header>
                    <field name="is_published" widget="boolean_button"
                           options='{"terminology": "published"}'/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Page Title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="owner_id"/>
                            <field name="parent_id"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="tag_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <field name="body"/>
                        </page>
                        <page string="Blocks" name="blocks">
                            <field name="block_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="block_type"/>
                                    <field name="content"/>
                                    <field name="res_model"
                                           invisible="block_type != 'embed_view'"/>
                                    <field name="view_type"
                                           invisible="block_type != 'embed_view'"/>
                                    <field name="domain"
                                           invisible="block_type != 'embed_view'"/>
                                    <field name="saved_query_id"
                                           invisible="block_type != 'saved_query'"/>
                                    <field name="evidence_pack_id"
                                           invisible="block_type != 'evidence_ref'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Sub-pages" name="sub_pages">
                            <field name="child_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="owner_id"/>
                                    <field name="is_published"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- workspace.page: list view                                     -->
    <!-- ============================================================ -->
    <record id="view_workspace_page_list" model="ir.ui.view">
        <field name="name">workspace.page.list</field>
        <field name="model">workspace.page</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="owner_id"/>
                <field name="parent_id" optional="show"/>
                <field name="tag_ids" widget="many2many_tags"
                       options="{'color_field': 'color'}"/>
                <field name="is_published"/>
                <field name="write_date"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- workspace.page: search view                                   -->
    <!-- ============================================================ -->
    <record id="view_workspace_page_search" model="ir.ui.view">
        <field name="name">workspace.page.search</field>
        <field name="model">workspace.page</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="owner_id"/>
                <field name="tag_ids"/>
                <filter name="my_pages" string="My Pages"
                        domain="[('owner_id', '=', uid)]"/>
                <filter name="published" string="Published"
                        domain="[('is_published', '=', True)]"/>
                <separator/>
                <filter name="group_owner" string="Owner"
                        context="{'group_by': 'owner_id'}"/>
                <filter name="group_parent" string="Parent Page"
                        context="{'group_by': 'parent_id'}"/>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- workspace.page: action                                        -->
    <!-- ============================================================ -->
    <record id="action_workspace_page" model="ir.actions.act_window">
        <field name="name">Pages</field>
        <field name="res_model">workspace.page</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_workspace_page_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first workspace page
            </p>
            <p>Pages are Notion-like documents with rich content blocks.</p>
        </field>
    </record>

</odoo>
