<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add DocAI extract button + status to vendor bill form -->
    <record id="view_move_form_docai" model="ir.ui.view">
        <field name="name">account.move.form.docai</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add Extract button next to other header buttons -->
            <xpath expr="//header" position="inside">
                <button name="action_extract_with_docai"
                        string="Extract with DocAI"
                        type="object"
                        class="oe_highlight"
                        invisible="move_type not in ('in_invoice', 'in_refund') or state != 'draft'"
                        icon="fa-magic"/>
            </xpath>

            <!-- Add DocAI status fields after invoice_date -->
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="x_docai_status"
                       widget="badge"
                       decoration-info="x_docai_status == 'extracting'"
                       decoration-success="x_docai_status == 'extracted'"
                       decoration-warning="x_docai_status == 'review'"
                       decoration-danger="x_docai_status == 'failed'"
                       invisible="x_docai_status == 'none'"
                       readonly="1"/>
                <field name="x_docai_confidence"
                       invisible="x_docai_status not in ('extracted', 'review')"
                       readonly="1"
                       widget="percentage"/>
            </xpath>
        </field>
    </record>

    <!-- Tree view: add DocAI status column to vendor bills list -->
    <record id="view_move_tree_docai" model="ir.ui.view">
        <field name="name">account.move.tree.docai</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_in_invoice_bill_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="x_docai_status"
                       widget="badge"
                       decoration-info="x_docai_status == 'extracting'"
                       decoration-success="x_docai_status == 'extracted'"
                       decoration-warning="x_docai_status == 'review'"
                       decoration-danger="x_docai_status == 'failed'"
                       optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
