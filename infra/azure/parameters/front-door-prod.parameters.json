{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "profileName": {
      "value": "ipai-prod-fd"
    },
    "wafPolicyName": {
      "value": "ipaiProdWafPolicy"
    },
    "enableWaf": {
      "value": true
    },
    "originGroups": {
      "value": [
        {
          "name": "odoo-web",
          "origins": [
            {
              "hostName": "odoo-web.internal.insightpulseai.com",
              "originHostHeader": "erp.insightpulseai.com",
              "httpPort": 80,
              "httpsPort": 443,
              "priority": 1,
              "weight": 1000
            }
          ],
          "healthProbePath": "/web/health",
          "healthProbeProtocol": "Https",
          "healthProbeIntervalInSeconds": 30
        },
        {
          "name": "n8n",
          "origins": [
            {
              "hostName": "n8n.internal.insightpulseai.com",
              "httpPort": 80,
              "httpsPort": 443,
              "priority": 1,
              "weight": 1000
            }
          ],
          "healthProbePath": "/healthz",
          "healthProbeProtocol": "Https",
          "healthProbeIntervalInSeconds": 30
        },
        {
          "name": "mcp-gateway",
          "origins": [
            {
              "hostName": "mcp-gateway.internal.insightpulseai.com",
              "httpPort": 80,
              "httpsPort": 443,
              "priority": 1,
              "weight": 1000
            }
          ],
          "healthProbePath": "/healthz",
          "healthProbeProtocol": "Https",
          "healthProbeIntervalInSeconds": 30
        },
        {
          "name": "plane",
          "origins": [
            {
              "hostName": "plane.internal.insightpulseai.com",
              "httpPort": 80,
              "httpsPort": 443,
              "priority": 1,
              "weight": 1000
            }
          ],
          "healthProbePath": "/",
          "healthProbeProtocol": "Https",
          "healthProbeIntervalInSeconds": 60
        },
        {
          "name": "shelf",
          "origins": [
            {
              "hostName": "shelf.internal.insightpulseai.com",
              "httpPort": 80,
              "httpsPort": 443,
              "priority": 1,
              "weight": 1000
            }
          ],
          "healthProbePath": "/healthcheck",
          "healthProbeProtocol": "Https",
          "healthProbeIntervalInSeconds": 60
        },
        {
          "name": "crm",
          "origins": [
            {
              "hostName": "crm.internal.insightpulseai.com",
              "httpPort": 80,
              "httpsPort": 443,
              "priority": 1,
              "weight": 1000
            }
          ],
          "healthProbePath": "/",
          "healthProbeProtocol": "Https",
          "healthProbeIntervalInSeconds": 60
        },
        {
          "name": "superset",
          "origins": [
            {
              "hostName": "superset.internal.insightpulseai.com",
              "httpPort": 80,
              "httpsPort": 443,
              "priority": 1,
              "weight": 1000
            }
          ],
          "healthProbePath": "/health",
          "healthProbeProtocol": "Https",
          "healthProbeIntervalInSeconds": 30
        },
        {
          "name": "ocr",
          "origins": [
            {
              "hostName": "ocr.internal.insightpulseai.com",
              "httpPort": 80,
              "httpsPort": 443,
              "priority": 1,
              "weight": 1000
            }
          ],
          "healthProbePath": "/health",
          "healthProbeProtocol": "Https",
          "healthProbeIntervalInSeconds": 60
        },
        {
          "name": "auth",
          "origins": [
            {
              "hostName": "auth.internal.insightpulseai.com",
              "httpPort": 80,
              "httpsPort": 443,
              "priority": 1,
              "weight": 1000
            }
          ],
          "healthProbePath": "/",
          "healthProbeProtocol": "Https",
          "healthProbeIntervalInSeconds": 60
        },
        {
          "name": "redirect",
          "origins": [
            {
              "hostName": "odoo-web.internal.insightpulseai.com",
              "originHostHeader": "erp.insightpulseai.com",
              "httpPort": 80,
              "httpsPort": 443,
              "priority": 1,
              "weight": 1000
            }
          ],
          "healthProbePath": "/web/health",
          "healthProbeProtocol": "Https",
          "healthProbeIntervalInSeconds": 60
        }
      ]
    },
    "customDomains": {
      "value": [
        { "hostName": "erp.insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "n8n.insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "mcp.insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "plane.insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "shelf.insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "crm.insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "superset.insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "ocr.insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "auth.insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "www.insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "erp-azure.insightpulseai.com", "certificateType": "ManagedCertificate" },
        { "hostName": "n8n-azure.insightpulseai.com", "certificateType": "ManagedCertificate" }
      ]
    },
    "routes": {
      "value": [
        {
          "name": "erp-static",
          "customDomains": ["erp.insightpulseai.com", "erp-azure.insightpulseai.com"],
          "originGroupName": "odoo-web",
          "patternsToMatch": ["/web/static/*"],
          "cacheEnabled": true,
          "cacheDuration": "P30D",
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "erp-content",
          "customDomains": ["erp.insightpulseai.com", "erp-azure.insightpulseai.com"],
          "originGroupName": "odoo-web",
          "patternsToMatch": ["/web/image/*", "/web/content/*"],
          "cacheEnabled": true,
          "cacheDuration": "P7D",
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "erp-websocket",
          "customDomains": ["erp.insightpulseai.com", "erp-azure.insightpulseai.com"],
          "originGroupName": "odoo-web",
          "patternsToMatch": ["/websocket", "/longpolling/*"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "erp-rpc",
          "customDomains": ["erp.insightpulseai.com", "erp-azure.insightpulseai.com"],
          "originGroupName": "odoo-web",
          "patternsToMatch": ["/xmlrpc/*", "/jsonrpc"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "erp-default",
          "customDomains": ["erp.insightpulseai.com", "erp-azure.insightpulseai.com"],
          "originGroupName": "odoo-web",
          "patternsToMatch": ["/*"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "n8n-default",
          "customDomains": ["n8n.insightpulseai.com", "n8n-azure.insightpulseai.com"],
          "originGroupName": "n8n",
          "patternsToMatch": ["/*"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "mcp-default",
          "customDomains": ["mcp.insightpulseai.com"],
          "originGroupName": "mcp-gateway",
          "patternsToMatch": ["/*"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "plane-default",
          "customDomains": ["plane.insightpulseai.com"],
          "originGroupName": "plane",
          "patternsToMatch": ["/*"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "shelf-default",
          "customDomains": ["shelf.insightpulseai.com"],
          "originGroupName": "shelf",
          "patternsToMatch": ["/*"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "crm-default",
          "customDomains": ["crm.insightpulseai.com"],
          "originGroupName": "crm",
          "patternsToMatch": ["/*"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "superset-default",
          "customDomains": ["superset.insightpulseai.com"],
          "originGroupName": "superset",
          "patternsToMatch": ["/*"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "ocr-default",
          "customDomains": ["ocr.insightpulseai.com"],
          "originGroupName": "ocr",
          "patternsToMatch": ["/*"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "auth-default",
          "customDomains": ["auth.insightpulseai.com"],
          "originGroupName": "auth",
          "patternsToMatch": ["/*"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        },
        {
          "name": "root-redirect",
          "customDomains": ["insightpulseai.com", "www.insightpulseai.com"],
          "originGroupName": "redirect",
          "patternsToMatch": ["/*"],
          "cacheEnabled": false,
          "forwardingProtocol": "HttpsOnly",
          "enabledState": "Enabled"
        }
      ]
    }
  }
}
