<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_ask_ai_azure" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.ipai.ask.ai.azure</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Ask AI (Azure)" string="Ask AI (Azure)">
                    <block title="Azure OpenAI Configuration">
                        <setting string="Azure OpenAI Endpoint"
                                 help="Full Azure OpenAI resource URL (e.g. https://myresource.openai.azure.com)">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="ipai_ask_ai_azure_endpoint" class="col-lg-3"/>
                                    <field name="ipai_ask_ai_azure_endpoint" class="col-lg-6"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="API Key"
                                 help="Azure OpenAI API key (stored server-side only)">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="ipai_ask_ai_azure_api_key" class="col-lg-3"/>
                                    <field name="ipai_ask_ai_azure_api_key" class="col-lg-6" password="True"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Model / Deployment Name"
                                 help="Azure OpenAI deployment name (e.g. gpt-4o)">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="ipai_ask_ai_azure_model" class="col-lg-3"/>
                                    <field name="ipai_ask_ai_azure_model" class="col-lg-6"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="API Version"
                                 help="Azure OpenAI API version string">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="ipai_ask_ai_azure_api_version" class="col-lg-3"/>
                                    <field name="ipai_ask_ai_azure_api_version" class="col-lg-6"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
