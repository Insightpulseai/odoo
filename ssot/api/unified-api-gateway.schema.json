{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unified API Gateway SSOT",
  "description": "Schema for ssot/api/unified-api-gateway.yaml",
  "type": "object",
  "required": ["version", "last_updated", "gateway", "route_groups", "systems", "authority_matrix", "rate_limit_tiers"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "last_updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "gateway": {
      "type": "object",
      "required": ["canonical_hostname", "version_prefix", "ingress_owner", "gateway_product", "auth_mode", "tls"],
      "properties": {
        "canonical_hostname": { "type": "string" },
        "version_prefix": { "type": "string", "pattern": "^/api/v\\d+$" },
        "ingress_owner": { "type": "string" },
        "gateway_product": { "type": "string" },
        "gateway_tier": { "type": "string" },
        "auth_mode": { "type": "string" },
        "tls": { "type": "string" },
        "waf": { "type": "string" }
      }
    },
    "rate_limit_tiers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["requests_per_minute"],
        "properties": {
          "requests_per_minute": { "type": "integer", "minimum": 1 },
          "description": { "type": "string" }
        }
      }
    },
    "route_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "prefix", "backing_system", "authority_type", "owner", "allowed_methods", "auth_required", "audit_required", "status"],
        "properties": {
          "id": { "type": "string" },
          "prefix": { "type": "string", "pattern": "^/api/v\\d+/" },
          "backing_system": { "type": "string" },
          "authority_type": {
            "type": "string",
            "enum": ["system_of_record", "single_source_of_truth", "runtime", "read_only_summary", "orchestration_only"]
          },
          "owner": { "type": "string" },
          "internal_origin": { "type": "string" },
          "allowed_methods": {
            "type": "array",
            "items": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] }
          },
          "auth_required": { "type": "boolean" },
          "audit_required": { "type": "boolean" },
          "rate_limit_tier": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["planned", "active", "blocked", "deprecated"]
          },
          "blocker": { "type": "string" },
          "examples": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "if": {
          "properties": { "status": { "const": "blocked" } }
        },
        "then": {
          "required": ["blocker"]
        }
      }
    },
    "systems": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["role", "domains"],
        "properties": {
          "role": { "type": "string" },
          "domains": { "type": "array", "items": { "type": "string" } },
          "hostname": { "type": "string" },
          "project_ref": { "type": "string" },
          "ui_surface": { "type": "boolean" },
          "api_via_gateway": { "type": "boolean" }
        }
      }
    },
    "authority_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["domain", "authoritative_system", "forbidden_operations"],
        "properties": {
          "domain": { "type": "string" },
          "authoritative_system": { "type": "string" },
          "writable_via_gateway": { "type": "boolean" },
          "read_only_via_gateway": { "type": "boolean" },
          "forbidden_operations": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    },
    "migration_phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status"],
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "status": { "type": "string", "enum": ["not_started", "in_progress", "complete", "blocked"] },
          "dependencies": { "type": "array", "items": { "type": "integer" } }
        }
      }
    },
    "dns": { "type": "object" }
  }
}
