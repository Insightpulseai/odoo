<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ipai_odoo_copilot.SystrayButton">
        <div class="o_ipai_copilot_systray">
            <!-- Systray Icon -->
            <button class="o_ipai_copilot_btn btn border-0 bg-transparent"
                    t-on-click="togglePanel"
                    title="Pulser"
                    t-att-class="{'o_ipai_copilot_btn_active': state.isOpen}">
                <img class="o_ipai_copilot_icon_img"
                     src="/mail/static/src/img/odoobot.png"
                     alt="Pulser"/>
            </button>

            <!-- Chat Panel (right side drawer) -->
            <div t-if="state.isOpen"
                 class="o_ipai_copilot_panel shadow-lg">

                <!-- Header -->
                <div class="o_ipai_copilot_header d-flex align-items-center justify-content-between px-3 py-2 border-bottom">
                    <div class="d-flex align-items-center gap-2">
                        <img class="o_ipai_copilot_header_icon"
                             src="/mail/static/src/img/odoobot.png"
                             alt="Pulser"/>
                        <strong>Pulser</strong>
                    </div>
                    <div class="d-flex gap-1">
                        <button class="btn btn-sm btn-outline-secondary border-0"
                                t-on-click="clearMessages"
                                title="New conversation">
                            <i class="fa fa-plus"/>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary border-0"
                                t-on-click="closePanel"
                                title="Close">
                            <i class="fa fa-times"/>
                        </button>
                    </div>
                </div>

                <!-- Message List (drop zone) -->
                <div class="o_ipai_copilot_messages flex-grow-1 overflow-auto px-3 py-2"
                     t-ref="messageList"
                     t-on-dragover="onDragOver"
                     t-on-dragleave="onDragLeave"
                     t-on-drop="onDrop">

                    <!-- Empty State -->
                    <div t-if="!state.messages.length"
                         class="o_ipai_copilot_empty text-center text-muted mt-5">
                        <svg width="40" height="40" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="1.5"
                             stroke-linecap="round" stroke-linejoin="round"
                             class="mb-3 d-block mx-auto" style="opacity: 0.4">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                        </svg>
                        <p class="mb-1 fw-bold">How can I help?</p>
                        <p class="small">Ask about Odoo modules, workflows, BIR compliance, or your ERP data. I can search documentation and your records.</p>
                    </div>

                    <!-- Messages -->
                    <t t-foreach="state.messages" t-as="msg" t-key="msg_index">
                        <!-- User Message -->
                        <div t-if="msg.role === 'user'"
                             class="o_ipai_copilot_message o_ipai_copilot_message_user mb-2 d-flex justify-content-end">
                            <div class="o_ipai_copilot_bubble_user rounded-3 px-3 py-2 small">
                                <t t-if="msg.attachments and msg.attachments.length">
                                    <div class="o_ipai_copilot_attachments mb-1">
                                        <t t-foreach="msg.attachments" t-as="fname" t-key="fname_index">
                                            <span class="o_ipai_copilot_file_chip">
                                                <i class="fa fa-paperclip me-1"/>
                                                <t t-esc="fname"/>
                                            </span>
                                        </t>
                                    </div>
                                </t>
                                <t t-if="msg.content" t-esc="msg.content"/>
                            </div>
                        </div>

                        <!-- Assistant Message -->
                        <div t-if="msg.role === 'assistant'"
                             class="o_ipai_copilot_message o_ipai_copilot_message_assistant mb-2">
                            <div class="o_ipai_copilot_bubble_assistant rounded-3 px-3 py-2 small"
                                 style="max-width: 90%;">
                                <div class="o_ipai_copilot_content" t-esc="msg.content"/>
                                <div t-if="msg.latency_ms"
                                     class="text-muted mt-1"
                                     style="font-size: 0.7rem;">
                                    <t t-esc="msg.latency_ms"/>ms
                                </div>
                            </div>
                            <small class="text-muted ms-1"><t t-esc="msg.timestamp"/></small>
                        </div>

                        <!-- Error Message -->
                        <div t-if="msg.role === 'error'"
                             class="o_ipai_copilot_message o_ipai_copilot_message_error mb-2">
                            <div class="bg-danger bg-opacity-10 border border-danger rounded-3 px-3 py-2 small">
                                <i class="fa fa-exclamation-triangle text-danger me-1"/>
                                <t t-esc="msg.content"/>
                            </div>
                        </div>
                    </t>

                    <!-- Loading Indicator -->
                    <div t-if="state.isLoading"
                         class="o_ipai_copilot_message o_ipai_copilot_message_loading mb-2">
                        <div class="bg-light rounded-3 px-3 py-2 small">
                            <span class="o_ipai_copilot_typing">
                                <span class="o_ipai_copilot_dot"/>
                                <span class="o_ipai_copilot_dot"/>
                                <span class="o_ipai_copilot_dot"/>
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Input Area -->
                <div class="o_ipai_copilot_input border-top px-3 py-2">
                    <!-- Pending Files -->
                    <div t-if="state.pendingFiles.length"
                         class="o_ipai_copilot_pending_files d-flex flex-wrap gap-1 mb-2">
                        <t t-foreach="state.pendingFiles" t-as="pf" t-key="pf_index">
                            <span class="o_ipai_copilot_pending_chip badge bg-secondary d-flex align-items-center gap-1">
                                <i class="fa fa-file-o"/>
                                <span class="text-truncate" style="max-width: 120px;">
                                    <t t-esc="pf.name"/>
                                </span>
                                <button class="btn-close btn-close-white ms-1"
                                        style="font-size: 0.5rem;"
                                        t-on-click="() => this.removePendingFile(pf_index)"
                                        title="Remove"/>
                            </span>
                        </t>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary border-0 px-2"
                                t-on-click="onClickAttach"
                                t-att-disabled="state.isLoading"
                                title="Attach file">
                            <i class="fa fa-paperclip"/>
                        </button>
                        <input type="file"
                               t-ref="fileInput"
                               class="d-none"
                               multiple="multiple"
                               accept=".pdf,.png,.jpg,.jpeg,.gif,.webp,.txt,.csv,.html,.xlsx,.xls,.docx,.json"
                               t-on-change="onFileChange"/>
                        <textarea
                            t-ref="promptInput"
                            class="form-control form-control-sm"
                            placeholder="Ask Pulser..."
                            rows="1"
                            t-on-keydown="onKeyDown"
                            t-att-disabled="state.isLoading"/>
                        <button class="btn btn-primary btn-sm px-3"
                                t-on-click="sendMessage"
                                t-att-disabled="state.isLoading">
                            <i t-att-class="state.isLoading ? 'fa fa-spinner fa-spin' : 'fa fa-paper-plane'"/>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
