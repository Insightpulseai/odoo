<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_ipai_ap" model="ir.ui.view">
        <field name="name">account.move.form.ipai.ap</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_ipai_ingest_ocr" string="AI Ingest OCR" type="object" 
                        attrs="{'invisible': [('ipai_ap_state', '!=', 'ingested')]}"/>
                <button name="action_ipai_match_po" string="AI Match PO" type="object" 
                        attrs="{'invisible': [('ipai_ap_state', 'not in', ['draft', 'tax_verified'])]}"/>
                <button name="action_ipai_verify_tax" string="AI Verify Tax" type="object" class="oe_highlight" 
                        attrs="{'invisible': [('ipai_ap_state', 'not in', ['ingested', 'draft'])]}"/>
                <button name="action_ipai_rehearse_staging" string="AI Ops: Rehearse Staging" type="object" groups="base.group_system"/>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="alert alert-info" role="alert" attrs="{'invisible': [('ipai_ap_state', '==', False)]}">
                    AI Status: <field name="ipai_ap_state" class="oe_inline"/>
                </div>
            </xpath>
            <xpath expr="//page[@name='other_info']" position="inside">
                <group string="AI Compliance">
                    <field name="ipai_po_id"/>
                    <field name="ipai_compliance_log"/>
                    <field name="ipai_evidence_pack"/>
                    <field name="ipai_ocr_raw" groups="base.group_no_one"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
