<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="l10n_ph_bir_filing_view_list" model="ir.ui.view">
        <field name="name">l10n.ph.bir.filing.list</field>
        <field name="model">l10n.ph.bir.filing</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="form_code"/>
                <field name="branch_id"/>
                <field name="period_id"/>
                <field name="filing_reference"/>
                <field name="filing_datetime"/>
                <field name="amount_due"/>
                <field name="amount_paid"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'paid'"
                       decoration-info="status == 'filed'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="l10n_ph_bir_filing_view_form" model="ir.ui.view">
        <field name="name">l10n.ph.bir.filing.form</field>
        <field name="model">l10n.ph.bir.filing</field>
        <field name="arch" type="xml">
            <form string="BIR Filing Record">
                <header>
                    <button name="action_mark_filed" type="object"
                            string="Mark Filed" class="oe_highlight"
                            invisible="status != 'draft'"
                            groups="ipai_bir_compliance.group_bir_compliance_manager"/>
                    <button name="action_mark_paid" type="object"
                            string="Mark Paid" class="oe_highlight"
                            invisible="status != 'filed'"
                            groups="ipai_bir_compliance.group_bir_compliance_manager"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,filed,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Filing Details">
                            <field name="period_id"/>
                            <field name="form_code"/>
                            <field name="branch_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Filing Reference">
                            <field name="filing_reference"/>
                            <field name="filing_datetime"/>
                        </group>
                    </group>
                    <group>
                        <group string="Payment">
                            <field name="currency_id" invisible="1"/>
                            <field name="amount_due"/>
                            <field name="amount_paid"/>
                            <field name="payment_reference"/>
                            <field name="payment_datetime"/>
                        </group>
                        <group string="Attachments">
                            <field name="return_attachment_id"/>
                            <field name="payment_proof_attachment_id"/>
                            <field name="alphalist_attachment_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="l10n_ph_bir_filing_action" model="ir.actions.act_window">
        <field name="name">Filed Returns</field>
        <field name="res_model">l10n.ph.bir.filing</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
