{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environment": {
      "value": "staging"
    },
    "baseName": {
      "value": "ipai"
    },
    "databricksTier": {
      "value": "standard"
    },
    "appServiceSku": {
      "value": "B2"
    },
    "enableLogAnalytics": {
      "value": true
    },
    "logAnalyticsRetentionDays": {
      "value": 30
    },
    "enableFrontDoor": {
      "value": false
    },
    "enableApim": {
      "value": false
    },
    "enableOdooServices": {
      "value": true
    }
  }
}
