{
  "env": {
    "GH_HOST": "github.com",
    "DOCKER_CONTEXT": "colima",
    "CLAUDE_CODE_USE_FOUNDRY": "1",
    "ANTHROPIC_FOUNDRY_RESOURCE": "data-intel-ph-resource",
    "IPAI_AZURE_AI_HUB": "aifoundry-ipai-dev",
    "IPAI_AZURE_AI_PROJECT": "data-intel-ph",
    "IPAI_AZURE_DOC_INTELLIGENCE_RESOURCE": "docai-ipai-dev",
    "IPAI_AZURE_KEY_VAULT": "aifoundrkeyvault67125c7c",
    "IPAI_AZURE_APP_INSIGHTS": "appi-ipai-dev",
    "IPAI_AZURE_CONTAINERAPPS_ENV": "cae-ipai-dev",
    "IPAI_AZURE_ACR": "cripaidev",
    "IPAI_AZURE_BUILD_POOL": "ipai-build-pool",
    "IPAI_AZURE_DEVOPS_ORG": "insightpulseai"
  },
  "permissions": {
    "allow": [
      "Edit",
      "Read",
      "Write",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(docker --context colima *)",
      "Bash(docker context show)",
      "Bash(docker compose *)",
      "Bash(python3 *)",
      "Bash(python3 -m py_compile*)",
      "Bash(black *)",
      "Bash(isort *)",
      "Bash(flake8*)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(curl *)",
      "Bash(ls *)",
      "Bash(which *)",
      "Bash(./scripts/*)"
    ],
    "deny": [
      "Bash(docker context use *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./ssot/secrets/**)"
    ]
  },
  "agentCommands": {
    "plan": ".claude/commands/plan.md",
    "implement": ".claude/commands/implement.md",
    "verify": ".claude/commands/verify.md",
    "ship": ".claude/commands/ship.md",
    "fix-github-issue": ".claude/commands/fix-github-issue.md",
    "speckit.constitution": ".claude/commands/speckit.constitution.md",
    "speckit.specify": ".claude/commands/speckit.specify.md",
    "speckit.clarify": ".claude/commands/speckit.clarify.md",
    "speckit.plan": ".claude/commands/speckit.plan.md",
    "speckit.tasks": ".claude/commands/speckit.tasks.md",
    "speckit.analyze": ".claude/commands/speckit.analyze.md",
    "speckit.checklist": ".claude/commands/speckit.checklist.md",
    "speckit.implement": ".claude/commands/speckit.implement.md"
  }
}
