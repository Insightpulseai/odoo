<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">

    <record id="seq_tax_review" model="ir.sequence">
        <field name="name">Tax Review</field>
        <field name="code">ipai.tax.review</field>
        <field name="prefix">TR-%(year)s-</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_bir_export_batch" model="ir.sequence">
        <field name="name">BIR Export Batch</field>
        <field name="code">ipai.bir.export.batch</field>
        <field name="prefix">BIR-%(year)s-</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
