{
  "mcpServers": {
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "azure": {
      "command": "npx",
      "args": ["-y", "@azure/mcp@latest", "server", "start"]
    },
    "azure-devops": {
      "command": "npx",
      "args": ["-y", "@azure-devops/mcp", "insightpulseai"]
    },
    "foundry": {
      "command": "uvx",
      "args": [
        "--prerelease=allow",
        "--from",
        "git+https://github.com/azure-ai-foundry/mcp-foundry.git",
        "run-azure-ai-foundry-mcp"
      ],
      "env": {
        "AZURE_AI_FOUNDRY_ENDPOINT": "https://ipai-copilot-resource.services.ai.azure.com/api/projects/proj-ipai-copilot"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  },
  "_removed": {
    "_note": "Entries removed 2026-04-19 per ssot/governance/mcp-allowlist.yaml",
    "github": "HTTP Copilot endpoint unauthenticated; re-add when GH Copilot MCP license is wired",
    "figma": "Local HTTP fails; claude.ai Figma remote connector covers this role",
    "databricks-genie": "Stale warehouse ID + module not installed + placeholder space ID; re-add via Databricks native Genie-as-MCP (Workspace Settings → MCP Servers) when adopted"
  }
}
