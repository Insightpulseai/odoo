<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- workspace.saved.query: form view                              -->
    <!-- ============================================================ -->
    <record id="view_workspace_saved_query_form" model="ir.ui.view">
        <field name="name">workspace.saved.query.form</field>
        <field name="model">workspace.saved.query</field>
        <field name="arch" type="xml">
            <form string="Saved Query">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Query Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="query_text"/>
                            <field name="corpus_id"/>
                            <field name="top_k"/>
                        </group>
                        <group>
                            <field name="owner_id"/>
                            <field name="last_run"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cached Results" name="results">
                            <field name="cached_results" widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                        <page string="Used In Blocks" name="blocks">
                            <field name="block_ids">
                                <list>
                                    <field name="page_id"/>
                                    <field name="sequence"/>
                                    <field name="block_type"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- workspace.saved.query: list view                              -->
    <!-- ============================================================ -->
    <record id="view_workspace_saved_query_list" model="ir.ui.view">
        <field name="name">workspace.saved.query.list</field>
        <field name="model">workspace.saved.query</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="query_text"/>
                <field name="corpus_id"/>
                <field name="top_k"/>
                <field name="owner_id"/>
                <field name="last_run"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- workspace.saved.query: action                                 -->
    <!-- ============================================================ -->
    <record id="action_workspace_saved_query" model="ir.actions.act_window">
        <field name="name">Saved Queries</field>
        <field name="res_model">workspace.saved.query</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Save your first RAG query
            </p>
            <p>Saved queries let you re-run knowledge searches and embed results in pages.</p>
        </field>
    </record>

</odoo>
