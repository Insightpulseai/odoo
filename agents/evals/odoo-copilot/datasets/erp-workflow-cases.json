      },
      "idempotent": true
    },
    {
      "id": "wf-003",
      "category": "finance_close",
      "query": "Reconcile all unreconciled bank statement lines for BDO checking account as of March 31.",
      "context": {
        "company_id": "ipai-main",
        "user_role": "account.group_account_manager",
        "active_model": "account.bank.statement.line",
        "active_record_id": null
      },
      "expected_actions": [
        "account.bank.statement.line.search([('journal_id.name', '=', 'BDO Checking'), ('is_reconciled', '=', False)])",
        "account.reconcile.model.apply_rules()",
        "account.bank.statement.line.reconcile()"
      ],
      "expected_output": {
        "status": "reconciled",
        "journal": "BDO Checking"
      },
      "pass_criteria": {
        "must_contain": ["reconcile", "BDO", "bank statement"],
        "must_not_contain": ["skipped", "ignored"],
        "behavior": "action"
      },
      "idempotent": true
    },
