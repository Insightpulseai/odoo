# ============================================================================
# InsightPulseAI / Azure Foundry / Odoo / APIM
# Canonical .env.example
# Do not commit real secrets.
# ============================================================================

# ============================================================================
# 1) Claude Code / Microsoft Foundry
# Purpose:
# - Used by Claude Code itself when routed through Microsoft Foundry
# - This is NOT the same as the Odoo bridge app config
# Docs:
# - Claude Code on Microsoft Foundry
# - Claude Code enterprise network config
# ============================================================================

# Enable Foundry integration for Claude Code
CLAUDE_CODE_USE_FOUNDRY=1

# Preferred: Azure resource name
ANTHROPIC_FOUNDRY_RESOURCE=data-intel-ph-resource

# Optional alternative to ANTHROPIC_FOUNDRY_RESOURCE
# If set, this should point to the Anthropic base under the Foundry resource
ANTHROPIC_FOUNDRY_BASE_URL=https://data-intel-ph-resource.services.ai.azure.com/anthropic

# Authentication option A: API key
# Leave blank if using Azure credential chain / az login
ANTHROPIC_FOUNDRY_API_KEY=

# Optional pinned deployment names for Claude Code model routing
# Set these only if you have matching Claude deployments in Foundry
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=

# ============================================================================
# 2) Odoo bridge / Azure AI Foundry
# Purpose:
# - Used by the Odoo addon / bridge service
# - Project endpoint is for project-scoped capabilities
# - Resource endpoint is for the parent Foundry resource
# ============================================================================

# Canonical Foundry project endpoint
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://data-intel-ph-resource.services.ai.azure.com/api/projects/data-intel-ph

# Canonical Foundry resource endpoint
AZURE_AI_FOUNDRY_ENDPOINT=https://data-intel-ph-resource.services.ai.azure.com/

# Odoo copilot physical agent name currently shown in Foundry
AZURE_AI_FOUNDRY_AGENT_ID=ipai-odoo-copilot-azure

# If your app expects AGENT_NAME instead of AGENT_ID, use this instead/as well
AZURE_AI_FOUNDRY_AGENT_NAME=ipai-odoo-copilot-azure

# Resource API key from:
# data-intel-ph-resource -> Keys and Endpoint -> Foundry
AZURE_AI_FOUNDRY_API_KEY=

# Optional project metadata
AZURE_AI_FOUNDRY_PROJECT_NAME=data-intel-ph
AZURE_AI_FOUNDRY_RESOURCE_NAME=data-intel-ph-resource
AZURE_AI_FOUNDRY_REGION=eastus2

# Optional model deployment names currently visible in Foundry
AZURE_AI_FOUNDRY_CHAT_DEPLOYMENT=gpt-4.1
AZURE_AI_FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optional Azure auth behavior flags for app code
# managed_identity | api_key | azure_cli | default_credential
AZURE_AI_FOUNDRY_AUTH_MODE=api_key

# Optional Azure SDK audience override if your code needs it
AZURE_AI_FOUNDRY_AUTH_AUDIENCE=https://ai.azure.com/.default

# ============================================================================
# 3) Azure AI Search / Knowledge grounding
# Purpose:
# - Search service attached as a tool/knowledge source for the Foundry agent
# - Fill only if your Odoo bridge or sync jobs talk to Search directly
# ============================================================================

AZURE_AI_SEARCH_SERVICE_NAME=
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_INDEX_NAME=
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_API_VERSION=2025-03-01-preview

# ============================================================================
# 4) APIM (optional)
# Purpose:
# - Only use if Azure API Management is actually in front of your bridge/service
# - Leave blank if not deployed
# ============================================================================

AZURE_APIM_ENABLED=0
AZURE_APIM_ENDPOINT=
AZURE_APIM_SUBSCRIPTION_KEY=

# ============================================================================
# 5) Claude Code / enterprise network config (optional)
# Purpose:
# - Only use if behind a corporate proxy / custom CA / mTLS
# - For your current setup, leave empty unless required
# ============================================================================

HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=
NODE_EXTRA_CA_CERTS=
CLAUDE_CODE_CLIENT_CERT=
CLAUDE_CODE_CLIENT_KEY=
CLAUDE_CODE_CLIENT_KEY_PASSPHRASE=

# ============================================================================
# 6) Local development / validation helpers
# ============================================================================

ENVIRONMENT=dev
LOG_LEVEL=INFO
