# =============================================================================
# .dockerignore — Keep build context small for ACR builds
# Only addons/ipai, addons/oca, config/, docker/, and requirements are needed.
# =============================================================================

# Exclude everything by default
*

# Include only what Dockerfile.unified needs
!addons/ipai/
!addons/oca/
!config/
!docker/
!requirements*.txt
!.devcontainer/

# Exclude pycache inside included dirs
**/__pycache__
**/*.pyc
**/*.pyo
