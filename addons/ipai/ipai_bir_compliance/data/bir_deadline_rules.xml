<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 0619E: 10th of next month, first two months of quarter only -->
        <record id="rule_0619e" model="l10n.ph.bir.deadline.rule">
            <field name="form_id" ref="bir_form_0619e"/>
            <field name="rule_code">M10_NEXT_MONTH_FIRST_TWO_MONTHS_ONLY</field>
            <field name="rule_kind">relative_monthly</field>
            <field name="month_offset">1</field>
            <field name="day_of_month">10</field>
            <field name="deadline_source">form_instruction</field>
            <field name="notes">Applies to first two months of each calendar quarter only. Third month covered by 1601EQ.</field>
        </record>

        <!-- 1601EQ: last day of month following quarter end -->
        <record id="rule_1601eq" model="l10n.ph.bir.deadline.rule">
            <field name="form_id" ref="bir_form_1601eq"/>
            <field name="rule_code">Q_LAST_DAY_NEXT_MONTH</field>
            <field name="rule_kind">relative_quarterly</field>
            <field name="month_offset">1</field>
            <field name="day_of_month">31</field>
            <field name="deadline_source">form_instruction</field>
            <field name="notes">eFPS deadline follows applicable revenue issuances — keep override path.</field>
        </record>

        <!-- 1601C: 10th of next month, with December exception -->
        <record id="rule_1601c" model="l10n.ph.bir.deadline.rule">
            <field name="form_id" ref="bir_form_1601c"/>
            <field name="rule_code">M10_NEXT_MONTH_WITH_DECEMBER_EXCEPTION</field>
            <field name="rule_kind">relative_monthly</field>
            <field name="month_offset">1</field>
            <field name="day_of_month">10</field>
            <field name="special_case_json">{"12": {"month": 1, "day": 25, "next_year": true}}</field>
            <field name="deadline_source">form_instruction</field>
            <field name="notes">December exception: BIR shows conflicting pages (Jan 15 vs Jan 25). Seeded as Jan 25 per majority of sources. Use interactive_tax_calendar override to adjust.</field>
        </record>

        <!-- 1604C: January 31 of following year -->
        <record id="rule_1604c" model="l10n.ph.bir.deadline.rule">
            <field name="form_id" ref="bir_form_1604c"/>
            <field name="rule_code">Y_JAN_31</field>
            <field name="rule_kind">fixed_annual</field>
            <field name="fixed_month">1</field>
            <field name="fixed_day">31</field>
            <field name="deadline_source">form_instruction</field>
        </record>

        <!-- 1604E: March 1 of following year -->
        <record id="rule_1604e" model="l10n.ph.bir.deadline.rule">
            <field name="form_id" ref="bir_form_1604e"/>
            <field name="rule_code">Y_MAR_01</field>
            <field name="rule_kind">fixed_annual</field>
            <field name="fixed_month">3</field>
            <field name="fixed_day">1</field>
            <field name="deadline_source">form_instruction</field>
        </record>

        <!-- 2550Q: 25th day following close of quarter -->
        <record id="rule_2550q" model="l10n.ph.bir.deadline.rule">
            <field name="form_id" ref="bir_form_2550q"/>
            <field name="rule_code">Q25_NEXT_MONTH_AFTER_QUARTER</field>
            <field name="rule_kind">relative_quarterly</field>
            <field name="month_offset">1</field>
            <field name="day_of_month">25</field>
            <field name="deadline_source">form_instruction</field>
        </record>

        <!-- 1701Q: fixed dates Apr 15, Aug 15, Nov 15 -->
        <record id="rule_1701q" model="l10n.ph.bir.deadline.rule">
            <field name="form_id" ref="bir_form_1701q"/>
            <field name="rule_code">Q_FIXED_APR_AUG_NOV_15</field>
            <field name="rule_kind">fixed_quarterly</field>
            <field name="fixed_day">15</field>
            <field name="special_case_json">{"1": {"month": 4, "day": 15}, "2": {"month": 8, "day": 15}, "3": {"month": 11, "day": 15}}</field>
            <field name="deadline_source">form_instruction</field>
            <field name="notes">Q1->Apr 15, Q2->Aug 15, Q3->Nov 15. Q4 is covered by annual 1701.</field>
        </record>

        <!-- 1701: April 15 of following year -->
        <record id="rule_1701" model="l10n.ph.bir.deadline.rule">
            <field name="form_id" ref="bir_form_1701"/>
            <field name="rule_code">Y_APR_15</field>
            <field name="rule_kind">fixed_annual</field>
            <field name="fixed_month">4</field>
            <field name="fixed_day">15</field>
            <field name="deadline_source">form_instruction</field>
            <field name="notes">If tax due exceeds PHP 2,000, second installment due Jul 15.</field>
        </record>

        <!-- 1701 installment 2 (optional) -->
        <record id="rule_1701_installment2" model="l10n.ph.bir.deadline.rule">
            <field name="form_id" ref="bir_form_1701"/>
            <field name="rule_code">INSTALLMENT_2_JUL_15</field>
            <field name="rule_kind">fixed_annual</field>
            <field name="fixed_month">7</field>
            <field name="fixed_day">15</field>
            <field name="deadline_source">form_instruction</field>
            <field name="notes">Second installment when tax due exceeds PHP 2,000.</field>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
