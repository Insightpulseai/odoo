      ],
      "expected_output": {
        "status": "draft",
        "move_type": "out_refund",
        "amount": 8500
      },
      "pass_criteria": {
        "must_contain": ["credit note", "8,500", "return"],
        "must_not_contain": ["debit note"],
        "behavior": "action"
      },
      "idempotent": false
    },
    {
      "id": "wf-010",
      "category": "invoice_lifecycle",
      "query": "Reconcile payment PAY-2026-0055 with invoice INV-2026-0055 and close the receivable.",
      "context": {
        "company_id": "ipai-main",
        "user_role": "account.group_account_invoice",
        "active_model": "account.move.line",
        "active_record_id": null
      },
      "expected_actions": [
        "account.move.line.search([('move_id.name', 'in', ['PAY-2026-0055', 'INV-2026-0055']), ('account_id.reconcile', '=', True)])",
        "account.move.line.reconcile()"
      ],
      "expected_output": {
        "status": "reconciled",
        "residual": 0
      },
      "pass_criteria": {
        "must_contain": ["reconcile", "PAY-2026-0055", "INV-2026-0055"],
        "must_not_contain": ["partial", "unreconciled"],
        "behavior": "action"
      },
      "idempotent": true
    },
