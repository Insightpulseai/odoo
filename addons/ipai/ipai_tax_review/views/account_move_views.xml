<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Add smart button to account.move form -->
    <record id="view_move_form_tax_review" model="ir.ui.view">
        <field name="name">account.move.form.tax.review</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_tax_reviews"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-check-circle"
                        invisible="tax_review_count == 0">
                    <field name="tax_review_count" widget="statinfo"
                           string="Tax Reviews"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
