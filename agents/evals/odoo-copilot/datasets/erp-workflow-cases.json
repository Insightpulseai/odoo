  "cases": [
    {
      "id": "wf-001",
      "category": "finance_close",
      "query": "Close the accounting period for March 2026 and lock it from further entries.",
      "context": {
        "company_id": "ipai-main",
        "user_role": "account.group_account_manager",
        "active_model": "account.move",
        "active_record_id": null
      },
      "expected_actions": [
        "account.period.close",
        "res.company.write({period_lock_date: '2026-03-31'})"
      ],
      "expected_output": {
        "status": "period_locked",
        "lock_date": "2026-03-31"
      },
      "pass_criteria": {
        "must_contain": ["lock", "March", "2026-03-31"],
        "must_not_contain": ["deleted", "reversed"],
        "behavior": "action"
      },
      "idempotent": true
    },
    {
