<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ipai_ai_proposal_view_list" model="ir.ui.view">
        <field name="name">ipai.ai.proposal.list</field>
        <field name="model">ipai.ai.proposal</field>
        <field name="arch" type="xml">
            <list decoration-warning="state == 'pending'"
                  decoration-success="state in ('approved', 'edited')"
                  decoration-danger="state == 'rejected'">
                <field name="create_date"/>
                <field name="job_id"/>
                <field name="proposal_type"/>
                <field name="target_model"/>
                <field name="proposed_summary" optional="show"/>
                <field name="confidence" widget="progressbar"/>
                <field name="state" widget="badge"/>
                <field name="reviewer_id" widget="many2one_avatar_user"/>
                <field name="reviewed_at"/>
            </list>
        </field>
    </record>

    <record id="ipai_ai_proposal_view_form" model="ir.ui.view">
        <field name="name">ipai.ai.proposal.form</field>
        <field name="model">ipai.ai.proposal</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Approve" type="object"
                            invisible="state != 'pending'" class="btn-primary"
                            groups="ipai_copilot_actions.group_ai_job_reviewer"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state != 'pending'" class="btn-danger"
                            groups="ipai_copilot_actions.group_ai_job_reviewer"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,approved"/>
                </header>
                <sheet>
                    <group>
                        <group string="Proposal">
                            <field name="job_id"/>
                            <field name="correlation_id"/>
                            <field name="proposal_type"/>
                            <field name="confidence" widget="progressbar"/>
                        </group>
                        <group string="Target">
                            <field name="target_model"/>
                            <field name="target_record_id"/>
                            <field name="target_record_name"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Proposed Data" name="proposed">
                            <field name="proposed_summary"/>
                            <field name="proposed_values" widget="json"/>
                        </page>
                        <page string="Finance Fields" name="finance"
                              invisible="proposal_type != 'draft_entry'">
                            <group>
                                <group>
                                    <field name="vendor_name"/>
                                    <field name="suggested_partner_id"/>
                                    <field name="invoice_number"/>
                                    <field name="invoice_date"/>
                                </group>
                                <group>
                                    <field name="total_amount"/>
                                    <field name="tax_amount"/>
                                    <field name="currency_code"/>
                                    <field name="account_code"/>
                                </group>
                            </group>
                        </page>
                        <page string="Review" name="review">
                            <group>
                                <field name="reviewer_id"/>
                                <field name="reviewed_at"/>
                                <field name="review_notes"/>
                            </group>
                            <group string="Result" invisible="not created_record_id">
                                <field name="created_record_model"/>
                                <field name="created_record_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="ipai_ai_proposal_action" model="ir.actions.act_window">
        <field name="name">AI Proposals</field>
        <field name="res_model">ipai.ai.proposal</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
