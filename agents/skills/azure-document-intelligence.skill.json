{
  "id": "azure.document_intelligence.analyze",
  "version": 1,
  "description": "Extract structured data from documents (PDFs, images, scans) using Azure Document Intelligence prebuilt and custom models. Supports invoices, receipts, tax forms, ID documents, contracts, bank statements, and layout analysis.",
  "maturity": "L1",
  "inputs": {
    "model_id": {
      "type": "string",
      "description": "Document Intelligence model ID (e.g., prebuilt-invoice, prebuilt-receipt, prebuilt-layout, or custom model ID)",
      "required": true
    },
    "document_source": {
      "type": "string",
      "description": "Path to document file, URL, or base64-encoded content",
      "required": true
    },
    "source_type": {
      "type": "string",
      "description": "How the document is provided",
      "enum": ["file_path", "url", "base64", "blob_container"],
      "default": "file_path",
      "required": false
    },
    "features": {
      "type": "array",
      "description": "Add-on features to enable (formulas, styleFont, barcodes, languages, queryFields)",
      "required": false
    },
    "query_fields": {
      "type": "array",
      "description": "Custom fields to extract via LLM query (requires queryFields feature)",
      "required": false
    },
    "output_format": {
      "type": "string",
      "description": "Output content format",
      "enum": ["json", "markdown", "pdf"],
      "default": "json",
      "required": false
    },
    "pages": {
      "type": "string",
      "description": "Page range to analyze (e.g., '1-3', '1,3,5')",
      "required": false
    }
  },
  "requires": {
    "secrets": [
      "AZURE_DI_ENDPOINT",
      "AZURE_DI_KEY"
    ],
    "ssot_files": [
      "ssot/odoo/odoo_finance_entities.yaml",
      "ssot/odoo/odoo_expense_entities.yaml"
    ],
    "tools": [
      "azure-cli",
      "python3",
      "pip:azure-ai-documentintelligence"
    ]
  },
  "outputs": {
    "artifacts": [
      "docs/evidence/<stamp>/document-intelligence/*.json",
      "ssot/odoo/document_intelligence_entities.yaml"
    ],
    "evidence": "docs/evidence/<stamp>/document-intelligence/"
  },
  "policies": {
    "no_plaintext_secrets": true,
    "must_pass_ci": [
      "scripts/ci/validate_yaml.sh"
    ],
    "idempotent": true,
    "rollback_supported": false
  },
  "verification": {
    "checks": [
      {
        "name": "DI endpoint reachable",
        "type": "http_get",
        "target": "${AZURE_DI_ENDPOINT}/documentintelligence/info?api-version=2024-11-30",
        "expected": "HTTP 200"
      },
      {
        "name": "Entity contract valid YAML",
        "type": "yaml_valid",
        "target": "ssot/odoo/document_intelligence_entities.yaml",
        "expected": "valid"
      },
      {
        "name": "Evidence artifacts exist",
        "type": "file_exists",
        "target": "docs/evidence/*/document-intelligence/*.json",
        "expected": "at least 1 file"
      }
    ]
  }
}
