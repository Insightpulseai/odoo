<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Skill Execution Form View -->
    <record id="view_skill_execution_form" model="ir.ui.view">
        <field name="name">ipai.skill.execution.form</field>
        <field name="model">ipai.skill.execution</field>
        <field name="arch" type="xml">
            <form string="Skill Execution">
                <header>
                    <button name="action_start" type="object" string="Start"
                            invisible="state != 'queued'" class="oe_highlight"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state not in ('queued', 'running')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="queued,running,completed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="skill_id"/>
                            <field name="user_id"/>
                            <field name="duration_seconds"/>
                        </group>
                        <group>
                            <field name="started_at"/>
                            <field name="completed_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Input" name="input">
                            <field name="input_data" widget="text"/>
                        </page>
                        <page string="Output" name="output">
                            <field name="output_data" widget="text"/>
                        </page>
                        <page string="Tool Log" name="tool_log">
                            <field name="tool_log" widget="text"/>
                        </page>
                        <page string="Error" name="error"
                               invisible="state != 'failed'">
                            <field name="error_message" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Skill Execution List View -->
    <record id="view_skill_execution_list" model="ir.ui.view">
        <field name="name">ipai.skill.execution.list</field>
        <field name="model">ipai.skill.execution</field>
        <field name="arch" type="xml">
            <list string="Skill Executions" decoration-danger="state == 'failed'"
                  decoration-success="state == 'completed'"
                  decoration-info="state == 'running'">
                <field name="create_date"/>
                <field name="skill_id"/>
                <field name="user_id"/>
                <field name="state"/>
                <field name="duration_seconds"/>
            </list>
        </field>
    </record>

    <!-- Skill Execution Search View -->
    <record id="view_skill_execution_search" model="ir.ui.view">
        <field name="name">ipai.skill.execution.search</field>
        <field name="model">ipai.skill.execution</field>
        <field name="arch" type="xml">
            <search string="Search Executions">
                <field name="skill_id"/>
                <field name="user_id"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Failed" name="failed" domain="[('state', '=', 'failed')]"/>
                <filter string="Running" name="running" domain="[('state', '=', 'running')]"/>
                <group expand="0" string="Group By">
                    <filter string="Skill" name="group_skill" context="{'group_by': 'skill_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem
        id="menu_executions"
        name="Executions"
        parent="menu_agent_skills_root"
        sequence="20"
        action="action_skill_execution"/>

    <!-- Action -->
    <record id="action_skill_execution" model="ir.actions.act_window">
        <field name="name">Skill Executions</field>
        <field name="res_model">ipai.skill.execution</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_skill': 1}</field>
    </record>
</odoo>
