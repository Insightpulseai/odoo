{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ssot.plane.clarity_ppm.v1",
  "title": "Plane Clarity PPM Contract v1",
  "type": "object",
  "required": ["schema", "version", "contract", "investment_model", "governance"],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "const": "ssot.plane.clarity_ppm.v1"},
    "version": {"type": "integer", "minimum": 1},
    "updated": {"type": "string"},
    "contract": {
      "type": "object",
      "required": ["name", "workspace_slug", "project_ref", "taxonomy_refs"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "workspace_slug": {"type": "string", "minLength": 1},
        "project_ref": {"type": "string", "minLength": 1},
        "taxonomy_refs": {
          "type": "object",
          "required": ["labels", "modules", "states", "estimates", "cycles"],
          "additionalProperties": false,
          "properties": {
            "labels": {"type": "string"},
            "modules": {"type": "string"},
            "states": {"type": "string"},
            "estimates": {"type": "string"},
            "cycles": {"type": "string"}
          }
        }
      }
    },
    "investment_model": {
      "type": "object",
      "required": ["id_prefix", "required_fields", "investment_types"],
      "additionalProperties": false,
      "properties": {
        "id_prefix": {"type": "string", "minLength": 1},
        "required_fields": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "investment_types": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "governance": {
      "type": "object",
      "required": [
        "required_label_prefixes",
        "module_prefix_pattern",
        "cycle_naming_pattern",
        "required_states"
      ],
      "additionalProperties": false,
      "properties": {
        "required_label_prefixes": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "module_prefix_pattern": {"type": "string", "minLength": 1},
        "cycle_naming_pattern": {"type": "string", "minLength": 1},
        "required_states": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    }
  }
}
