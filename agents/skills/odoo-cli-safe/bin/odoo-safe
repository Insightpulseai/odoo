#!/usr/bin/env bash
# Odoo CLI safe wrapper
# Enforces --stop-after-init for install/update and blocks interactive shell
set -euo pipefail

# --- Binary check ---
if ! command -v odoo >/dev/null 2>&1; then
  echo "error: odoo not installed or not on PATH" >&2
  echo "hint: this wrapper is designed to run inside an Odoo container" >&2
  exit 127
fi

# --- Build command string ---
CMD_STRING="$*"

# --- Block interactive shell ---
case "$CMD_STRING" in
  *" shell"*|*" shell")
    echo "error: interactive shell blocked by odoo-safe wrapper" >&2
    echo "hint: use 'odoo -d <db> -i <module> --stop-after-init' instead" >&2
    exit 2
    ;;
esac

# --- Require --stop-after-init for install/update ---
if [[ "$CMD_STRING" == *"-i "* ]] || [[ "$CMD_STRING" == *"-u "* ]] || \
   [[ "$CMD_STRING" == *"--init "* ]] || [[ "$CMD_STRING" == *"--update "* ]]; then
  if [[ "$CMD_STRING" != *"--stop-after-init"* ]]; then
    echo "error: install/update operations require --stop-after-init" >&2
    echo "hint: add '--stop-after-init --no-http' to your command" >&2
    exit 2
  fi
fi

# --- Warn on prod database usage ---
if [[ "${ODOO_SAFE_ALLOW_PROD:-0}" != "1" ]]; then
  case "$CMD_STRING" in
    *"-d odoo "*|*"-d odoo"|*"--database odoo "*|*"--database odoo")
      # Allow if it's a test or install context, warn otherwise
      if [[ "$CMD_STRING" != *"--stop-after-init"* ]]; then
        echo "error: prod database 'odoo' access blocked without --stop-after-init" >&2
        echo "hint: set ODOO_SAFE_ALLOW_PROD=1 if intentional" >&2
        exit 2
      fi
      ;;
  esac
fi

# --- Pass through ---
exec odoo "$@"
