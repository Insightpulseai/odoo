<odoo>

    <!--
        InsightPulse Branded Login Shell
        Wraps native Odoo login in a split-panel layout.
        Left: branded trust panel. Right: native Odoo login form.
        All auth behavior (form, OAuth, passkey) stays native.
    -->

    <template id="ipai_login_shell" inherit_id="web.login_layout" name="IPAI Login Shell">

        <!-- Wrap the entire login card in our split layout -->
        <xpath expr="//div[hasclass('o_database_list')]" position="before">
            <div class="ipai-login-left d-none d-lg-flex">
                <div class="ipai-brand">
                    <img src="/ipai_web_branding/static/src/img/logo_white.png"
                         alt="InsightPulse"
                         class="ipai-brand-logo"/>
                </div>
                <div class="ipai-hero">
                    <h1 class="ipai-hero-title">Welcome to your smarter financial workspace</h1>
                    <p class="ipai-hero-sub">Secure. Simple. Built for modern business.</p>
                </div>
                <ul class="ipai-features">
                    <li class="ipai-feature">
                        <div class="ipai-feature-icon">&#x1F6E1;</div>
                        <div><strong>Bank-grade Security</strong><br/><span>Enterprise encryption and multi-factor authentication.</span></div>
                    </li>
                    <li class="ipai-feature">
                        <div class="ipai-feature-icon">&#x26A1;</div>
                        <div><strong>Lightning Fast</strong><br/><span>Real-time insights and instant transaction processing.</span></div>
                    </li>
                    <li class="ipai-feature">
                        <div class="ipai-feature-icon">&#x1F4CA;</div>
                        <div><strong>Smart Analytics</strong><br/><span>AI-powered financial insights to drive better decisions.</span></div>
                    </li>
                    <li class="ipai-feature">
                        <div class="ipai-feature-icon">&#x2705;</div>
                        <div><strong>Compliance Ready</strong><br/><span>Built-in regulatory compliance for peace of mind.</span></div>
                    </li>
                </ul>
                <p class="ipai-trust">Trusted by 10,000+ businesses worldwide</p>
            </div>
        </xpath>

        <!-- Add class hook to the login card for styling -->
        <xpath expr="//div[hasclass('o_database_list')]" position="attributes">
            <attribute name="class" add="ipai-login-card" separator=" "/>
        </xpath>

        <!-- Replace footer -->
        <xpath expr="//div[hasclass('text-center','small','mt-4')]" position="replace">
            <div class="text-center small mt-4 pt-3" t-if="not disable_footer">
                <div class="ipai-support">
                    Need help?
                    <a href="mailto:support@insightpulseai.com">Contact Support</a>
                </div>
                <p class="ipai-legal">
                    By signing in, you agree to our
                    <a href="/terms" target="_blank">Terms of Service</a>
                    and <a href="/privacy" target="_blank">Privacy Policy</a>
                </p>
            </div>
        </xpath>

    </template>

</odoo>
