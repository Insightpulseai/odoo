<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Cash Advance Tree View -->
    <record id="view_cash_advance_tree" model="ir.ui.view">
        <field name="name">cash.advance.tree</field>
        <field name="model">cash.advance</field>
        <field name="arch" type="xml">
            <list string="Cash Advance Requests"
                  decoration-info="state=='draft'"
                  decoration-warning="state in ('submitted','dept_approved')"
                  decoration-success="state in ('released','for_liquidation','liquidated','closed')"
                  decoration-danger="state in ('rejected','cancelled')"
                  decoration-bf="is_overdue">
                <field name="name"/>
                <field name="date_needed"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="branch_id" optional="show"/>
                <field name="payee_name" optional="hide"/>
                <field name="payment_method"/>
                <field name="total_amount" sum="Total"/>
                <field name="liquidation_due_date" optional="show"/>
                <field name="is_overdue" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state=='draft'"
                       decoration-warning="state in ('submitted','dept_approved')"
                       decoration-success="state in ('finance_approved','released','for_liquidation','liquidated','closed')"
                       decoration-danger="state in ('rejected','cancelled')"/>
            </list>
        </field>
    </record>

    <!-- Cash Advance Form View -->
    <record id="view_cash_advance_form" model="ir.ui.view">
        <field name="name">cash.advance.form</field>
        <field name="model">cash.advance</field>
        <field name="arch" type="xml">
            <form string="Cash Advance Request">
                <header>
                    <!-- Draft actions -->
                    <button name="action_submit" string="Submit" type="object"
                            states="draft" class="btn-primary"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            states="draft" class="btn-secondary"/>

                    <!-- Department approval -->
                    <button name="action_dept_approve" string="Department Approve" type="object"
                            states="submitted" class="btn-primary"
                            groups="hr.group_hr_manager"/>
                    <button name="action_reject" string="Reject" type="object"
                            states="submitted" class="btn-danger"
                            groups="hr.group_hr_manager"/>

                    <!-- Finance approval -->
                    <button name="action_finance_approve" string="Finance Approve" type="object"
                            states="dept_approved" class="btn-primary"
                            groups="account.group_account_manager"/>
                    <button name="action_reject" string="Reject" type="object"
                            states="dept_approved" class="btn-danger"
                            groups="account.group_account_manager"/>

                    <!-- Release -->
                    <button name="action_release" string="Release Funds" type="object"
                            states="finance_approved" class="btn-primary"
                            groups="account.group_account_manager"/>

                    <!-- Start Liquidation -->
                    <button name="action_start_liquidation" string="Start Liquidation" type="object"
                            states="released" class="btn-primary"/>

                    <!-- Mark Liquidated -->
                    <button name="action_mark_liquidated" string="Mark Liquidated" type="object"
                            states="for_liquidation" class="btn-primary"
                            groups="account.group_account_user"/>

                    <!-- Close -->
                    <button name="action_close" string="Close" type="object"
                            states="liquidated" class="btn-primary"
                            groups="account.group_account_manager"/>

                    <!-- Cancel from submitted -->
                    <button name="action_cancel" string="Cancel" type="object"
                            states="submitted" class="btn-secondary"/>

                    <!-- Reset to draft -->
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                            attrs="{'invisible': [('state', 'not in', ('rejected', 'cancelled'))]}"
                            class="btn-secondary"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,dept_approved,finance_approved,released,for_liquidation,liquidated,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_liquidation" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                attrs="{'invisible': [('liquidation_id', '=', False)]}">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Liquidation</span>
                            </div>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Overdue"
                            attrs="{'invisible': [('is_overdue', '=', False)]}"
                            bg_color="bg-danger"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group name="employee_info">
                            <field name="employee_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="department_id"/>
                            <field name="payee_name"/>
                            <field name="branch_id"/>
                        </group>
                        <group name="request_info">
                            <field name="date_needed"/>
                            <field name="payment_method" widget="radio"/>
                            <field name="currency_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <group name="travel" string="Travel/Event Details">
                        <group>
                            <field name="travel_event_date_from"/>
                            <field name="travel_event_date_to"/>
                        </group>
                        <group>
                            <field name="liquidation_due_date" readonly="1"/>
                            <field name="is_overdue" readonly="1"/>
                        </group>
                    </group>

                    <group name="client_section" string="Client Information"
                           attrs="{'invisible': [('is_client_related', '=', False)]}">
                        <group>
                            <field name="client_name"/>
                            <field name="ce_number"/>
                        </group>
                    </group>
                    <group>
                        <field name="is_client_related"/>
                    </group>

                    <group name="purpose_description">
                        <field name="description" placeholder="Purpose of cash advance..."/>
                    </group>

                    <notebook>
                        <page string="Purpose / Breakdown" name="purpose_lines">
                            <field name="purpose_line_ids">
                                <list string="Purpose Lines" editable="bottom">
                                    <field name="purpose"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_amount" widget="monetary" readonly="1"
                                       class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Approval Info" name="approval_info">
                            <group>
                                <group string="Department Approval">
                                    <field name="approver_id" readonly="1"/>
                                    <field name="approval_date" readonly="1"/>
                                </group>
                                <group string="Finance Approval">
                                    <field name="finance_approver_id" readonly="1"/>
                                    <field name="finance_approval_date" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Liquidation" name="liquidation_info"
                              attrs="{'invisible': [('liquidation_id', '=', False)]}">
                            <group>
                                <group>
                                    <field name="liquidation_id" readonly="1"/>
                                    <field name="liquidation_due_date" readonly="1"/>
                                    <field name="calendar_event_id" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Cash Advance Search View -->
    <record id="view_cash_advance_search" model="ir.ui.view">
        <field name="name">cash.advance.search</field>
        <field name="model">cash.advance</field>
        <field name="arch" type="xml">
            <search string="Cash Advance Requests">
                <field name="name" string="Reference"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="branch_id"/>
                <field name="payee_name"/>
                <filter string="My Requests" name="my_requests" domain="[('employee_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Dept. Approved" name="dept_approved" domain="[('state', '=', 'dept_approved')]"/>
                <filter string="Finance Approved" name="finance_approved" domain="[('state', '=', 'finance_approved')]"/>
                <filter string="Released" name="released" domain="[('state', '=', 'released')]"/>
                <filter string="For Liquidation" name="for_liquidation" domain="[('state', '=', 'for_liquidation')]"/>
                <filter string="Liquidated" name="liquidated" domain="[('state', '=', 'liquidated')]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter string="Pending Approval" name="pending_approval"
                        domain="[('state', 'in', ('submitted', 'dept_approved'))]"/>
                <filter string="Overdue" name="overdue" domain="[('is_overdue', '=', True)]"/>
                <separator/>
                <filter string="Client Related" name="client_related" domain="[('is_client_related', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Branch" name="group_branch" context="{'group_by': 'branch_id'}"/>
                    <filter string="Payment Method" name="group_payment" context="{'group_by': 'payment_method'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'state'}"/>
                    <filter string="Date Needed" name="group_date" context="{'group_by': 'date_needed:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_cash_advance" model="ir.actions.act_window">
        <field name="name">Cash Advance Requests</field>
        <field name="res_model">cash.advance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cash_advance_search"/>
        <field name="context">{'search_default_my_requests': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first cash advance request
            </p>
            <p>
                Request cash advances for travel, events, or other business needs.
                After release, submit a liquidation report with itemized expenses.
            </p>
        </field>
    </record>

    <record id="action_cash_advance_my" model="ir.actions.act_window">
        <field name="name">My Cash Advances</field>
        <field name="res_model">cash.advance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cash_advance_search"/>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
    </record>

    <record id="action_cash_advance_to_approve" model="ir.actions.act_window">
        <field name="name">CA To Approve</field>
        <field name="res_model">cash.advance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cash_advance_search"/>
        <field name="domain">[('state', 'in', ('submitted', 'dept_approved'))]</field>
        <field name="context">{'search_default_pending_approval': 1}</field>
    </record>

    <record id="action_cash_advance_overdue" model="ir.actions.act_window">
        <field name="name">Overdue Cash Advances</field>
        <field name="res_model">cash.advance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cash_advance_search"/>
        <field name="domain">[('is_overdue', '=', True)]</field>
    </record>

</odoo>
