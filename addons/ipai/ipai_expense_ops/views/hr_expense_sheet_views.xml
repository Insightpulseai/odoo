<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend expense sheet form with exception panel -->
    <record id="hr_expense_sheet_form_inherit_ops" model="ir.ui.view">
        <field name="name">hr.expense.sheet.form.inherit.ops</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_sheet_form"/>
        <field name="arch" type="xml">

            <!-- Add exception stat button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" icon="fa-exclamation-triangle"
                        name="%(ipai_expense_ops.action_expense_exception)d"
                        type="action"
                        context="{'search_default_sheet_id': active_id}">
                    <field name="exception_count" widget="statinfo" string="Exceptions"/>
                </button>
            </xpath>

            <!-- Add blocking exception warning banner -->
            <xpath expr="//header" position="after">
                <div class="alert alert-danger" role="alert"
                     invisible="blocking_exception_count == 0">
                    <strong>Blocking exceptions:</strong>
                    <field name="blocking_exception_count" readonly="1"/> unresolved exception(s)
                    must be resolved before this report can be approved.
                </div>
            </xpath>

        </field>
    </record>

</odoo>
