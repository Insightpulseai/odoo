<odoo>

    <!-- Override login layout: replace "Powered by Odoo" footer with IPAI branding -->
    <template id="login_layout_ipai" inherit_id="web.login_layout" name="IPAI Login Layout">

        <!-- Replace default company logo with IPAI branded logo -->
        <xpath expr="//div[hasclass('text-center','pb-3','border-bottom')]" position="replace">
            <div class="text-center pb-3 border-bottom mb-4 o_ipai_login_logo">
                <img src="/ipai_web_branding/static/src/img/ipai_logo.svg"
                     alt="InsightPulse AI"
                     style="max-height:80px; max-width: 100%; width:auto"/>
            </div>
        </xpath>

        <!-- Replace "Powered by Odoo" footer with IPAI footer -->
        <xpath expr="//div[hasclass('text-center','small','mt-4')]" position="replace">
            <div class="text-center small mt-4 pt-3 border-top o_ipai_login_footer" t-if="not disable_footer">
                <t t-if="not disable_database_manager">
                    <a class="border-end pe-2 me-1" href="/web/database/manager">Manage Databases</a>
                </t>
                <span class="text-muted">InsightPulse AI</span>
            </div>
        </xpath>

    </template>

</odoo>
