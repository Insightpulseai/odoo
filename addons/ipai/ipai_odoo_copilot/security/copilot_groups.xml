<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <!-- Copilot User: basic copilot chat access -->
    <record id="group_copilot_user" model="res.groups">
        <field name="name">Copilot User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Access to use the copilot chat interface.</field>
    </record>

    <!-- Copilot Admin: settings + conversation management -->
    <record id="group_copilot_admin" model="res.groups">
        <field name="name">Copilot Administrator</field>
        <field name="implied_ids" eval="[(4, ref('group_copilot_user'))]"/>
        <field name="comment">Full administration of copilot settings, conversations, and gateway config.</field>
    </record>

</odoo>
