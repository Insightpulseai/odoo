<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        AiInlinePanel — inline AI panel rendered below the mail composer.
        Activated via composer action registered in composer_ai_action.js.

        State bindings:
          state.visible    — panel visibility toggle
          state.prompt     — free-form input (t-model)
          state.loading    — disables submit, shows streaming dots
          state.error      — error CODE (resolved via errorMessage getter)
          state.response   — { provider, text, model, trace_id }
          state.copied     — momentary "Copied!" feedback
          state.presets    — preset chip definitions
          state.activePreset — currently selected preset (if any)
          state.threadId   — multi-turn conversation thread ID

        Props:
          props.hasSelection — whether text is selected in the composer
    -->
    <t t-name="ipai_ai_widget.AiInlinePanel" owl="1">
        <div class="o_ai_inline_panel border rounded p-2 mt-2 bg-view" t-if="state.visible">
            <!-- Header with close button -->
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fw-bold small">
                    <i class="fa fa-magic me-1 text-primary"/>Ask AI
                </span>
                <button class="btn btn-sm btn-close" t-on-click="onClose" title="Close"/>
            </div>

            <!-- Preset chips row -->
            <PresetChips
                presets="state.presets"
                onPresetSelected.bind="onPresetSelected"
                hasSelection="props.hasSelection"/>

            <!-- Free-form prompt input -->
            <div class="d-flex gap-2 mt-2">
                <input type="text"
                       class="form-control form-control-sm"
                       placeholder="Ask anything about this record..."
                       t-ref="promptInput"
                       t-model="state.prompt"
                       t-att-disabled="state.loading"
                       t-on-keydown="onInputKeydown"/>
                <button class="btn btn-primary btn-sm"
                        t-att-disabled="state.loading || !state.prompt.trim()"
                        t-on-click="onSubmit">
                    <t t-if="state.loading">
                        <span class="o_ai_streaming_indicator">
                            <span class="dot"/>
                            <span class="dot"/>
                            <span class="dot"/>
                        </span>
                    </t>
                    <t t-else="">
                        <i class="fa fa-paper-plane"/>
                    </t>
                </button>
            </div>

            <!-- Error message -->
            <div t-if="state.error" class="alert alert-danger mt-2 mb-0 py-1 px-2 small">
                <i class="fa fa-exclamation-triangle me-1"/>
                <span t-esc="errorMessage"/>
            </div>

            <!-- Result area -->
            <div t-if="state.response" class="o_ai_result mt-2">
                <div class="o_ai_result_text p-2 rounded" t-esc="state.response.text"/>

                <!-- Provider info -->
                <div class="text-muted mt-1 d-flex justify-content-between" style="font-size: 0.75rem;">
                    <span>
                        <i class="fa fa-server me-1"/>
                        <span t-esc="state.response.provider"/> / <span t-esc="state.response.model"/>
                    </span>
                    <span class="font-monospace" t-esc="state.response.trace_id" style="font-size: 0.65rem;"/>
                </div>

                <!-- Action buttons -->
                <div class="o_ai_action_buttons d-flex gap-1 mt-2">
                    <button class="btn btn-sm btn-primary" t-on-click="onInsert">
                        <i class="fa fa-plus me-1"/>Insert
                    </button>
                    <button t-if="state.activePreset and state.activePreset.requires_selection"
                            class="btn btn-sm btn-outline-primary" t-on-click="onReplace">
                        <i class="fa fa-exchange me-1"/>Replace
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" t-on-click="onCopy">
                        <i class="fa fa-clipboard me-1"/>
                        <t t-if="state.copied">Copied!</t>
                        <t t-else="">Copy</t>
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" t-on-click="onDiscard">
                        <i class="fa fa-times me-1"/>Discard
                    </button>
                </div>
            </div>

            <!-- Multi-turn indicator -->
            <div t-if="state.threadId" class="text-muted mt-1" style="font-size: 0.7rem;">
                <i class="fa fa-comments me-1"/>Multi-turn conversation active
            </div>
        </div>
    </t>

    <!--
        PresetChips — horizontal row of clickable preset pills.
        Chips requiring text selection are disabled when hasSelection is false.

        Props:
          props.presets       — array of { key, label, icon, requires_selection }
          props.hasSelection  — boolean, whether composer has selected text
          props.onPresetSelected — callback(preset)
    -->
    <t t-name="ipai_ai_widget.PresetChips" owl="1">
        <div class="o_ai_preset_chips d-flex gap-1 flex-wrap">
            <t t-foreach="props.presets" t-as="preset" t-key="preset.key">
                <button class="o_ai_preset_chip btn btn-sm rounded-pill"
                        t-att-class="{'btn-outline-primary': !preset.requires_selection || props.hasSelection, 'btn-outline-secondary opacity-50': preset.requires_selection and !props.hasSelection}"
                        t-att-disabled="preset.requires_selection and !props.hasSelection"
                        t-att-title="preset.requires_selection and !props.hasSelection ? 'Select text in composer first' : preset.label"
                        t-on-click="() => this.onSelect(preset)">
                    <i t-att-class="'fa ' + preset.icon + ' me-1'" style="font-size: 0.8rem;"/>
                    <span t-esc="preset.label"/>
                </button>
            </t>
        </div>
    </t>

</templates>
