    "Bash(echo *)",
    "Bash(git fetch*)",
    "Bash(git pull*)",
    "Bash(git checkout*)",
    "Bash(git merge*)",
    "Bash(git rebase*)",
    "Bash(git stash*)",
    "Bash(git remote*)",
    "Bash(git show*)",
    "Bash(git rev-parse*)",
    "Bash(git tag*)",
    "Bash(./scripts/*)"
  ],
  "agentCommands": {
    "plan": ".claude/commands/plan.md",
    "implement": ".claude/commands/implement.md",
    "verify": ".claude/commands/verify.md",
    "ship": ".claude/commands/ship.md",
    "fix-github-issue": ".claude/commands/fix-github-issue.md",
    "speckit.constitution": ".claude/commands/speckit.constitution.md",
