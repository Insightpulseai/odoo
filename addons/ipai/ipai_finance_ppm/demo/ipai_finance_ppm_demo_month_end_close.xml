        <record id="mec_p3_07" model="project.task">
            <field name="name">P3.07 Validate balance sheet account reconciliations</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">7</field>
            <field name="description">Review all balance sheet account reconciliations. Ensure supporting schedules are complete and signed.</field>
        </record>
        <record id="mec_p3_08" model="project.task">
            <field name="name">P3.08 Review related party transaction disclosures</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">8</field>
            <field name="description">Identify and document all related party transactions per PAS 24 requirements.</field>
        </record>
        <record id="mec_p3_09" model="project.task">
            <field name="name">P3.09 Validate segment reporting allocations</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">9</field>
            <field name="description">Verify segment revenue and cost allocations are consistent with management reporting structure.</field>
        </record>
        <record id="mec_p3_10" model="project.task">
            <field name="name">P3.10 Review contingent liabilities and commitments</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">10</field>
