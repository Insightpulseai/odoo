<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Source Tree View -->
    <record id="chat_source_view_list" model="ir.ui.view">
        <field name="name">ipai.chat.source.list</field>
        <field name="model">ipai.chat.source</field>
        <field name="arch" type="xml">
            <list string="Chat Sources" default_order="create_date desc">
                <field name="name"/>
                <field name="session_id"/>
                <field name="source_type"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'indexed'"
                       decoration-warning="status == 'processing'"
                       decoration-danger="status == 'failed'"
                       decoration-muted="status == 'draft'"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="file_size"/>
                <field name="processed_at"/>
                <field name="create_date" string="Uploaded"/>
            </list>
        </field>
    </record>

    <!-- Source Form View -->
    <record id="chat_source_view_form" model="ir.ui.view">
        <field name="name">ipai.chat.source.form</field>
        <field name="model">ipai.chat.source</field>
        <field name="arch" type="xml">
            <form string="Chat Source">
                <header>
                    <button name="action_submit_for_processing"
                            string="Submit for Processing"
                            type="object" class="oe_highlight"
                            invisible="status != 'draft'"/>
                    <button name="action_retry"
                            string="Retry Indexing"
                            type="object" class="oe_highlight"
                            invisible="status != 'failed'"/>
                    <button name="action_deactivate"
                            string="Deactivate"
                            type="object"
                            invisible="not active"/>
                    <button name="action_activate"
                            string="Activate"
                            type="object"
                            invisible="active"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,processing,indexed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Source Details">
                            <field name="session_id"/>
                            <field name="source_type"/>
                            <field name="attachment_id"/>
                            <field name="url" invisible="source_type != 'url'"/>
                            <field name="file_size"/>
                            <field name="checksum"/>
                            <field name="active"/>
                        </group>
                        <group string="Processing">
                            <field name="external_source_id"/>
                            <field name="external_index_id"/>
                            <field name="processed_at"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Error" invisible="not last_error">
                        <field name="last_error" readonly="1" nolabel="1"
                               colspan="2" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Source Action -->
    <record id="chat_source_action" model="ir.actions.act_window">
        <field name="name">Chat Sources</field>
        <field name="res_model">ipai.chat.source</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No sources uploaded yet
            </p>
            <p>Upload sources through chat sessions to enable grounded conversations.</p>
        </field>
    </record>
</odoo>
