{
  "name": "PPM Clarity: Slack Commands",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ppm-clarity/slack/ppm-retry",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-retry",
      "name": "Slack /ppm-retry",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 0],
      "webhookId": "ppm-retry"
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ppm-clarity/slack/ppm-resolve",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-resolve",
      "name": "Slack /ppm-resolve",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 200],
      "webhookId": "ppm-resolve"
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ppm-clarity/slack/ppm-status",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-status",
      "name": "Slack /ppm-status",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 400],
      "webhookId": "ppm-status"
    },
    {
      "parameters": {
        "jsCode": "const eventId = $json.body.text;\n\nif (!eventId) {\n  return [{ json: { error: 'Usage: /ppm-retry <event_id>' } }];\n}\n\nreturn [{ json: { event_id: eventId } }];"
      },
      "id": "parse-retry",
      "name": "Parse Retry Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [250, 0]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT ops.retry_sync_event($1::uuid)",
        "options": {
          "queryParams": "={{ $json.event_id }}"
        }
      },
      "id": "retry-event",
      "name": "Retry Sync Event",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [500, 0],
      "credentials": {
        "postgres": {
          "id": "supabase-ppm",
          "name": "Supabase PPM"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "✅ Retried sync event: {{ $json.event_id }}",
        "options": {}
      },
      "id": "respond-retry",
      "name": "Response Retry",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [750, 0]
    },
    {
      "parameters": {
        "jsCode": "const parts = $json.body.text.split(' ');\nconst linkId = parts[0];\nconst winner = parts[1]; // 'plane', 'odoo', or 'manual'\n\nif (!linkId || !winner) {\n  return [{ json: { error: 'Usage: /ppm-resolve <link_id> [plane|odoo|manual]' } }];\n}\n\nif (!['plane', 'odoo', 'manual'].includes(winner)) {\n  return [{ json: { error: 'Winner must be: plane, odoo, or manual' } }];\n}\n\nreturn [{ json: { link_id: parseInt(linkId), winner: winner } }];"
      },
      "id": "parse-resolve",
      "name": "Parse Resolve Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [250, 200]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT ops.resolve_conflict($1::integer, $2::text)",
        "options": {
          "queryParams": "={{ JSON.stringify([$json.link_id, $json.winner]) }}"
        }
      },
      "id": "resolve-conflict-manual",
      "name": "Resolve Conflict",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [500, 200],
      "credentials": {
        "postgres": {
          "id": "supabase-ppm",
          "name": "Supabase PPM"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "✅ Resolved conflict for link {{ $json.link_id }}: winner={{ $json.winner }}",
        "options": {}
      },
      "id": "respond-resolve",
      "name": "Response Resolve",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [750, 200]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COUNT(*) as total_links, SUM(CASE WHEN sync_status = 'healthy' THEN 1 ELSE 0 END) as healthy, SUM(CASE WHEN sync_status = 'conflict' THEN 1 ELSE 0 END) as conflicts, SUM(CASE WHEN sync_status = 'error' THEN 1 ELSE 0 END) as errors FROM ops.work_item_links",
        "options": {}
      },
      "id": "get-status",
      "name": "Get System Status",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [250, 400],
      "credentials": {
        "postgres": {
          "id": "supabase-ppm",
          "name": "Supabase PPM"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const status = $json;\n\nconst message = `📊 PPM Clarity Status\\n• Total Links: ${status.total_links}\\n• Healthy: ${status.healthy} ✅\\n• Conflicts: ${status.conflicts} ⚠️\\n• Errors: ${status.errors} ❌`;\n\nreturn [{ json: { message: message } }];"
      },
      "id": "format-status",
      "name": "Format Status Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 400]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "={{ $json.message }}",
        "options": {}
      },
      "id": "respond-status",
      "name": "Response Status",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [750, 400]
    }
  ],
