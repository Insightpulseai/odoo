        </record>
        <record id="mec_p3_15" model="project.task">
            <field name="name">P3.15 Review subsequent events through close date</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">15</field>
            <field name="description">Identify events after reporting period that require adjustment or disclosure per PAS 10.</field>
        </record>
        <record id="mec_p3_16" model="project.task">
            <field name="name">P3.16 Prepare management discussion and analysis draft</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">16</field>
            <field name="description">Draft MD&amp;A narrative highlighting key financial performance drivers, risks, and outlook.</field>
        </record>
        <record id="mec_p3_17" model="project.task">
