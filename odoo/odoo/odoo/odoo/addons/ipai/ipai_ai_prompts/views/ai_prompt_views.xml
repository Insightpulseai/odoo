<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_ipai_ai_prompt_tree" model="ir.ui.view">
        <field name="name">ipai.ai.prompt.tree</field>
        <field name="model">ipai.ai.prompt</field>
        <field name="arch" type="xml">
            <tree string="Default Prompts">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="target_context"/>
                <field name="when_users_need_to"/>
                <field name="button_prompt"/>
                <field name="agent_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_ipai_ai_prompt_form" model="ir.ui.view">
        <field name="name">ipai.ai.prompt.form</field>
        <field name="model">ipai.ai.prompt</field>
        <field name="arch" type="xml">
            <form string="Default Prompt">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Prompt Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="target_context"/>
                            <field name="when_users_need_to"
                                   placeholder="e.g. compose or rewrite a message"/>
                            <field name="button_prompt"
                                   placeholder="e.g. Write for me"/>
                        </group>
                        <group>
                            <field name="agent_id"/>
                            <field name="topic_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Instructions">
                        <field name="instructions" nolabel="1"
                               placeholder="Enter the prompt instructions..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ipai_ai_prompt_search" model="ir.ui.view">
        <field name="name">ipai.ai.prompt.search</field>
        <field name="model">ipai.ai.prompt</field>
        <field name="arch" type="xml">
            <search string="Default Prompts">
                <field name="name"/>
                <field name="target_context"/>
                <field name="agent_id"/>
                <filter string="Active" name="active"
                        domain="[('active', '=', True)]"/>
                <separator/>
                <filter string="Archived" name="archived"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Context" name="group_context"
                            context="{'group_by': 'target_context'}"/>
                    <filter string="Agent" name="group_agent"
                            context="{'group_by': 'agent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ipai_ai_prompt" model="ir.actions.act_window">
        <field name="name">Default Prompts</field>
        <field name="res_model">ipai.ai.prompt</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_ipai_ai_prompt_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Default Prompt
            </p>
            <p>
                Default Prompts are reusable AI behaviors tied to contextual
                surfaces such as mail composer, text selection, chatter, and more.
            </p>
        </field>
    </record>

    <!-- Menu: AI Agents > Configuration > Default Prompts -->
    <menuitem id="menu_ipai_ai_prompt"
              name="Default Prompts"
              parent="ipai_ai_agent_builder.menu_ipai_ai_config"
              action="action_ipai_ai_prompt"
              sequence="10"/>

    <!-- Menu: AI Agents > Configuration > Providers (bridges ipai_ai_core) -->
    <menuitem id="menu_ipai_ai_providers_config"
              name="Providers"
              parent="ipai_ai_agent_builder.menu_ipai_ai_config"
              action="ipai_ai_core.action_ipai_ai_provider"
              sequence="20"/>

</odoo>
