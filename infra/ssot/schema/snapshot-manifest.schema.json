{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ipai-ssot-snapshot-manifest/v1",
  "title": "SSOT Snapshot Manifest",
  "description": "Contract for the inventory snapshot manifest tying together GitHub and Vercel snapshots.",
  "type": "object",
  "required": ["generated_at", "generator", "github_org", "summary", "sources"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of snapshot generation"
    },
    "generator": {
      "type": "string",
      "description": "Path to the script that generated this manifest"
    },
    "github_org": {
      "type": "string",
      "description": "GitHub organization name"
    },
    "summary": {
      "type": "object",
      "required": ["repo_count", "active_repos", "archived_repos", "total_workflows"],
      "properties": {
        "repo_count": { "type": "integer", "minimum": 0 },
        "active_repos": { "type": "integer", "minimum": 0 },
        "archived_repos": { "type": "integer", "minimum": 0 },
        "total_workflows": { "type": "integer", "minimum": 0 },
        "total_github_deployments": { "type": "integer", "minimum": 0 },
        "total_environments": { "type": "integer", "minimum": 0 },
        "vercel_project_count": { "type": "integer", "minimum": 0 },
        "vercel_deployment_count": { "type": "integer", "minimum": 0 },
        "vercel_alias_count": { "type": "integer", "minimum": 0 }
      }
    },
    "sources": {
      "type": "object",
      "required": ["github"],
      "properties": {
        "github": {
          "type": "array",
          "items": { "type": "string" }
        },
        "vercel": {
          "type": "array",
          "items": { "type": "string" }
        },
        "databricks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "supabase": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "description": "Map of artifact file paths to descriptions"
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "default_branch": { "type": "string" },
          "visibility": { "enum": ["public", "private", "internal"] },
          "workflows": { "type": "integer", "minimum": 0 },
          "recent_runs": { "type": "integer", "minimum": 0 },
          "deployments": { "type": "integer", "minimum": 0 },
          "environments": { "type": "integer", "minimum": 0 },
          "archived": { "type": "boolean" },
          "updated_at": { "type": "string" }
        }
      }
    },
    "vercel": {
      "type": "object"
    }
  }
}
