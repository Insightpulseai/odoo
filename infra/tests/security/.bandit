# Bandit Security Configuration
# Reference: https://bandit.readthedocs.io/

[bandit]
# Scan targets
targets = addons/ipai

# Exclude paths
exclude_dirs = /tests/,/migrations/,/__pycache__/,/.git/,/node_modules/

# Severity level: low, medium, high
severity = medium

# Confidence level: low, medium, high
confidence = medium

# Test IDs to skip
# B101: assert_used (common in tests)
# B601: paramiko_calls (false positives)
skips = B101,B601

# Output format: json, csv, txt, html
format = json

# Tests to include (empty = all tests)
tests =

# Maximum number of lines to scan per file
# max_lines_per_file = 10000

# Number of context lines to include in output
context_lines = 3
