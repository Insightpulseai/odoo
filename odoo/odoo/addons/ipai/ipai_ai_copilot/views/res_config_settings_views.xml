<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_copilot" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.ipai.copilot</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='general_settings']" position="inside">
                <block title="AI Copilot (IPAI)" name="ipai_ai_copilot_settings">
                    <setting string="Copilot Bridge URL"
                             help="Bridge endpoint for LLM-backed copilot chat. Falls back to widget bridge, then Azure, then provider-direct.">
                        <field name="ipai_copilot_bridge_url" placeholder="https://your-project.supabase.co/functions/v1/copilot-chat"/>
                    </setting>
                    <setting string="Copilot Bridge Token"
                             help="Server-to-server bearer token (never exposed to browser).">
                        <field name="ipai_copilot_bridge_token" password="True" placeholder="(optional)"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
