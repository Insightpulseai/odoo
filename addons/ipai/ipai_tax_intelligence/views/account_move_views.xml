<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- =====================================================
         account.move — Tax Intelligence smart button and action
         ===================================================== -->
    <record id="view_account_move_tax_intelligence" model="ir.ui.view">
        <field name="name">account.move.tax.intelligence</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Smart button in oe_button_box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_tax_exceptions"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-shield"
                    invisible="tax_exception_count == 0">
                    <field name="tax_exception_count" widget="statinfo"
                        string="Tax Exceptions"/>
                </button>
            </xpath>

            <!-- Validate taxes button in header (only on draft) -->
            <xpath expr="//header" position="inside">
                <button name="action_validate_taxes"
                    string="Validate Taxes"
                    type="object"
                    invisible="state != 'draft'"
                    class="btn-secondary"/>
            </xpath>

            <!-- Tax validation state badge in sheet -->
            <xpath expr="//sheet" position="inside">
                <div class="alert alert-warning mb-3"
                    role="alert"
                    invisible="tax_validation_state != 'has_blocking'">
                    <strong>Blocking tax exceptions detected.</strong>
                    This document cannot be posted until all blocking exceptions are resolved or waived.
                    <button name="action_view_tax_exceptions" type="object"
                        class="btn-link p-0 ms-2">
                        View Exceptions
                    </button>
                </div>
                <div class="alert alert-info mb-3"
                    role="alert"
                    invisible="tax_validation_state != 'has_warnings'">
                    <strong>Tax validation warnings.</strong>
                    Review tax exceptions before posting.
                    <button name="action_view_tax_exceptions" type="object"
                        class="btn-link p-0 ms-2">
                        View Exceptions
                    </button>
                </div>
            </xpath>

            <!-- Hidden fields needed for computed fields -->
            <xpath expr="//sheet" position="after">
                <field name="tax_exception_ids" invisible="1"/>
                <field name="tax_validation_state" invisible="1"/>
                <field name="tax_exception_count" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
