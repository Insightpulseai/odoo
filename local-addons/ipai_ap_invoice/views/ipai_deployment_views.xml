<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ipai_deployment_tree" model="ir.ui.view">
        <field name="name">ipai.deployment.status.tree</field>
        <field name="model">ipai.deployment.status</field>
        <field name="arch" type="xml">
            <tree string="Deployment Status" decoration-success="status == 'healthy'" decoration-danger="status == 'failed'">
                <field name="name"/>
                <field name="provider"/>
                <field name="version"/>
                <field name="commit_hash"/>
                <field name="last_success"/>
                <field name="status" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="action_ipai_deployment_status" model="ir.actions.act_window">
        <field name="name">Deployment Status</field>
        <field name="res_model">ipai.deployment.status</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_ipai_deployment_root" name="AI Ops" parent="account.menu_finance_configuration" sequence="100"/>
    <menuitem id="menu_ipai_deployment_status" name="Deployment Status" parent="menu_ipai_deployment_root" action="action_ipai_deployment_status"/>
</odoo>
