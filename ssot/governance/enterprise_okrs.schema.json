{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Enterprise OKR Framework",
  "description": "Schema for ssot/governance/enterprise_okrs.yaml",
  "type": "object",
  "required": [
    "schema_version",
    "strategic_objectives",
    "canonical_okrs",
    "kpi_index"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "last_updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "strategic_objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "key_results"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "key_results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kr"],
              "additionalProperties": true,
              "properties": {
                "kr": { "type": "string" },
                "kpi_ref": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "canonical_okrs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "key_results"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "parent_objectives": {
            "type": "array",
            "items": { "type": "string" }
          },
          "key_results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kr"],
              "additionalProperties": true,
              "properties": {
                "kr": { "type": "string" },
                "kpi_ref": { "type": "string" },
                "measurement": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "kpi_index": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
