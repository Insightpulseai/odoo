{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Odoo n8n Supabase Integration SSOT",
  "type": "object",
  "required": ["version", "updated_at", "flows"],
  "properties": {
    "version": { "type": "string" },
    "updated_at": { "type": "string" },
    "flows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "source_system",
          "target_system",
          "direction",
          "engine_type",
          "trigger_type",
          "data_owner",
          "execution_owner",
          "state",
          "criticality",
          "evidence_ref"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "source_system": { "type": "string" },
          "target_system": { "type": "string" },
          "direction": {
            "type": "string",
            "enum": [
              "odoo_to_supabase",
              "supabase_to_odoo",
              "bidirectional",
              "external_to_supabase",
              "external_to_odoo",
              "other"
            ]
          },
          "engine_type": {
            "type": "string",
            "enum": ["n8n", "supabase_etl", "direct"]
          },
          "trigger_type": {
            "type": "string",
            "enum": [
              "webhook",
              "schedule",
              "event",
              "manual",
              "rpc",
              "db_poll",
              "other"
            ]
          },
          "data_owner": { "type": "string" },
          "execution_owner": { "type": "string" },
          "state": {
            "type": "string",
            "enum": ["planned", "active", "deprecated", "disabled", "unknown"]
          },
          "criticality": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "evidence_ref": { "type": "string" },
          "exception_reason": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
