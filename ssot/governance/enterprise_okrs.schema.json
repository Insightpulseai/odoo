{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Enterprise OKR Framework",
  "description": "Schema for ssot/governance/enterprise_okrs.yaml — v2.0 with SMART targets",
  "type": "object",
  "required": [
    "schema_version",
    "strategic_objectives",
    "canonical_okrs",
    "smart_targets",
    "kpi_index"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "last_updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "strategic_objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "key_results"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "key_results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kr"],
              "additionalProperties": true,
              "properties": {
                "kr": { "type": "string" },
                "kpi_ref": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "canonical_okrs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "key_results"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "parent_objectives": {
            "type": "array",
            "items": { "type": "string" }
          },
          "key_results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kr"],
              "additionalProperties": true,
              "properties": {
                "kr": { "type": "string" },
                "kpi_ref": { "type": "string" },
                "measurement": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "smart_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "objective", "owner", "start", "target_date", "status", "confidence", "key_results"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "objective": { "type": "string" },
          "owner": { "type": "string" },
          "start": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "target_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "status": { "type": "string", "enum": ["not_started", "in_progress", "at_risk", "blocked", "complete"] },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "baseline": { "type": "string" },
          "target": { "type": "string" },
          "parent_okrs": { "type": "array", "items": { "type": "string" } },
          "parent_objectives": { "type": "array", "items": { "type": "string" } },
          "epic_ref": { "type": ["string", "null"] },
          "key_results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "kr", "metric_type", "due", "status"],
              "additionalProperties": true,
              "properties": {
                "id": { "type": "string" },
                "kr": { "type": "string" },
                "metric_type": { "type": "string", "enum": ["output", "outcome", "milestone"] },
                "baseline": { "type": "string" },
                "target": { "type": "string" },
                "due": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
                "status": { "type": "string", "enum": ["not_started", "in_progress", "at_risk", "blocked", "complete"] }
              }
            }
          },
          "initiatives": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "executive_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "deadline"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "deadline": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    },
    "kpi_index": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "boards_mapping": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
