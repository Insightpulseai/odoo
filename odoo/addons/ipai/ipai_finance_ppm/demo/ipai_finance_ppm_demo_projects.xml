<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Task Stages for Finance PPM projects -->
        <record id="stage_preparation" model="project.task.type">
            <field name="name">Preparation</field>
            <field name="sequence">10</field>
        </record>
        <record id="stage_review" model="project.task.type">
            <field name="name">Review</field>
            <field name="sequence">20</field>
        </record>
        <record id="stage_approval" model="project.task.type">
            <field name="name">Approval</field>
            <field name="sequence">30</field>
        </record>
        <record id="stage_filed" model="project.task.type">
            <field name="name">Filed</field>
            <field name="sequence">40</field>
            <field name="fold" eval="True"/>
        </record>

        <!-- Project: Month-End Close -->
        <record id="project_month_end_close" model="project.project">
            <field name="name">Finance PPM - Month-End Close</field>
            <field name="ipai_ppm_budget_amount">0.00</field>
            <field name="ipai_ppm_cost_center">FIN-CORE</field>
            <field name="ipai_ppm_import_source">demo_seed</field>
            <field name="ipai_ppm_import_batch_id">seed-2026-03-18</field>
            <field name="type_ids" eval="[(6, 0, [ref('stage_preparation'), ref('stage_review'), ref('stage_approval'), ref('stage_filed')])]"/>
        </record>

        <!-- Project: BIR Tax Filing -->
        <record id="project_bir_tax_filing" model="project.project">
            <field name="name">Finance PPM - BIR Tax Filing</field>
            <field name="ipai_ppm_budget_amount">0.00</field>
            <field name="ipai_ppm_cost_center">TAX-CORE</field>
            <field name="ipai_ppm_import_source">demo_seed</field>
            <field name="ipai_ppm_import_batch_id">seed-2026-03-18</field>
            <field name="type_ids" eval="[(6, 0, [ref('stage_preparation'), ref('stage_review'), ref('stage_approval'), ref('stage_filed')])]"/>
        </record>

    </data>
</odoo>
