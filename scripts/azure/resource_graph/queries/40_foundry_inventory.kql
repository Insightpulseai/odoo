Resources
| where type has 'microsoft.cognitiveservices/accounts'
   or type has 'microsoft.search/searchservices'
   or type has 'microsoft.machinelearningservices/workspaces'
| project
    id,
    name,
    type,
    location,
    resourceGroup,
    subscriptionId,
    kind,
    sku = tostring(sku.name),
    tags
| order by type asc, name asc
