# Odoo staging environment variables
# Copy to .env and fill in values
DB_HOST=pg-ipai-odoo.postgres.database.azure.com
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=odoo_staging
ODOO_HTTP_PORT=8069
# Secrets: resolve via Azure Key Vault (kv-ipai-staging)
# ZOHO_SMTP_USER: from Key Vault
# ZOHO_SMTP_PASSWORD: from Key Vault
