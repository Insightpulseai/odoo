<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Default Foundry coordinates (known from Azure project) -->
    <record id="param_foundry_enabled" model="ir.config_parameter">
        <field name="key">ipai_odoo_copilot.foundry_enabled</field>
        <field name="value">True</field>
    </record>
    <record id="param_foundry_api_endpoint" model="ir.config_parameter">
        <field name="key">ipai_odoo_copilot.foundry_api_endpoint</field>
        <field name="value">https://ipai-copilot-resource.services.ai.azure.com</field>
    </record>
    <record id="param_foundry_project" model="ir.config_parameter">
        <field name="key">ipai_odoo_copilot.foundry_project</field>
        <field name="value">ipai-copilot</field>
    </record>
    <record id="param_foundry_agent_name" model="ir.config_parameter">
        <field name="key">ipai_odoo_copilot.foundry_agent_name</field>
        <field name="value">ipai-odoo-copilot</field>
    </record>
    <record id="param_foundry_model" model="ir.config_parameter">
        <field name="key">ipai_odoo_copilot.foundry_model</field>
        <field name="value">gpt-4.1</field>
    </record>
    <!-- auth_oauth requires this for Entra ID token exchange -->
    <record id="param_auth_oauth_header" model="ir.config_parameter">
        <field name="key">auth_oauth.authorization_header</field>
        <field name="value">1</field>
    </record>
    <record id="param_foundry_read_only_mode" model="ir.config_parameter">
        <field name="key">ipai_odoo_copilot.foundry_read_only_mode</field>
        <field name="value">True</field>
    </record>
    <record id="param_foundry_memory_enabled" model="ir.config_parameter">
        <field name="key">ipai_odoo_copilot.foundry_memory_enabled</field>
        <field name="value">False</field>
    </record>
    <record id="param_foundry_search_service" model="ir.config_parameter">
        <field name="key">ipai_odoo_copilot.foundry_search_service</field>
        <field name="value">srch-ipai-dev</field>
    </record>
</odoo>
