{
  "name": "InsightPulseAI Odoo 19 CE Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "mounts": [
    "source=claude-code-config-${devcontainerId},target=/home/vscode/.claude,type=volume",
    "source=${localWorkspaceFolder}/addons/ipai,target=/mnt/extra-addons/ipai,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/addons/oca,target=/mnt/oca,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/addons/local,target=/mnt/extra-addons/local,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "DB_HOST": "db",
    "DB_USER": "odoo",
    "DB_PASSWORD": "odoo",
    "ODOO_HOME": "/opt/odoo"
  },
  "containerUser": "vscode",
  "remoteUser": "vscode",
  "dockerComposeFile": "docker-compose.devcontainer.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/odoo",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/init-firewall.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "redhat.vscode-xml",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",
        "christian-kohler.path-intellisense"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "editor.formatOnSave": true,
        "files.watcherExclude": {
          "**/oca_addons/**": true,
          "**/.git/**": true
        }
      }
    }
  }
}
