{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "references": [
    { "path": "packages/builder-contract" },
    { "path": "packages/builder-foundry-client" },
    { "path": "packages/builder-orchestrator" },
    { "path": "packages/builder-runner" },
    { "path": "packages/builder-evals" },
    { "path": "apps/builder-factory" }
  ],
  "files": []
}
