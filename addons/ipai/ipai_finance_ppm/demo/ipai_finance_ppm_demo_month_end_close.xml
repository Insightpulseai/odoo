        </record>
        <record id="mec_p3_11" model="project.task">
            <field name="name">P3.11 Perform cash flow statement reconciliation</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">11</field>
            <field name="description">Prepare indirect method cash flow statement. Reconcile to actual bank movement for the period.</field>
        </record>
        <record id="mec_p3_12" model="project.task">
            <field name="name">P3.12 Review capitalized development costs</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">12</field>
            <field name="description">Validate development cost capitalization criteria per PAS 38. Review amortization of intangible assets.</field>
        </record>
        <record id="mec_p3_13" model="project.task">
            <field name="name">P3.13 Validate equity roll-forward</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">13</field>
            <field name="description">Prepare statement of changes in equity. Verify dividends, OCI movements, and retained earnings continuity.</field>
