#!/usr/bin/env bash
# Azure CLI safe wrapper
# Encodes lessons from IPAI Odoo Azure deployment
set -euo pipefail

# --- Binary check ---
if ! command -v az >/dev/null 2>&1; then
  echo "error: az CLI not installed" >&2
  exit 127
fi

# --- Auth check ---
if ! az account show >/dev/null 2>&1; then
  echo "error: az not logged in — run 'az login' first (bootstrap skill)" >&2
  exit 1
fi

# --- Build full command string for pattern matching ---
CMD_STRING="$*"

# --- Block interactive commands ---
case "$CMD_STRING" in
  *"containerapp exec"*|*"containerapp ssh"*|*"serial-console"*|*" ssh "*|*" interactive"*)
    echo "error: interactive command blocked by az-safe wrapper" >&2
    echo "hint: interactive commands require TTY and are not skill-compatible" >&2
    exit 2
    ;;
esac

# --- Block broad destructive without explicit override ---
if [[ "${AZ_SAFE_ALLOW_DELETE:-0}" != "1" ]]; then
  case "$CMD_STRING" in
    *"group delete"*|*"account delete"*|*"subscription cancel"*)
      echo "error: broad destructive operation blocked by az-safe wrapper" >&2
      echo "hint: set AZ_SAFE_ALLOW_DELETE=1 if intentional" >&2
      exit 2
      ;;
  esac
fi

# --- REST-first routing for Container App Jobs ---
# Azure CLI arg parser consumes --flags meant for containers.
# Route job create/update through az rest instead.
case "$CMD_STRING" in
  *"containerapp job create"*|*"containerapp job update"*)
    echo "warning: containerapp job create/update should use 'az rest' instead" >&2
    echo "warning: az CLI arg parser may consume container --flags" >&2
    echo "hint: see skills/azure-cli-safe/examples/aca-job-update.sh" >&2
    # Allow through but warn — caller should switch to az rest
    ;;
esac

# --- Force JSON output for query commands ---
case "${1:-}" in
  containerapp|acr|group|deployment|keyvault|resource)
    case "${2:-}" in
      show|list)
        # Append -o json if not already specified
        if [[ "$CMD_STRING" != *"-o "* ]] && [[ "$CMD_STRING" != *"--output"* ]]; then
          exec az "$@" -o json
        fi
        ;;
    esac
    ;;
esac

# --- Pass through ---
exec az "$@"
