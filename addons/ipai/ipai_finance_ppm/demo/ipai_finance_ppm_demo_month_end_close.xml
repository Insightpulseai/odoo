<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================ -->
        <!-- Phase I: Initial & Compliance (D+1) — 15 tasks               -->
        <!-- ============================================================ -->
        <record id="mec_phase1" model="project.task">
            <field name="name">I. Initial &amp; Compliance</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">10</field>
            <field name="priority">1</field>
            <field name="description">D+1: Pre-close validation, bank reconciliation, and compliance checks.</field>
        </record>

        <record id="mec_p1_01" model="project.task">
            <field name="name">P1.01 Validate prior month carry-forward balances</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">1</field>
            <field name="description">Compare opening balances against prior month's closing trial balance. Flag variances > PHP 1,000.</field>
        </record>
        <record id="mec_p1_02" model="project.task">
            <field name="name">P1.02 Confirm bank feeds and statement cutoffs</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">2</field>
            <field name="description">Verify all bank feeds imported through last business day. Confirm cutoff date matches close calendar.</field>
        </record>
        <record id="mec_p1_03" model="project.task">
            <field name="name">P1.03 Reconcile petty cash and revolving funds</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">3</field>
            <field name="description">Count and reconcile petty cash. Match revolving fund disbursements to replenishment entries.</field>
        </record>
        <record id="mec_p1_04" model="project.task">
            <field name="name">P1.04 Review outstanding purchase orders for accrual</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">4</field>
            <field name="description">Identify POs with goods/services received but not yet invoiced. Prepare accrual JEs.</field>
        </record>
        <record id="mec_p1_05" model="project.task">
            <field name="name">P1.05 Verify AR aging and collectibility assessment</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">5</field>
            <field name="description">Run AR aging report. Flag accounts > 90 days for allowance review per PFRS 9.</field>
        </record>
        <record id="mec_p1_06" model="project.task">
            <field name="name">P1.06 Confirm AP sub-ledger to GL reconciliation</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">6</field>
            <field name="description">Reconcile AP sub-ledger total to GL control account. Investigate and clear differences.</field>
        </record>
        <record id="mec_p1_07" model="project.task">
            <field name="name">P1.07 Review employee advances and liquidations</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">7</field>
            <field name="description">Verify all employee advances have corresponding liquidation reports. Flag unliquidated advances > 30 days.</field>
        </record>
        <record id="mec_p1_08" model="project.task">
            <field name="name">P1.08 Validate withholding tax computations (EWT/FWT)</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">8</field>
            <field name="description">Verify expanded and final withholding tax computations match BIR tax rates. Cross-check with vendor master data.</field>
        </record>
        <record id="mec_p1_09" model="project.task">
            <field name="name">P1.09 Confirm VAT input/output reconciliation</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">9</field>
            <field name="description">Reconcile VAT input credits against purchase journal. Match VAT output to sales journal. Prepare VAT payable computation.</field>
        </record>
        <record id="mec_p1_10" model="project.task">
            <field name="name">P1.10 Review fixed asset additions and disposals</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">10</field>
            <field name="description">Confirm all asset additions are capitalized per policy. Verify disposal entries and gain/loss calculations.</field>
        </record>
        <record id="mec_p1_11" model="project.task">
            <field name="name">P1.11 Validate payroll accruals and statutory deductions</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">11</field>
            <field name="description">Verify payroll accrual for partial month. Confirm SSS, PhilHealth, Pag-IBIG, and tax withholding computations.</field>
        </record>
        <record id="mec_p1_12" model="project.task">
            <field name="name">P1.12 Check intercompany transaction matching</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">12</field>
            <field name="description">Run IC matching report. Investigate and resolve unmatched IC entries before close.</field>
        </record>
        <record id="mec_p1_13" model="project.task">
            <field name="name">P1.13 Verify prepaid expense amortization schedules</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">13</field>
            <field name="description">Confirm monthly amortization entries for insurance, rent, and other prepaid items are posted.</field>
        </record>
        <record id="mec_p1_14" model="project.task">
            <field name="name">P1.14 Review foreign currency revaluation rates</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">14</field>
            <field name="description">Update month-end FX rates from BSP. Run unrealized gain/loss revaluation for USD, EUR, JPY exposures.</field>
        </record>
        <record id="mec_p1_15" model="project.task">
            <field name="name">P1.15 Generate pre-close trial balance snapshot</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase1"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">15</field>
            <field name="description">Export pre-close trial balance. This is the baseline for Phase II adjustments.</field>
        </record>

        <!-- ============================================================ -->
        <!-- Phase II: Accruals & Adjustments (D+2) — 18 tasks             -->
        <!-- ============================================================ -->
        <record id="mec_phase2" model="project.task">
            <field name="name">II. Accruals &amp; Adj.</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">20</field>
            <field name="priority">1</field>
            <field name="description">D+2: Post accruals, adjustments, and reclassification entries.</field>
        </record>

        <record id="mec_p2_01" model="project.task">
            <field name="name">P2.01 Post revenue recognition accruals</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">1</field>
            <field name="description">Recognize unbilled revenue per contract milestones and PFRS 15 criteria.</field>
        </record>
        <record id="mec_p2_02" model="project.task">
            <field name="name">P2.02 Post expense accruals for received goods/services</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">2</field>
            <field name="description">Accrue expenses for goods received/services rendered without vendor invoices.</field>
        </record>
        <record id="mec_p2_03" model="project.task">
            <field name="name">P2.03 Post depreciation and amortization entries</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">3</field>
            <field name="description">Run depreciation computation for all asset classes. Post monthly depreciation JE.</field>
        </record>
        <record id="mec_p2_04" model="project.task">
            <field name="name">P2.04 Post allowance for doubtful accounts adjustment</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">4</field>
            <field name="description">Compute expected credit loss per PFRS 9 simplified approach. Post provision adjustment.</field>
        </record>
        <record id="mec_p2_05" model="project.task">
            <field name="name">P2.05 Post inventory valuation adjustments</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">5</field>
            <field name="description">Adjust inventory to lower of cost or NRV. Post write-down entries for slow-moving items.</field>
        </record>
        <record id="mec_p2_06" model="project.task">
            <field name="name">P2.06 Post lease liability and ROU asset entries (PFRS 16)</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">6</field>
            <field name="description">Post monthly lease amortization, interest expense, and lease liability reduction per PFRS 16.</field>
        </record>
        <record id="mec_p2_07" model="project.task">
            <field name="name">P2.07 Post employee benefit accruals (13th month, leave)</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">7</field>
            <field name="description">Accrue proportionate 13th month pay, SIL conversion, and other employee benefits.</field>
        </record>
        <record id="mec_p2_08" model="project.task">
            <field name="name">P2.08 Post intercompany cost allocations</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">8</field>
            <field name="description">Allocate shared costs (IT, admin, facilities) to business units per approved allocation keys.</field>
        </record>
        <record id="mec_p2_09" model="project.task">
            <field name="name">P2.09 Post deferred revenue release</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">9</field>
            <field name="description">Release deferred revenue per amortization schedule. Match to performance obligations.</field>
        </record>
        <record id="mec_p2_10" model="project.task">
            <field name="name">P2.10 Post FX revaluation gain/loss entries</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">10</field>
            <field name="description">Post unrealized FX gain/loss from revaluation. Verify rates match BSP closing rates.</field>
        </record>
        <record id="mec_p2_11" model="project.task">
            <field name="name">P2.11 Post provision for warranties and returns</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">11</field>
            <field name="description">Estimate warranty/return obligations based on historical rates. Adjust provision balance.</field>
        </record>
        <record id="mec_p2_12" model="project.task">
            <field name="name">P2.12 Post reclassification entries (current/non-current)</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">12</field>
            <field name="description">Reclassify long-term liabilities maturing within 12 months to current. Review loan amortization schedules.</field>
        </record>
        <record id="mec_p2_13" model="project.task">
            <field name="name">P2.13 Post tax provision (current and deferred)</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">13</field>
            <field name="description">Compute current income tax provision per CREATE law rates. Calculate deferred tax assets/liabilities for temporary differences.</field>
        </record>
        <record id="mec_p2_14" model="project.task">
            <field name="name">P2.14 Post management fee and royalty accruals</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">14</field>
            <field name="description">Accrue management fees and royalties per intercompany agreements. Apply correct withholding tax rates.</field>
        </record>
        <record id="mec_p2_15" model="project.task">
            <field name="name">P2.15 Post bonus and incentive accruals</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">15</field>
            <field name="description">Accrue performance bonuses and sales incentives based on approved targets and YTD achievement.</field>
        </record>
        <record id="mec_p2_16" model="project.task">
            <field name="name">P2.16 Post insurance premium amortization</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">16</field>
            <field name="description">Amortize prepaid insurance premiums for the current month across applicable cost centers.</field>
        </record>
        <record id="mec_p2_17" model="project.task">
            <field name="name">P2.17 Reconcile suspense and clearing accounts</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">17</field>
            <field name="description">Clear all suspense account balances. Reclassify to correct expense/asset accounts.</field>
        </record>
        <record id="mec_p2_18" model="project.task">
            <field name="name">P2.18 Generate post-adjustment trial balance</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase2"/>
            <field name="stage_id" ref="stage_preparation"/>
            <field name="sequence">18</field>
            <field name="description">Export adjusted trial balance. This is the baseline for Phase III review.</field>
        </record>

        <!-- ============================================================ -->
        <!-- Phase III: WIP & IC (D+3) — 18 tasks                         -->
        <!-- ============================================================ -->
        <record id="mec_phase3" model="project.task">
            <field name="name">III. WIP &amp; IC</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">30</field>
            <field name="priority">1</field>
            <field name="description">D+3: Work-in-progress review, intercompany elimination, and analytical review.</field>
        </record>

        <record id="mec_p3_01" model="project.task">
            <field name="name">P3.01 Review WIP schedule and percentage of completion</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">1</field>
            <field name="description">Validate WIP balances per project. Confirm percentage of completion inputs with project managers.</field>
        </record>
        <record id="mec_p3_02" model="project.task">
            <field name="name">P3.02 Perform IC elimination entries</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">2</field>
            <field name="description">Post intercompany elimination entries for consolidated reporting. Zero out IC revenue/expense and receivable/payable.</field>
        </record>
        <record id="mec_p3_03" model="project.task">
            <field name="name">P3.03 Validate IC profit elimination on inventory</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">3</field>
            <field name="description">Eliminate unrealized profit on intercompany inventory transfers still on hand at month-end.</field>
        </record>
        <record id="mec_p3_04" model="project.task">
            <field name="name">P3.04 Review cost center P&amp;L vs budget variance</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">4</field>
            <field name="description">Compare actual vs budget by cost center. Prepare variance commentary for items > 10% or PHP 100K.</field>
        </record>
        <record id="mec_p3_05" model="project.task">
            <field name="name">P3.05 Perform analytical review of revenue trends</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">5</field>
            <field name="description">Compare current month revenue to prior month and prior year. Investigate unusual variances.</field>
        </record>
        <record id="mec_p3_06" model="project.task">
            <field name="name">P3.06 Perform analytical review of expense trends</field>
            <field name="project_id" ref="project_month_end_close"/>
            <field name="parent_id" ref="mec_phase3"/>
            <field name="stage_id" ref="stage_review"/>
            <field name="sequence">6</field>
            <field name="description">Review expense trends month-over-month. Flag unusual spikes or missing recurring expenses.</field>
