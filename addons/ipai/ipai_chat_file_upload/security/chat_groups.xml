<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_chat_user" model="res.groups">
        <field name="name">Chat User</field>
        <field name="comment">Access to use chat sessions and upload sources</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="base.module_category_productivity"/>
    </record>

    <record id="group_chat_admin" model="res.groups">
        <field name="name">Chat Administrator</field>
        <field name="comment">Full administration of chat sessions, sources, and diagnostics</field>
        <field name="implied_ids" eval="[(4, ref('group_chat_user'))]"/>
        <field name="category_id" ref="base.module_category_productivity"/>
    </record>
</odoo>
