    Settings panel for Google Workspace Add-on configuration.
    Appears in Settings → General Settings under a "Google Workspace" section.
-->
<odoo>

    <record id="res_config_settings_view_form_gws" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.gws</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Google Workspace" string="Google Workspace" data-key="ipai_google_workspace">
                    <h2>Google Workspace Add-ons</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="gws_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="gws_enabled"/>
                                <div class="text-muted">
                                    Enable HTTP endpoints for Gmail, Calendar, Drive, and Sheets add-ons.
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt16 o_settings_container" invisible="not gws_enabled">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="gws_project_number"/>
                                <field name="gws_project_number" placeholder="e.g. 123456789012"/>
                                <div class="text-muted">
                                    Google Cloud project number for ID token audience validation.
                                    Find it in Google Cloud Console → Project settings.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
