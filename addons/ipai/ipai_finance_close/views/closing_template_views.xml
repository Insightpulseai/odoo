<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Template Form -->
    <record id="closing_template_form" model="ir.ui.view">
        <field name="name">closing.template.form</field>
        <field name="model">closing.template</field>
        <field name="arch" type="xml">
            <form string="Closing Template">
                <header>
                    <button name="action_generate_task_list" type="object"
                            string="Generate Task List" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Template Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="closing_type"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                            <field name="line_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Template Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="task_type"/>
                                    <field name="stage"/>
                                    <field name="deadline_reference"/>
                                    <field name="deadline_offset_days"/>
                                    <field name="processor_role"/>
                                    <field name="responsible_role"/>
                                    <field name="dependency_codes"/>
                                    <field name="planned_hours"/>
                                </list>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Template List -->
    <record id="closing_template_list" model="ir.ui.view">
        <field name="name">closing.template.list</field>
        <field name="model">closing.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="closing_type"/>
                <field name="line_count"/>
            </list>
        </field>
    </record>

    <!-- Template Action -->
    <record id="action_closing_template" model="ir.actions.act_window">
        <field name="name">Closing Templates</field>
        <field name="res_model">closing.template</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
