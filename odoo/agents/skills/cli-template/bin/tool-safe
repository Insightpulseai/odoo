#!/usr/bin/env bash
# Generic safe CLI wrapper template
# Copy and customize for each tool
set -euo pipefail

# --- Configuration (override in derived wrappers) ---
TOOL="${TOOL_NAME:-mycli}"
REQUIRE_AUTH="${REQUIRE_AUTH:-1}"
AUTH_CHECK_CMD="${AUTH_CHECK_CMD:-$TOOL auth status}"

# --- Binary check ---
if ! command -v "$TOOL" >/dev/null 2>&1; then
  echo "error: $TOOL not installed" >&2
  exit 127
fi

# --- Auth check (optional) ---
if [[ "$REQUIRE_AUTH" = "1" ]]; then
  if ! eval "$AUTH_CHECK_CMD" >/dev/null 2>&1; then
    echo "error: $TOOL auth not configured — run bootstrap skill first" >&2
    exit 1
  fi
fi

# --- Denylist: destructive verbs ---
case "${1:-}" in
  delete|destroy|remove|purge|drop)
    echo "error: destructive operation '$1' blocked by wrapper" >&2
    echo "hint: add to allowed-ops.md and update wrapper if intentional" >&2
    exit 2
    ;;
esac

# --- Denylist: interactive commands ---
case "${1:-}" in
  ssh|exec|console|interactive|shell|repl)
    echo "error: interactive command '$1' blocked by wrapper" >&2
    exit 2
    ;;
esac

# --- Pass through to real CLI ---
exec "$TOOL" "$@"
