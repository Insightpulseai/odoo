<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ipai_ask_ai_azure.AskAiSystray">
        <div class="o_ipai_ask_ai_systray dropdown">
            <button
                type="button"
                class="btn btn-secondary o-no-caret"
                t-on-click="toggle"
                title="Ask AI"
            >
                <i class="fa fa-magic me-1"/>
                <span>Copilot</span>
            </button>

            <div
                t-if="state.open"
                class="dropdown-menu d-block p-0 o_ipai_ask_ai_panel"
            >
                <div class="border rounded bg-white shadow-sm">
                    <div class="p-2 border-bottom fw-bold d-flex justify-content-between align-items-center">
                        <span><i class="fa fa-magic me-1 text-primary"/>Ask AI</span>
                        <button type="button" class="btn-close btn-sm" t-on-click="toggle"/>
                    </div>

                    <div class="p-2 o_ipai_ask_ai_messages">
                        <t t-foreach="state.messages" t-as="message" t-key="message_index">
                            <div class="mb-2">
                                <div
                                    t-att-class="message.role === 'user' ? 'text-end' : 'text-start'"
                                >
                                    <span
                                        t-att-class="message.role === 'user'
                                            ? 'badge text-bg-primary'
                                            : 'badge text-bg-light border'"
                                    >
                                        <t t-esc="message.role"/>
                                    </span>
                                </div>
                                <div
                                    t-att-class="message.role === 'user'
                                        ? 'mt-1 p-2 rounded bg-primary text-white'
                                        : 'mt-1 p-2 rounded bg-light border'"
                                    style="white-space: pre-wrap; font-size: 0.9rem;"
                                >
                                    <t t-esc="message.text"/>
                                </div>
                            </div>
                        </t>

                        <div t-if="state.loading" class="text-muted small">
                            <i class="fa fa-spinner fa-spin me-1"/>Thinking...
                        </div>

                        <div t-if="state.error" class="alert alert-danger py-2 mt-2 mb-0">
                            <t t-esc="state.error"/>
                        </div>
                    </div>

                    <div class="p-2 border-top">
                        <textarea
                            class="form-control mb-2"
                            rows="3"
                            placeholder="Ask a question..."
                            t-model="state.prompt"
                            t-on-keydown="onKeydown"
                        />
                        <div class="d-flex justify-content-end">
                            <button
                                type="button"
                                class="btn btn-primary btn-sm"
                                t-on-click="send"
                                t-att-disabled="state.loading || !state.prompt.trim()"
                            >
                                <i class="fa fa-paper-plane me-1"/>Send
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
