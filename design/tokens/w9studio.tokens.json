{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "W9 Studio Design Tokens",
    "description": "Design tokens for W9 Studio — commercial recording studio, Makati",
    "source": "Architect deck + Wix audit adaptation",
    "date": "2026-03-27"
  },
  "color": {
    "primitive": {
      "black":      { "value": "#0F0F0F", "description": "Matte black (warmer than pure black)" },
      "white":      { "value": "#FFFFFF" },
      "gold":       { "value": "#FFD700", "description": "W9 Studio primary accent" },
      "cyan":       { "value": "#00FFFF", "description": "Secondary accent" },
      "pink":       { "value": "#FF2E63", "description": "Tertiary accent" },
      "gray-800":   { "value": "#1A1A1A", "description": "Card surfaces" },
      "gray-700":   { "value": "#333333" },
      "gray-500":   { "value": "#6B7280" },
      "gray-400":   { "value": "#9CA3AF" },
      "gray-300":   { "value": "#D1D5DB" }
    },
    "semantic": {
      "background": {
        "primary":   { "value": "{color.primitive.black}" },
        "card":      { "value": "{color.primitive.gray-800}" },
        "accent":    { "value": "{color.primitive.gold}" }
      },
      "text": {
        "primary":   { "value": "{color.primitive.white}" },
        "secondary": { "value": "{color.primitive.gray-400}" },
        "muted":     { "value": "{color.primitive.gray-500}" },
        "on-accent": { "value": "{color.primitive.black}" }
      },
      "border": {
        "default":   { "value": "{color.primitive.gray-700}" },
        "accent":    { "value": "{color.primitive.gold}", "opacity": "0.2" },
        "hover":     { "value": "{color.primitive.gold}", "opacity": "0.4" }
      },
      "action":      { "value": "{color.primitive.gold}" }
    },
    "button": {
      "primary": {
        "fill": "{color.primitive.gold}",
        "text": "{color.primitive.black}",
        "hover-fill": "{color.primitive.gold}",
        "hover-opacity": "0.9"
      },
      "outline": {
        "fill": "transparent",
        "text": "{color.primitive.gray-300}",
        "border": "{color.primitive.gray-500}",
        "hover-text": "{color.primitive.white}",
        "hover-border": "{color.primitive.gray-400}"
      }
    }
  },
  "typography": {
    "fontFamily": {
      "display": "'JetBrains Mono', 'SF Mono', 'Fira Code', monospace",
      "heading": "'Sora', 'Inter', sans-serif",
      "body": "system-ui, -apple-system, 'Segoe UI', sans-serif"
    },
    "scale": {
      "display-hero": { "size": "4.5rem", "lineHeight": "1.1", "letterSpacing": "-0.02em", "weight": "700" },
      "h2":           { "size": "1.875rem", "lineHeight": "1.2", "letterSpacing": "-0.01em", "weight": "700" },
      "h3":           { "size": "1.125rem", "lineHeight": "1.3", "letterSpacing": "0", "weight": "700" },
      "body-lg":      { "size": "1.125rem", "lineHeight": "1.6", "weight": "400" },
      "body":         { "size": "0.875rem", "lineHeight": "1.5", "weight": "400" },
      "body-sm":      { "size": "0.75rem", "lineHeight": "1.4", "weight": "400" },
      "mono-sm":      { "size": "0.75rem", "lineHeight": "1.4", "weight": "400", "family": "display" },
      "eyebrow":      { "size": "0.875rem", "lineHeight": "1", "letterSpacing": "0.1em", "weight": "400", "transform": "uppercase" }
    }
  },
  "spacing": {
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.5rem",
    "6": "2rem",
    "8": "3rem",
    "10": "5rem",
    "12": "8rem"
  },
  "radius": {
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "pill": "9999px"
  },
  "motion": {
    "transition-fast": "0.2s ease",
    "transition-std": "0.3s ease",
    "transition-slow": "0.4s ease"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  }
}
