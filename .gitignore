# =============================================================================
# Odoo Repo .gitignore — Clean State (2026-04-08)
# =============================================================================

# Recursive self-copy (stale duplicates, never re-track)
/odoo/

# =============================================================================
# Deprecated Services & Dirs (fully removed from tracking)
# =============================================================================
archive/
supabase/
.supabase/
automations/n8n/
infra/cloudflare/
infra/digitalocean/
infra/nginx/
infra/superset/
infra/supabase/
infra/supabase-etl/
infra/platform-kit/
infra/ops-control/
infra/spec/
infra/deploy/
infra/terraform/
infra/observability/
infra/github/
infra/mattermost/
infra/n8n/
ops-platform/
web/
platform/
design/
docs-site/
agent-platform/

# =============================================================================
# Secrets (never commit)
# =============================================================================
ops/secrets/age-key.txt
ops/secrets/*.key
*.key
*.pem
*.crt
secrets/
!ssot/secrets/
!ssot/secrets/registry.yaml
.secrets
*.secrets.local
*.secrets.yaml
.env
.env.*
!.env.example
!**/.env.example
**/.supabase-token
scripts/audit/.env
.devcontainer/devcontainer.env
.devcontainer/.env
config/odoo.conf.local
.env.smtp
.env.cloudflare

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# =============================================================================
# Odoo
# =============================================================================
*.pyc
.odoo-bin
filestore/
sessions/
*.log

# Odoo addons — layered architecture: CE → OCA → IPAI
addons/*
!addons/ipai_*/
!addons/ipai_*/**
!addons/tbwa_*/
!addons/tbwa_*/**
!addons/_deprecated/
!addons/_deprecated/**
!addons/ipai/
!addons/ipai/**

# OCA (hydrated by git-aggregator, never committed)
addons/oca/*
!addons/oca/.gitkeep
addons/OCA/
addons/**/__pycache__/
addons/**/*.pyc

# OCA install runtime
.oca_install_state.json
.oca_install.lock

# =============================================================================
# Node.js
# =============================================================================
node_modules/
.pnpm-store/
**/.next/
**/node_modules/
*.tsbuildinfo

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml
docker-compose.local.yml
docker-compose.*.local.yml

# =============================================================================
# IDE
# =============================================================================
!/.vscode/extensions.json
!/.vscode/settings.json
!/.vscode/tasks.json
!/.vscode/launch.json
!/.vscode/ipai_workspace.code-workspace
!/.vscode/README.md
.idea/
*.swp
*.swo
*~
.DS_Store
.cursor/

