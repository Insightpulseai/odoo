# Azure AI Foundry — default provider
AZURE_AI_FOUNDRY_ENDPOINT=https://ipai-copilot-resource.services.ai.azure.com/api/projects/proj-ipai-copilot

# Azure identity (Managed Identity in ACA; service principal in local dev)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# Runtime settings
AGENT_PLATFORM_ENV=development
AGENT_PLATFORM_LOG_LEVEL=INFO
AGENT_PLATFORM_PORT=8000

# Odoo adapter
ODOO_URL=https://odoo.insightpulseai.com
ODOO_DB=odoo
ODOO_USER=
ODOO_API_KEY=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
APPLICATIONINSIGHTS_CONNECTION_STRING=
