<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- BIR deadline reference data for Philippine compliance.
             These ir.config_parameter records store the statutory day-of-month
             for each BIR form type. Used by closing templates to compute
             planned_date from period_end. -->

        <!-- Monthly forms -->
        <record id="bir_deadline_1601c" model="ir.config_parameter">
            <field name="key">ipai_finance_close.bir_deadline_day.1601c</field>
            <field name="value">10</field>
        </record>

        <record id="bir_deadline_0619e" model="ir.config_parameter">
            <field name="key">ipai_finance_close.bir_deadline_day.0619e</field>
            <field name="value">10</field>
        </record>

        <record id="bir_deadline_2550m" model="ir.config_parameter">
            <field name="key">ipai_finance_close.bir_deadline_day.2550m</field>
            <field name="value">20</field>
        </record>

        <!-- Quarterly forms -->
        <record id="bir_deadline_2550q" model="ir.config_parameter">
            <field name="key">ipai_finance_close.bir_deadline_day.2550q</field>
            <field name="value">25</field>
        </record>

        <record id="bir_deadline_1601eq" model="ir.config_parameter">
            <field name="key">ipai_finance_close.bir_deadline_day.1601eq</field>
            <field name="value">25</field>
        </record>

        <record id="bir_deadline_1702q" model="ir.config_parameter">
            <field name="key">ipai_finance_close.bir_deadline_day.1702q</field>
            <field name="value">25</field>
        </record>

        <!-- Annual forms -->
        <record id="bir_deadline_1702rt" model="ir.config_parameter">
            <field name="key">ipai_finance_close.bir_deadline_day.1702rt</field>
            <field name="value">15</field>
        </record>

        <record id="bir_deadline_1604cf" model="ir.config_parameter">
            <field name="key">ipai_finance_close.bir_deadline_day.1604cf</field>
            <field name="value">31</field>
        </record>

    </data>
</odoo>
