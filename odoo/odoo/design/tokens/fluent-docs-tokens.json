{
  "$schema": "fluent-docs-tokens/v1",
  "description": "Semantic docs platform tokens mapped to Fluent 2 theme values",
  "tokens": {
    "layout": {
      "docsNavWidth": { "value": "280px", "description": "Left navigation width" },
      "docsNavWidthCollapsed": { "value": "48px", "description": "Collapsed nav width" },
      "docsContentMaxWidth": { "value": "960px", "description": "Max content pane width" },
      "docsTocWidth": { "value": "240px", "description": "Right TOC pane width" },
      "docsHeaderHeight": { "value": "48px", "description": "Global header height" }
    },
    "color": {
      "docsBgCanvas": { "fluent": "colorNeutralBackground1", "description": "Main content background" },
      "docsBgSidebar": { "fluent": "colorNeutralBackground2", "description": "Sidebar background" },
      "docsBgHeader": { "fluent": "colorNeutralBackground3", "description": "Header background" },
      "docsBgCode": { "fluent": "colorNeutralBackground4", "description": "Code block background" },
      "docsBorderDefault": { "fluent": "colorNeutralStroke1", "description": "Default border" },
      "docsBorderSubtle": { "fluent": "colorNeutralStroke2", "description": "Subtle border" },
      "docsTextPrimary": { "fluent": "colorNeutralForeground1", "description": "Primary text" },
      "docsTextSecondary": { "fluent": "colorNeutralForeground2", "description": "Secondary/muted text" },
      "docsTextLink": { "fluent": "colorBrandForeground1", "description": "Link text" },
      "docsTextCode": { "fluent": "colorNeutralForeground1", "description": "Inline code text" },
      "docsAccentPrimary": { "fluent": "colorBrandBackground", "description": "Primary accent (brand)" },
      "docsAccentSuccess": { "fluent": "colorPaletteGreenForeground1", "description": "Success state" },
      "docsAccentWarning": { "fluent": "colorPaletteYellowForeground1", "description": "Warning state" },
      "docsAccentDanger": { "fluent": "colorPaletteRedForeground1", "description": "Danger/error state" },
      "docsAccentInfo": { "fluent": "colorPaletteBlueForeground2", "description": "Info/note state" }
    },
    "typography": {
      "docsTitle": { "fluent": "typographyStyles.title1", "description": "Page title (H1)" },
      "docsHeading": { "fluent": "typographyStyles.subtitle1", "description": "Section heading (H2)" },
      "docsSubheading": { "fluent": "typographyStyles.subtitle2", "description": "Subsection (H3)" },
      "docsBody": { "fluent": "typographyStyles.body1", "description": "Body text" },
      "docsCaption": { "fluent": "typographyStyles.caption1", "description": "Captions and metadata" },
      "docsCode": { "fontFamily": "'Cascadia Code', 'JetBrains Mono', monospace", "fontSize": "14px", "description": "Code blocks" }
    },
    "spacing": {
      "docsGapSmall": { "fluent": "spacingHorizontalS", "description": "Small gap (8px)" },
      "docsGapMedium": { "fluent": "spacingHorizontalM", "description": "Medium gap (12px)" },
      "docsGapLarge": { "fluent": "spacingHorizontalL", "description": "Large gap (16px)" },
      "docsGapXLarge": { "fluent": "spacingHorizontalXL", "description": "Extra large gap (20px)" },
      "docsSectionGap": { "fluent": "spacingVerticalXXL", "description": "Between major sections (32px)" }
    },
    "elevation": {
      "docsCardResting": { "fluent": "shadow4", "description": "Card resting state" },
      "docsCardHover": { "fluent": "shadow8", "description": "Card hover state" },
      "docsDialogShadow": { "fluent": "shadow64", "description": "Dialog/overlay shadow" }
    },
    "borderRadius": {
      "docsSmall": { "fluent": "borderRadiusSmall", "description": "Small radius (2px)" },
      "docsMedium": { "fluent": "borderRadiusMedium", "description": "Medium radius (4px)" },
      "docsLarge": { "fluent": "borderRadiusLarge", "description": "Large radius (6px)" }
    }
  }
}
