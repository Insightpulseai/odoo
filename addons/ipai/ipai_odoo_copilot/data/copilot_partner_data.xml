<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Pulser partner — the "bot" identity for AI responses.
         Separate from OdooBot (base.partner_root) to avoid conflicts.
         Email is informational only (not a real mailbox). -->
    <record id="partner_copilot" model="res.partner">
        <field name="name">Pulser</field>
        <field name="email">pulser@insightpulseai.com</field>
        <field name="active" eval="True"/>
        <field name="is_company" eval="False"/>
        <field name="type">contact</field>
    </record>
</odoo>
