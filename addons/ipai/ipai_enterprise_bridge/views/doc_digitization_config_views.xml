<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ipai_doc_digitization_config_view_form" model="ir.ui.view">
        <field name="name">ipai.doc.digitization.config.form</field>
        <field name="model">ipai.doc.digitization.config</field>
        <field name="arch" type="xml">
            <form string="Document Digitization Configuration">
                <sheet>
                    <group>
                        <group string="Provider">
                            <field name="name"/>
                            <field name="provider"/>
                            <field name="endpoint"
                                   placeholder="https://your-doc-ai.cognitiveservices.azure.com"/>
                            <field name="model"/>
                        </group>
                        <group string="Processing">
                            <field name="storage_mode"/>
                            <field name="async_enabled"/>
                            <field name="min_file_size"/>
                        </group>
                    </group>
                    <group string="Test Results">
                        <group>
                            <field name="last_test_date"/>
                            <field name="last_test_result"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_test_connection"
                            type="object"
                            string="Test Connection"
                            class="btn-primary"
                            icon="fa-plug"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
