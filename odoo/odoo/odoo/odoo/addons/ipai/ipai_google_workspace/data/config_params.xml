<odoo>
    <data noupdate="1">

        <!-- GWS Add-on disabled by default -->
        <function model="ir.config_parameter" name="set_param">
            <value>ipai_gws.enabled</value>
            <value>False</value>
        </function>

        <!-- Project number placeholder — set in Settings after installation -->
        <function model="ir.config_parameter" name="set_param">
            <value>ipai_gws.project_number</value>
            <value></value>
        </function>

    </data>
</odoo>
