{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VMOKRAPI-SPATRES Platform Strategy",
  "description": "Schema for ssot/governance/platform-strategy-2026.yaml",
  "type": "object",
  "required": [
    "schema_version",
    "last_updated",
    "vision",
    "mission",
    "kras",
    "objectives",
    "okrs",
    "kpis",
    "strategies",
    "programs",
    "activities",
    "tasks",
    "resources",
    "evidence_policy",
    "risks",
    "spatres"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "last_updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "vision": { "type": "string" },
    "mission": { "type": "string" },
    "strategy": { "type": "object" },
    "platform_doctrine": { "type": "object" },
    "current_context": { "type": "object" },
    "kras": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "owner"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "owner": { "type": "string" }
        }
      }
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "target_date", "kra_ref"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "owner": { "type": "string" },
          "kra_ref": {
            "type": "array",
            "items": { "type": "string" }
          },
          "target_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "status": {
            "type": "string",
            "enum": ["not_started", "in_progress", "completed", "blocked"]
          }
        }
      }
    },
    "okrs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "objective_ref", "key_results"],
        "properties": {
          "id": { "type": "string" },
          "objective_ref": { "type": "string" },
          "title": { "type": "string" },
          "owner": { "type": "string" },
          "horizon_end": { "type": "string" },
          "key_results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "description", "target", "measure"],
              "properties": {
                "id": { "type": "string" },
                "description": { "type": "string" },
                "target": {},
                "measure": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "kpis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "formula": { "type": "string" },
          "target": {},
          "unit": { "type": "string" }
        }
      }
    },
    "strategies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "supports_objectives": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "programs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "strategies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "owner": { "type": "string" }
        }
      }
    },
    "activities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "program_ref": { "type": "string" },
          "name": { "type": "string" },
          "owner": { "type": "string" }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "owner", "activity_ref"],
        "properties": {
          "id": { "type": "string" },
          "activity_ref": { "type": "string" },
          "name": { "type": "string" },
          "owner": { "type": "string" },
          "due": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["not_started", "in_progress", "completed", "blocked"]
          },
          "priority": { "type": "string" },
          "blocker": { "type": "string" }
        },
        "if": {
          "properties": { "status": { "const": "blocked" } }
        },
        "then": {
          "required": ["blocker"]
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "people": { "type": "array" },
        "systems": { "type": "array" },
        "repositories": { "type": "array" },
        "infrastructure": { "type": "array" }
      }
    },
    "evidence_policy": {
      "type": "object",
      "required": ["required_types", "rule"],
      "properties": {
        "required_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rule": { "type": "string" }
      }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "likelihood", "impact", "mitigation"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "likelihood": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "impact": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "mitigation": { "type": "string" }
        }
      }
    },
    "spatres": {
      "type": "object",
      "required": ["scope", "people", "artifacts", "timeline", "risks", "environments", "success"],
      "properties": {
        "scope": { "type": "array", "items": { "type": "string" } },
        "people": { "type": "array", "items": { "type": "string" } },
        "artifacts": { "type": "array", "items": { "type": "string" } },
        "timeline": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "environments": { "type": "array", "items": { "type": "string" } },
        "success": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
