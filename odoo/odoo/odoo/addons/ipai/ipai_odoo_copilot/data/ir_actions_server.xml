<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="action_server_ensure_foundry_agent"
            model="ir.actions.server">
        <field name="name">IPAI Foundry: Ensure Agent</field>
        <field name="model_id" ref="base.model_res_config_settings"/>
        <field name="state">code</field>
        <field name="code">
ok, msg = env["ipai.foundry.service"].ensure_agent()
if not ok:
    raise UserError(msg)
        </field>
    </record>
</odoo>
