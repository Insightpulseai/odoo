#!/usr/bin/env bash
# GitHub CLI safe wrapper
set -euo pipefail

# --- Binary check ---
if ! command -v gh >/dev/null 2>&1; then
  echo "error: gh CLI not installed" >&2
  exit 127
fi

# --- Auth check ---
if ! gh auth status >/dev/null 2>&1; then
  echo "error: gh not authenticated — run 'gh auth login' first (bootstrap skill)" >&2
  exit 1
fi

# --- Build command string ---
CMD_STRING="$*"

# --- Block destructive operations ---
case "$CMD_STRING" in
  *"repo delete"*|*"release delete"*|*"repo archive"*)
    echo "error: destructive operation blocked by gh-safe wrapper" >&2
    exit 2
    ;;
esac

# --- Block force-push patterns ---
case "$CMD_STRING" in
  *"--force"*|*"-f push"*)
    echo "error: force operations blocked by gh-safe wrapper" >&2
    exit 2
    ;;
esac

# --- Pass through ---
exec gh "$@"
