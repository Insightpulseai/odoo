<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-02-22T00:00:00.000Z" agent="ChatGPT" version="24.7.0" type="device">
  <diagram id="oca-gov-flow" name="OCA Governance Flow (Allowlist + Risk-Tier)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="OCA Governance Flow — Allowlist + Surgical Risk-Tier Gate (Odoo 19 CE)" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="20" width="1280" height="40" as="geometry"/>
        </mxCell>

        <!-- Lanes -->
        <mxCell id="lane_dev" value="Developer Change" style="swimlane;html=1;rounded=1;startSize=28;horizontal=0;fillColor=#ffffff;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="300" height="760" as="geometry"/>
        </mxCell>

        <mxCell id="lane_repo" value="Repo SSOT" style="swimlane;html=1;rounded=1;startSize=28;horizontal=0;fillColor=#ffffff;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="380" y="90" width="340" height="760" as="geometry"/>
        </mxCell>

        <mxCell id="lane_ci" value="CI Gates (PR Checks)" style="swimlane;html=1;rounded=1;startSize=28;horizontal=0;fillColor=#ffffff;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="740" y="90" width="330" height="760" as="geometry"/>
        </mxCell>

        <mxCell id="lane_ops" value="Ops / Runtime Outcome" style="swimlane;html=1;rounded=1;startSize=28;horizontal=0;fillColor=#ffffff;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="1090" y="90" width="250" height="760" as="geometry"/>
        </mxCell>

        <!-- Developer actions -->
        <mxCell id="dev_choose" value="Decide change type:\nA) Add/Remove OCA addon\nB) Modify allowlist mapping\nC) Touch high-risk addon" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_dev">
          <mxGeometry x="20" y="60" width="260" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="dev_edit_allowlist" value="Edit\naddons/oca/ALLOWLIST.yaml\n(addon repo/path, risk tier)" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_dev">
          <mxGeometry x="20" y="200" width="260" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="dev_symlink" value="Create/Update symlink\naddons/oca/selected/<addon>\n→ addons/oca/repos/<repo>/<path>" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_dev">
          <mxGeometry x="20" y="310" width="260" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="dev_pr" value="Open PR\n(PR labels optional)\n- for high-risk: add label" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_dev">
          <mxGeometry x="20" y="430" width="260" height="90" as="geometry"/>
        </mxCell>

        <!-- Repo artifacts -->
        <mxCell id="repo_allowlist" value="ALLOWLIST.yaml (SSOT)\n- allowed addons\n- repo/path\n- risk: low/med/high\n- required labels" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_repo">
          <mxGeometry x="20" y="80" width="300" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="repo_repos" value="OCA Submodules\naddons/oca/repos/*\n(never in addons_path)" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_repo">
          <mxGeometry x="20" y="230" width="300" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="repo_selected" value="Selected Allowlist\naddons/oca/selected/*\n(symlink exposure only)" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_repo">
          <mxGeometry x="20" y="340" width="300" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="repo_plan" value="Install Plan / Waves\n(docs + runbooks)\n- Wave 1..4\n- testing gates" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_repo">
          <mxGeometry x="20" y="450" width="300" height="90" as="geometry"/>
        </mxCell>

        <!-- CI gates -->
        <mxCell id="ci_allowlist" value="Gate 1: Allowlist\nverify_oca_allowlist.py\n- selected entries must be allowlisted\n- symlink-only\n- target matches repo/path" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_ci">
          <mxGeometry x="20" y="90" width="290" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="ci_risk" value="Gate 2: Risk-Tier (Surgical)\nverify_oca_risk_tier.py\n- triggers only if:\n  a) selected/<high-risk> touched OR\n  b) allowlist diff touches high-risk keys\n- requires PR label" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_ci">
          <mxGeometry x="20" y="240" width="290" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="ci_quality" value="Gate 3: Security/Quality (optional)\n- SonarCloud\n- GitGuardian\n- tests/lint" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_ci">
          <mxGeometry x="20" y="400" width="290" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="ci_merge" value="Merge Allowed\n(if all gates pass)\n+ required approvals met" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_ci">
          <mxGeometry x="20" y="530" width="290" height="90" as="geometry"/>
        </mxCell>

        <!-- Ops outcome -->
        <mxCell id="ops_addons_path" value="Odoo addons_path stays tight:\n.../addons/oca/selected\n(no repos/* exposure)" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_ops">
          <mxGeometry x="20" y="120" width="210" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="ops_install" value="Controlled Install\n- apply wave plan\n- staging tests\n- prod window (finance)\n- roll-forward bias" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_ops">
          <mxGeometry x="20" y="240" width="210" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="ops_audit" value="Auditability\n- allowlist history\n- PR labels\n- checks evidence" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="lane_ops">
          <mxGeometry x="20" y="390" width="210" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="ops_result" value="Outcome:\nOnly approved OCA addons are installable/exposed\nHigh-risk changes are explicitly approved" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontStyle=1;" vertex="1" parent="lane_ops">
          <mxGeometry x="20" y="510" width="210" height="120" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="dev_choose" target="dev_edit_allowlist">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="dev_edit_allowlist" target="dev_symlink">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="dev_symlink" target="dev_pr">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="dev_edit_allowlist" target="repo_allowlist">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="dev_symlink" target="repo_selected">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="repo_allowlist" target="ci_allowlist">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="repo_selected" target="ci_allowlist">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="ci_allowlist" target="ci_risk">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e9" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="ci_risk" target="ci_quality">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e10" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="ci_quality" target="ci_merge">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e11" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="ci_merge" target="ops_install">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e12" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="ops_install" target="ops_result">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e13" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="ops_addons_path" target="ops_install">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
