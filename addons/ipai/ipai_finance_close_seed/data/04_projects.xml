<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Project 1: Month-End Close (3-stage: Preparation → Review → Approval)
             ============================================================ -->

        <record id="project_month_end_close" model="project.project">
            <field name="name">Finance PPM - Month-End Close</field>
            <field name="active" eval="True"/>
            <field name="description">Month-End Close - Finance SSC | 9 employees | 39 closing tasks across 3 stages (Preparation → Review → Approval)</field>
            <field name="allow_subtasks" eval="True"/>
            <field name="allow_task_dependencies" eval="True"/>
            <field name="allow_milestones" eval="True"/>
            <field name="type_ids" eval="[
                (4, ref('stage_me_preparation')),
                (4, ref('stage_me_review')),
                (4, ref('stage_me_approval')),
                (4, ref('stage_done')),
                (4, ref('stage_cancelled')),
            ]"/>
        </record>

        <!-- ============================================================
             Project 2: BIR Tax Filing (4-stage: Preparation → Report Approval → Payment Approval → Filing & Payment)
             ============================================================ -->

        <record id="project_bir_tax_filing" model="project.project">
            <field name="name">Finance PPM - BIR Tax Filing</field>
            <field name="active" eval="True"/>
            <field name="description">BIR Tax Filing - Finance SSC | 9 employees | 50 BIR tasks | 4 stages (Preparation → Report Approval → Payment Approval → Filing &amp; Payment)</field>
            <field name="allow_subtasks" eval="True"/>
            <field name="allow_task_dependencies" eval="True"/>
            <field name="allow_milestones" eval="True"/>
            <field name="type_ids" eval="[
                (4, ref('stage_bir_preparation')),
                (4, ref('stage_bir_report_approval')),
                (4, ref('stage_bir_payment_approval')),
                (4, ref('stage_bir_filing_payment')),
                (4, ref('stage_done')),
                (4, ref('stage_cancelled')),
            ]"/>
        </record>

    </data>
</odoo>
